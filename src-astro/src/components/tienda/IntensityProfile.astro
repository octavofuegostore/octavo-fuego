---
/**
 * IntensityProfile — Visual meter bars for rapé intensity/olfactory profiles
 * Replaced HTML table with visual progress bars for each metric
 *
 * @source ESP.html "Perfil de Intensidad y Notas Olfativas" | ENG.html same | PT.html same
 */

import type { Locale } from '@/i18n';
import { useTranslations } from '@/i18n';
import { products } from '@/data/products';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

// Intensity levels mapped to meter percentage
const intensityLevels: Record<string, number> = {
  'Muy Alta': 95, 'Very High': 95, 'Muito Alta': 95,
  'Alta': 80, 'High': 80, 'Alta': 80,
  'Media / Alta': 70, 'Medium / High': 70, 'Média / Alta': 70,
  'Media': 55, 'Medium': 55, 'Média': 55,
  'Media / Suave': 40, 'Medium / Soft': 40, 'Média / Suave': 40,
};

// Build intensity rows from product data
const rows = products
  .sort((a, b) => a.varietyOrder - b.varietyOrder)
  .map((p) => ({
    name: p.nombre[locale],
    fuerza: p.intensidad.fuerza[locale],
    aroma: p.intensidad.aroma[locale],
    nivel: p.intensidad.nivel[locale],
    fuerzaLevel: intensityLevels[p.intensidad.fuerza[locale]] || 50,
  }));
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <span class="section-label text-xs uppercase tracking-[0.2em] font-bold text-[var(--color-action-primary)] border-b border-gray-200 pb-3 mb-10 block">
      {t.tienda.intensity}
    </span>

    <div class="space-y-8">
      {rows.map((row) => (
        <div class="border border-gray-200 rounded-[var(--radius-card)] p-6 hover:shadow-[var(--shadow-hover)] transition-all duration-200">
          <div class="flex items-center justify-between mb-5">
            <h3 class="font-display text-lg font-semibold text-[var(--near-black)]">{row.name}</h3>
            <span class="text-xs text-[var(--color-action-primary)] font-semibold bg-[var(--color-action-primary)]/5 px-3 py-1 rounded-full">
              {row.nivel}
            </span>
          </div>

          <div class="space-y-4">
            <!-- Sensory Strength meter -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-[0.7rem] uppercase tracking-[0.1em] font-semibold text-[var(--ceniza)]">
                  {locale === 'es' ? 'Fuerza Sensorial' : locale === 'en' ? 'Sensory Strength' : 'Força Sensorial'}
                </span>
                <span class="text-xs text-[var(--near-black)] font-medium">{row.fuerza}</span>
              </div>
              <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden">
                <div
                  class="h-full rounded-full transition-all duration-700"
                  style={`width: ${row.fuerzaLevel}%; background: linear-gradient(90deg, var(--color-action-primary), #2d6b4f)`}
                ></div>
              </div>
            </div>

            <!-- Aromatic Profile -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-[0.7rem] uppercase tracking-[0.1em] font-semibold text-[var(--ceniza)]">
                  {locale === 'es' ? 'Perfil Aromático' : locale === 'en' ? 'Aromatic Profile' : 'Perfil Aromático'}
                </span>
                <span class="text-xs text-[var(--near-black)] font-medium italic">{row.aroma}</span>
              </div>
              <div class="text-sm text-[var(--ceniza)] leading-relaxed">
                {row.aroma}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
