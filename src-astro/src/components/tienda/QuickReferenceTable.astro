---
/**
 * QuickReferenceTable — Card-based reference for 5 rapé varieties
 * Replaced HTML table with modern card grid layout
 *
 * @source ESP.html "Tabla de Referencia Rápida" | ENG.html "Quick Reference Table" | PT.html "Tabela de Referência Rápida"
 */

import type { Locale } from '@/i18n';
import { useTranslations } from '@/i18n';
import { products } from '@/data/products';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

// Build card rows from product data
const rows = products
  .sort((a, b) => a.varietyOrder - b.varietyOrder)
  .map((p) => ({
    name: p.nombre[locale],
    enfoque: p.enfoque[locale],
    uso: p.usoRecomendado[locale],
    varietyOrder: p.varietyOrder,
  }));
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <span class="section-label text-xs uppercase tracking-[0.2em] font-bold text-[var(--color-action-primary)] border-b border-gray-200 pb-3 mb-10 block">
      {t.tienda.quickRef}
    </span>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {rows.map((row) => (
        <div class="border border-gray-200 rounded-[var(--radius-card)] p-6 hover:shadow-[var(--shadow-hover)] hover:border-[var(--color-action-primary)] transition-all duration-200 bg-white">
          <div class="flex items-start justify-between mb-4">
            <h3 class="font-display text-lg font-semibold text-[var(--near-black)]">{row.name}</h3>
            <span class="text-[0.65rem] uppercase tracking-wider text-[var(--color-action-primary)] font-bold bg-[var(--color-action-primary)]/5 px-2 py-1 rounded-full">
              #{row.varietyOrder}
            </span>
          </div>
          <div class="space-y-3">
            <div>
              <span class="text-[0.65rem] uppercase tracking-[0.12em] font-semibold text-[var(--ceniza)] block mb-1">
                {locale === 'es' ? 'Enfoque Principal' : locale === 'en' ? 'Main Focus' : 'Foco Principal'}
              </span>
              <p class="text-sm text-[var(--near-black)]">{row.enfoque}</p>
            </div>
            <div>
              <span class="text-[0.65rem] uppercase tracking-[0.12em] font-semibold text-[var(--ceniza)] block mb-1">
                {locale === 'es' ? 'Uso Recomendado' : locale === 'en' ? 'Recommended Use' : 'Uso Recomendado'}
              </span>
              <p class="text-sm text-[var(--near-black)]">{row.uso}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
