---
import { cn } from '@/lib/utils';

interface Props {
  nombre: string;
  etnia: string;
  precio: number;
  imagen: string;
  slug: string;
  href?: string;
  class?: string;
  showQuickView?: boolean;
}

const { nombre, etnia, precio, imagen, slug, href = `#`, class: className, showQuickView = true } = Astro.props;

const formattedPrice = new Intl.NumberFormat('es-CO', {
  style: 'currency',
  currency: 'COP',
  minimumFractionDigits: 0,
}).format(precio);
---

<div class={cn("group bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-hover)] hover:-translate-y-1 transition-all duration-200", className)}>
  <a href={href} class="block">
    <!-- Image -->
    <div class="aspect-square bg-gray-50 rounded-t-[var(--radius-card)] overflow-hidden">
      <img 
        src={imagen} 
        alt={nombre}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        transition:name={`product-image-${slug}`}
      />
    </div>
    
    <!-- Content -->
    <div class="p-6">
      <p class="text-ceniza text-xs uppercase tracking-widest mb-2">{etnia}</p>
      <h3 class="font-display text-lg font-semibold mb-2 text-[var(--near-black)]" transition:name={`product-title-${slug}`}>{nombre}</h3>
      <div class="flex items-center justify-between">
        <span class="text-[var(--verde-botanico)] font-semibold">{formattedPrice}</span>
        <span class="text-sm text-ceniza opacity-0 group-hover:opacity-100 transition-opacity">
          Ver →
        </span>
      </div>
    </div>
  </a>
  
  <!-- Action Buttons - Appears on hover -->
  <div class="px-6 pb-6 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
    {showQuickView && (
      <button 
        class="flex-1 bg-gray-100 text-[var(--near-black)] py-3 text-sm font-medium hover:bg-gray-200 transition-colors rounded-[var(--radius-button)] quick-view-btn"
        data-slug={slug}
        data-nombre={nombre}
        data-etnia={etnia}
        data-precio={precio}
        data-imagen={imagen}
        aria-label={`Vista rápida de ${nombre}`}
      >
        Vista rápida
      </button>
    )}
    <button 
      class="flex-1 bg-[var(--near-black)] text-white py-3 text-sm font-medium hover:bg-[var(--verde-botanico)] transition-colors rounded-[var(--radius-button)]"
      data-product-id={slug}
      aria-label={`Añadir ${nombre} al carrito`}
    >
      Añadir
    </button>
  </div>
</div>
