---
/**
 * ProphecyTeaser — Homepage teaser for the full prophecy page
 * Shows ignition quote + "¿Somos nosotros el Nuevo Pueblo?" hook + CTA
 *
 * @source ProfeciaOctavoFuego-ESPANOL.html — ignition-quote + final-question
 */

import type { Locale } from '@/i18n';
import { useTranslations } from '@/i18n';
import type { Prophecy } from '@/data/prophecy';

interface Props {
  prophecy: Prophecy;
  locale: Locale;
}

const { prophecy, locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="py-20 md:py-28 bg-[var(--papel)]">
  <div class="max-w-3xl mx-auto px-6 md:px-12 text-center">
    <!-- Section label -->
    <span class="text-[0.7rem] uppercase tracking-[0.4em] text-[var(--color-action-primary)] font-bold block mb-8">
      {t.profecia.teaserTitle}
    </span>

    <!-- Ignition quote -->
    <blockquote class="font-display text-xl md:text-2xl leading-relaxed text-[var(--near-black)] italic mb-8">
      {prophecy.ignition.quote[locale]}
    </blockquote>

    <!-- Hook question -->
    <p class="text-lg md:text-xl text-[var(--ceniza)] mb-10 font-light">
      {prophecy.finalQuestion.question[locale]}
    </p>

    <!-- CTA -->
    <a
      href={`/${locale}/profecia`}
      class="inline-block border-2 border-[var(--color-action-primary)] text-[var(--color-action-primary)] px-8 py-4 text-sm font-semibold tracking-wide hover:bg-[var(--color-action-primary)] hover:text-white transition-all duration-200 rounded-[var(--radius-button)]"
    >
      {t.profecia.cta} →
    </a>
  </div>
</section>
