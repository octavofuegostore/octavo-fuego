---
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n';
import { products } from '@/data/products';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  locale?: Locale;
}

const { locale = 'es' } = Astro.props;
const t = useTranslations(locale);
const baseUrl = `/${locale}`;
---

<header class="fixed top-0 left-0 right-0 z-50 h-16 md:h-20 bg-white border-b border-gray-100">
  <nav class="max-w-7xl mx-auto h-full px-6 md:px-12 flex items-center justify-between">
    <!-- Logo -->
    <a href={baseUrl} class="flex items-center gap-3 font-display text-xl md:text-2xl font-bold tracking-tight text-[var(--near-black)]">
      <img src="/images/octavofuego-logo.png" alt="Octavo Fuego" class="h-8 w-auto" />
      {t.common.brand}
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8">
      <!-- Catálogo Dropdown -->
      <div class="relative group">
        <button
          class="flex items-center gap-1 text-sm font-medium text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors"
          aria-expanded="false"
          aria-haspopup="true"
        >
          {t.nav.tienda}
          <Icon name="solar:alt-arrow-down-bold-duotone" class="w-4 h-4 transition-transform group-hover:rotate-180" />
        </button>

        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
          <div class="bg-white border border-gray-200 shadow-[var(--shadow-hover)] py-2 min-w-[200px] rounded-[var(--radius-card)]">
            {products
              .sort((a, b) => a.varietyOrder - b.varietyOrder)
              .map((product) => (
                <a
                  href={`${baseUrl}/tienda/rape/${product.slug}`}
                  class="block px-4 py-2 text-sm text-[var(--ceniza)] hover:text-[var(--near-black)] hover:bg-gray-50 transition-colors"
                >
                  {product.nombre[locale]}
                </a>
              ))}
            <div class="border-t border-gray-100 mt-2 pt-2">
              <a
                href={`${baseUrl}/tienda`}
                class="block px-4 py-2 text-sm text-[var(--verde-botanico)] hover:text-[var(--near-black)] transition-colors"
              >
                {t.nav.verTienda}
              </a>
            </div>
          </div>
        </div>
      </div>

      <a href={`${baseUrl}/profecia`} class="text-sm font-medium text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors">
        {t.nav.profecia}
      </a>
      <a href="/blog" class="text-sm font-medium text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors">
        {t.nav.blog}
      </a>
      <a href="/nosotros" class="text-sm font-medium text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors">
        {t.nav.nosotros}
      </a>
      <a href="/contacto" class="text-sm font-medium text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors">
        {t.nav.contacto}
      </a>
    </div>

    <!-- Right side: Language + Cart -->
    <div class="flex items-center gap-3">
      <LanguageSwitcher locale={locale} />

      <a href="/carrito" class="relative p-2 text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors">
        <Icon name="solar:bag-2-bold-duotone" class="w-6 h-6" />
        <span class="absolute -top-1 -right-1 w-5 h-5 bg-[var(--verde-botanico)] text-white text-xs flex items-center justify-center hidden">
          0
        </span>
      </a>

      <!-- Mobile menu button -->
      <button class="md:hidden p-2 text-[var(--ceniza)] hover:text-[var(--near-black)]" aria-label="Menu">
        <Icon name="solar:hamburger-menu-bold-duotone" class="w-6 h-6" />
      </button>
    </div>
  </nav>
</header>

<div class="h-16 md:h-20"></div>
