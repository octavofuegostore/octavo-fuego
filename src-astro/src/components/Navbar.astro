---
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n';
import { products } from '@/data/products';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  locale?: Locale;
}

const { locale = 'es' } = Astro.props;
const t = useTranslations(locale);
const baseUrl = `/${locale}`;
---

<header class="fixed top-[env(safe-area-inset-top,0px)] left-0 right-0 z-50 h-16 md:h-20 bg-white border-b border-gray-100">
  <nav class="max-w-7xl mx-auto h-full px-6 md:px-12 flex items-center justify-between">
    <!-- Logo -->
      <a href={baseUrl} class="flex items-center gap-3 font-display text-base sm:text-lg md:text-2xl font-bold tracking-tight text-[var(--near-black)]">
      <img src="/images/octavofuego-logo.png" alt="Octavo Fuego" class="h-8 w-auto" />
      {t.common.brand}
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8">
      <!-- Catálogo Dropdown -->
      <div class="relative group">
        <button
          class="flex items-center gap-1 text-sm font-medium text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors"
          aria-expanded="false"
          aria-haspopup="true"
        >
          {t.nav.tienda}
          <Icon name="solar:alt-arrow-down-bold-duotone" class="w-4 h-4 transition-transform group-hover:rotate-180" />
        </button>

        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
          <div class="bg-white border border-gray-200 shadow-[var(--shadow-hover)] py-2 min-w-[200px] rounded-[var(--radius-card)]">
            {products
              .sort((a, b) => a.varietyOrder - b.varietyOrder)
              .map((product) => (
                <a
                  href={`${baseUrl}/tienda/rape/${product.slug}`}
                  class="block px-4 py-2 text-sm text-[var(--ceniza)] hover:text-[var(--near-black)] hover:bg-gray-50 transition-colors"
                >
                  {product.nombre[locale]}
                </a>
              ))}
            <div class="border-t border-gray-100 mt-2 pt-2">
              <a
                href={`${baseUrl}/tienda`}
                class="block px-4 py-2 text-sm text-[var(--color-action-primary)] hover:text-[var(--near-black)] transition-colors"
              >
                {t.nav.verTienda}
              </a>
            </div>
          </div>
        </div>
      </div>

      <a href={`${baseUrl}/profecia`} class="text-sm font-medium text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors">
        {t.nav.profecia}
      </a>
      <a href="/blog" class="text-sm font-medium text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors">
        {t.nav.blog}
      </a>
      <a href="/nosotros" class="text-sm font-medium text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors">
        {t.nav.nosotros}
      </a>
      <a href="/contacto" class="text-sm font-medium text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors">
        {t.nav.contacto}
      </a>
    </div>

    <!-- Right side: Language + Cart -->
    <div class="flex items-center gap-1.5 sm:gap-3">
      <LanguageSwitcher locale={locale} />

      <a href="/carrito" class="relative p-2 text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors">
        <Icon name="solar:bag-2-bold-duotone" class="w-6 h-6" />
        <span class="absolute -top-1 -right-1 w-5 h-5 bg-[var(--color-action-primary)] text-white text-xs flex items-center justify-center hidden">
          0
        </span>
      </a>

      <!-- Mobile menu button -->
      <button id="hamburger-btn" class="md:hidden p-2 text-[var(--ceniza)] hover:text-[var(--near-black)]" aria-label="Menu" aria-expanded="false">
        <Icon name="solar:hamburger-menu-bold-duotone" class="w-6 h-6" />
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Menu Drawer -->
<div id="mobile-menu" class="hidden fixed inset-0 z-40" role="dialog" aria-modal="true" aria-label="Menú de navegación">
  <div id="mobile-menu-overlay" class="absolute inset-0 bg-black/50 transition-opacity duration-300"></div>
  <div class="absolute top-0 right-0 h-full w-72 max-w-[85vw] bg-white shadow-2xl flex flex-col p-6 pt-[calc(4rem+env(safe-area-inset-top,0px))]">
    <nav class="flex flex-col gap-4">
      <a href={`${baseUrl}/tienda`} class="text-lg font-medium text-[var(--near-black)] hover:text-[var(--color-action-primary)] transition-colors py-2">{t.nav.tienda}</a>
      <a href={`${baseUrl}/profecia`} class="text-lg font-medium text-[var(--near-black)] hover:text-[var(--color-action-primary)] transition-colors py-2">{t.nav.profecia}</a>
      <a href="/blog" class="text-lg font-medium text-[var(--near-black)] hover:text-[var(--color-action-primary)] transition-colors py-2">{t.nav.blog}</a>
      <a href="/nosotros" class="text-lg font-medium text-[var(--near-black)] hover:text-[var(--color-action-primary)] transition-colors py-2">{t.nav.nosotros}</a>
      <a href="/contacto" class="text-lg font-medium text-[var(--near-black)] hover:text-[var(--color-action-primary)] transition-colors py-2">Contacto</a>
      <hr class="border-gray-100 my-2" />
      <a href="/carrito" class="flex items-center gap-2 text-lg font-medium text-[var(--near-black)] hover:text-[var(--color-action-primary)] transition-colors py-2">
        <span>Carrito</span>
      </a>
      <div class="mt-auto pt-4">
        <LanguageSwitcher locale={locale} />
      </div>
    </nav>
  </div>
</div>

<div class="h-16 md:h-20 pt-[env(safe-area-inset-top,0px)]"></div>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('hamburger-btn');
    const menu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('mobile-menu-overlay');

    if (!btn || !menu || !overlay) return;

    const openMenu = () => {
      menu.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
      btn.setAttribute('aria-expanded', 'true');
    };

    const closeMenu = () => {
      menu.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
      btn.setAttribute('aria-expanded', 'false');
    };

    btn.addEventListener('click', () => {
      if (menu.classList.contains('hidden')) {
        openMenu();
      } else {
        closeMenu();
      }
    });

    overlay.addEventListener('click', closeMenu);

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
        closeMenu();
      }
    });

    // Close on nav link click
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  });
</script>
