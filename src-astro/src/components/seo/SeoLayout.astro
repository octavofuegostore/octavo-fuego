---
interface Props {
  title?: string;
  description?: string;
  locale?: 'es' | 'en' | 'pt';
  ogImage?: string;
  ogType?: 'website' | 'product';
  canonicalUrl?: string;
}

const {
  title = 'Octavo Fuego',
  description = 'Rapé do Acre, Sananga y Kuripes. Medicinas ancestrales amazónicas con propósito.',
  locale = 'es',
  ogImage = '/images/og-default.jpg',
  ogType = 'website',
  canonicalUrl
} = Astro.props;

const fullTitle = title === 'Octavo Fuego' ? title : `${title} | Octavo Fuego`;
const canonical = canonicalUrl || new URL(Astro.url.pathname, 'https://octavofuego.com').href;
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, 'https://octavofuego.com').href;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />
    
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Octavo Fuego" />
    <meta property="og:locale" content={locale === 'es' ? 'es_CO' : locale === 'en' ? 'en_US' : 'pt_BR'} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-black text-white">
    <slot />
  </body>
</html>
