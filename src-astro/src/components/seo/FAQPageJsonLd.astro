---
/**
 * FAQPage JSON-LD Schema Component
 * 6 locale-aware questions per product for SEO (voice search + rich snippets).
 */
import type { Product } from '@/data/products';
import type { Locale } from '@/i18n';
import { buildFAQContent } from '@/lib/seo/faqContent';

interface Props {
  product: Product;
  locale: Locale;
}

const { product, locale } = Astro.props;
const faqContent = buildFAQContent(product, locale);

const mainEntity = faqContent.map((q) => ({
  '@type': 'Question',
    'name': q.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': q.answer,
  },
}));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': mainEntity,
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
