---
/**
 * FAQSection — Visible collapsible FAQ UI component.
 * Uses semantic <details>/<summary> for zero-JS toggle behavior.
 */
import type { Product } from '@/data/products';
import type { Locale } from '@/i18n';
import { useTranslations } from '@/i18n';
import { buildFAQContent } from '@/lib/seo/faqContent';

interface Props {
  product: Product;
  locale: Locale;
}

const { product, locale } = Astro.props;
const t = useTranslations(locale);

const qaList = buildFAQContent(product, locale);
const headingText = locale === 'es' ? 'Preguntas frecuentes'
  : locale === 'en' ? 'Frequently asked questions'
  : 'Perguntas frequentes';
---

<section class="mt-12 pt-8 border-t border-gray-200">
  <h2 class="text-sm font-semibold uppercase tracking-widest text-[var(--ceniza)] mb-6">
    {headingText}
  </h2>
  <div class="space-y-3">
    {qaList.map((qa) => (
      <details class="group bg-[var(--papel)] rounded-[var(--radius-card)] border border-gray-100 overflow-hidden">
        <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer text-sm font-medium text-[var(--near-black)] hover:text-[var(--color-action-primary)] transition-colors list-none [&::-webkit-details-marker]:hidden">
          <span>{qa.question}</span>
          <svg class="w-4 h-4 text-[var(--ceniza)] flex-shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4 text-sm text-[var(--ceniza)] leading-relaxed">
          {qa.answer}
        </div>
      </details>
    ))}
  </div>
</section>

<style>
  /* Ensure <details> summary arrow is hidden across browsers */
  details summary::-webkit-details-marker { display: none; }
  details > summary { list-style: none; }
</style>
