---
interface Props {
  title?: string;
  description?: string;
  locale?: 'es' | 'en' | 'pt';
}

const {
  title = 'Octavo Fuego',
  description = 'Rapé do Acre, Sananga y Kuripes. Medicinas ancestrales amazónicas con propósito.',
  locale = 'es'
} = Astro.props;

const fullTitle = title === 'Octavo Fuego' ? title : `${title} | Octavo Fuego`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://octavofuego.com');
const ogImage = '/images/og-default.jpg';
