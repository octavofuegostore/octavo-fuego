---
import { useTranslations, languageNames } from '@/i18n';
import type { Locale } from '@/i18n';
import { Icon } from 'astro-icon/components';

interface Props {
  locale?: Locale;
}

const { locale = 'es' } = Astro.props;
const t = useTranslations(locale);

const locales: Locale[] = ['es', 'en', 'pt'];
const currentUrl = Astro.url.pathname;

function getLocaleUrl(targetLocale: Locale): string {
  const path = Astro.url.pathname;
  const segments = path.split('/').filter(Boolean);

  // Remove current locale prefix if present
  if (segments.length > 0 && locales.includes(segments[0] as Locale)) {
    segments.shift();
  }

  // Add target locale prefix (except for 'es' which is default)
  if (targetLocale === 'es') {
    return '/' + segments.join('/');
  }
  return '/' + targetLocale + '/' + segments.join('/');
}
---

<div class="relative group">
  <button
    class="flex items-center gap-1 text-sm font-medium text-[var(--ceniza)] hover:text-[var(--near-black)] transition-colors px-2 py-1 rounded-md hover:bg-gray-50"
    aria-expanded="false"
    aria-haspopup="true"
    aria-label="Idioma"
  >
<Icon name="solar:global-bold-duotone" class="w-4 h-4" />
    <span class="hidden sm:inline">{languageNames[locale]}</span>
    <Icon name="solar:alt-arrow-down-bold-duotone" class="w-3 h-3 transition-transform group-hover:rotate-180" />
  </button>

  <div class="absolute top-full right-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
    <div class="bg-white border border-gray-200 shadow-[var(--shadow-hover)] py-1 min-w-[120px] rounded-[var(--radius-card)]">
      {locales.map((loc) => (
        <a
          href={getLocaleUrl(loc)}
          class={`block px-4 py-2 text-sm transition-colors ${
            loc === locale
              ? 'text-[var(--verde-botanico)] font-semibold bg-gray-50'
              : 'text-[var(--ceniza)] hover:text-[var(--near-black)] hover:bg-gray-50'
          }`}
        >
          {languageNames[loc]}
        </a>
      ))}
    </div>
  </div>
</div>
