---
import { estadoOrdenSchema } from '@/lib/admin/schemas/enums'
import { getStatusLabel } from '@/lib/admin/schemas/traducciones'

interface Props {
  currentState: string
  validTransitions: string[]
  ordenId: string
}

const { currentState, validTransitions, ordenId } = Astro.props

const STEPS = ['pendiente', 'confirmada', 'pagada', 'preparando', 'enviada', 'entregada']
const currentIdx = STEPS.indexOf(currentState)
const isCancelled = currentState === 'cancelada'
---

<div class="bg-white rounded-2xl shadow-card p-6">
  <h3 class="font-display text-lg font-bold text-humo mb-6">Estado de la Orden</h3>

  {isCancelled ? (
    <div class="flex items-center gap-3 p-4 bg-error/10 rounded-xl">
      <span class="w-3 h-3 rounded-full bg-error" />
      <span class="font-medium text-error">Orden Cancelada</span>
    </div>
  ) : (
    <div class="flex items-center gap-1">
      {STEPS.map((step, i) => {
        const isPast = i < currentIdx
        const isCurrent = i === currentIdx
        const isFuture = i > currentIdx
        const canTransition = validTransitions.includes(step)

        return (
          <div class="flex items-center flex-1">
            <div class="flex flex-col items-center">
              <!-- Step circle -->
              <form method="POST" class="m-0">
                <input type="hidden" name="estado" value={step} />
                <input type="hidden" name="estadoAnterior" value={currentState} />
                <button
                  type="submit"
                  disabled={!canTransition}
                  class:list={[
                    "w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold transition-all",
                    isPast ? "bg-success text-white" : "",
                    isCurrent ? "bg-tabacco text-white ring-4 ring-tabacco/20" : "",
                    isFuture && canTransition ? "bg-tabacco/10 text-tabacco hover:bg-tabacco/20 cursor-pointer" : "",
                    isFuture && !canTransition ? "bg-papel text-ceniza cursor-not-allowed" : "",
                    !isPast && !isCurrent && canTransition ? "cursor-pointer" : "",
                  ]}
                >
                  {isPast ? '✓' : i + 1}
                </button>
                <span class:list={[
                  "text-xs mt-1 text-center block whitespace-nowrap",
                  isPast ? "text-success font-medium" : "",
                  isCurrent ? "text-tabacco font-bold" : "",
                  isFuture ? "text-ceniza" : "",
                ]}>
                  {getStatusLabel(step, 'es')}
                </span>
              </form>
            </div>
            <!-- Connector line -->
            {i < STEPS.length - 1 && (
              <div class:list={[
                "flex-1 h-0.5 mx-2",
                i < currentIdx ? "bg-success" : "bg-papel",
              ]} />
            )}
          </div>
        )
      })}
    </div>
  )}
</div>
