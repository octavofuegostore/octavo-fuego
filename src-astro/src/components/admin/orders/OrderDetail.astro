---
// OrderDetail.astro — Order detail view with status timeline
import { getOrdenById } from '@/lib/admin/service';
import OrderStateMachine from '@/components/admin/orders/OrderStateMachine.astro';

interface Props {
  orderId: string;
}

const { orderId } = Astro.props;

const order = await getOrdenById(orderId);

// Valid transitions from F1 schema
const TRANSICIONES: Record<string, string[]> = {
  pendiente: ['confirmada', 'cancelada'],
  confirmada: ['pagada', 'cancelada'],
  pagada: ['preparando', 'cancelada'],
  preparando: ['enviada', 'cancelada'],
  enviada: ['entregada', 'cancelada'],
  entregada: [],
  cancelada: [],
}
const validTransitions = TRANSICIONES[order?.status ?? ''] ?? []

import { getStatusLabel } from '@/lib/admin/schemas/traducciones'

const statusConfig: Record<string, { bg: string; text: string; label: string }> = {
  pendiente: { bg: 'bg-warning/10', text: 'text-warning', label: getStatusLabel('pendiente', 'es') },
  confirmada: { bg: 'bg-info/10', text: 'text-info', label: getStatusLabel('confirmada', 'es') },
  pagada: { bg: 'bg-success/10', text: 'text-success', label: getStatusLabel('pagada', 'es') },
  preparando: { bg: 'bg-accent/10', text: 'text-accent', label: getStatusLabel('preparando', 'es') },
  enviada: { bg: 'bg-accent/10', text: 'text-accent', label: getStatusLabel('enviada', 'es') },
  entregada: { bg: 'bg-success/10', text: 'text-success', label: getStatusLabel('entregada', 'es') },
  cancelada: { bg: 'bg-error/10', text: 'text-error', label: getStatusLabel('cancelada', 'es') }
};

const channelConfig = {
  whatsapp: { bg: 'bg-success/10', text: 'text-success', label: 'WhatsApp' },
  web: { bg: 'bg-info/10', text: 'text-info', label: 'Web' },
  manual: { bg: 'bg-ceniza/10', text: 'text-ceniza', label: 'Manual' }
};

function formatPrice(price: number, currency: string): string {
  return new Intl.NumberFormat('es-CO', {
    style: 'currency',
    currency: currency,
    minimumFractionDigits: 0
  }).format(price);
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('es-CO', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
}

const subtotal = order ? order.items.reduce((sum, item) => sum + item.price * item.quantity, 0) : 0;
const shipping = order ? order.total - subtotal : 0;
---

{order ? (<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Main Info -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Order Header -->
    <div class="bg-white rounded-2xl shadow-card p-6">
      <div class="flex items-start justify-between">
        <div>
          <h2 class="text-xl font-display font-bold text-humo">Orden {order.id}</h2>
          <p class="text-sm text-ceniza mt-1">Creada el {formatDate(order.createdAt)}</p>
        </div>
        <div class="flex items-center gap-3">
          <span class:list={[
            "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium",
            statusConfig[order.status].bg,
            statusConfig[order.status].text
          ]}>
            {statusConfig[order.status].label}
          </span>
          <span class:list={[
            "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium",
            channelConfig[order.channel].bg,
            channelConfig[order.channel].text
          ]}>
            {channelConfig[order.channel].label}
          </span>
        </div>
      </div>
    </div>

    <!-- Order State Machine -->
    <OrderStateMachine currentState={order.status} validTransitions={validTransitions} ordenId={orderId} />

    <!-- Order Items -->
    <div class="bg-white rounded-2xl shadow-card overflow-hidden">
      <div class="p-6 border-b border-papel">
        <h3 class="font-display text-lg font-bold text-humo">Productos</h3>
      </div>
      
      <div class="divide-y divide-papel">
        {order.items.map((item) => (
          <div class="p-4 flex items-center justify-between">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-papel rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-humo">{item.name}</p>
                <p class="text-xs text-ceniza">{item.quantity} x {formatPrice(item.price, order.currency)}</p>
              </div>
            </div>
            <p class="text-sm font-medium text-humo">
              {formatPrice(item.quantity * item.price, order.currency)}
            </p>
          </div>
        ))}
      </div>
      
      <div class="p-4 bg-papel/30 border-t border-papel">
        <div class="space-y-2">
          <div class="flex justify-between text-sm">
            <span class="text-ceniza">Subtotal</span>
            <span class="text-humo">{formatPrice(subtotal, order.currency)}</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-ceniza">Envío</span>
            <span class="text-humo">{formatPrice(shipping, order.currency)}</span>
          </div>
          <div class="flex justify-between text-lg font-bold border-t border-papel pt-2">
            <span class="text-humo">Total</span>
            <span class="text-tabacco">{formatPrice(order.total, order.currency)}</span>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Customer Info -->
    <div class="bg-white rounded-2xl shadow-card p-6">
      <h3 class="font-display text-lg font-bold text-humo mb-4">Cliente</h3>
      
      <div class="space-y-4">
        <div>
          <p class="text-sm text-ceniza">Nombre</p>
          <p class="text-sm font-medium text-humo">{order.customer.name}</p>
        </div>
        <div>
          <p class="text-sm text-ceniza">Email</p>
          <p class="text-sm font-medium text-humo">{order.customer.email}</p>
        </div>
        <div>
          <p class="text-sm text-ceniza">Teléfono</p>
          <p class="text-sm font-medium text-humo">{order.customer.phone}</p>
        </div>
      </div>
      
      <div class="mt-4 pt-4 border-t border-papel">
        <a href="/admin/clientes" class="text-sm text-tabacco hover:text-tabacco/80 font-medium transition-colors">
          Ver perfil del cliente →
        </a>
      </div>
    </div>

    <!-- Location -->
    <div class="bg-white rounded-2xl shadow-card p-6">
      <h3 class="font-display text-lg font-bold text-humo mb-4">Ubicación</h3>
      
      <div class="flex items-center gap-3">
        <span class:list={[
          "w-3 h-3 rounded-full",
          order.location === 'CO-BOGOTA' ? 'bg-info' : 'bg-success'
        ]} />
        <span class="text-sm font-medium text-humo">{order.location}</span>
      </div>
    </div>

    <!-- Actions -->
    <div class="bg-white rounded-2xl shadow-card p-6">
      <h3 class="font-display text-lg font-bold text-humo mb-4">Acciones</h3>
      
      <div class="space-y-3">
        {order.status === 'pending' && (
          <>
            <button class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-success text-white rounded-lg text-sm font-medium hover:bg-success/90 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Confirmar Orden
            </button>
            <button class="w-full flex items-center justify-center gap-2 px-4 py-2.5 border border-error text-error rounded-lg text-sm font-medium hover:bg-error/5 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              Cancelar Orden
            </button>
          </>
        )}
        
        {order.status === 'confirmed' && (
          <button class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-accent text-white rounded-lg text-sm font-medium hover:bg-accent/90 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
            </svg>
            Marcar como Enviada
          </button>
        )}
        
        <button class="w-full flex items-center justify-center gap-2 px-4 py-2.5 border border-papel text-humo rounded-lg text-sm font-medium hover:bg-papel transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
          </svg>
          Imprimir
        </button>
      </div>
    </div>
  </div>
</div>) : (
  <div class="bg-white rounded-2xl shadow-card p-12 text-center">
    <div class="w-16 h-16 bg-papel rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2V7a2 2 0 00-2-2h-5m-1 7l-3 3m0 0l3 3m-3-3h12" />
      </svg>
    </div>
    <h2 class="text-lg font-display font-bold text-humo mb-2">Orden no encontrada</h2>
    <p class="text-sm text-ceniza">No se encontró información para la orden solicitada.</p>
  </div>
)}
