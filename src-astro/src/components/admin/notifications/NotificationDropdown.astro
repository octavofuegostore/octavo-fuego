---
/**
 * NotificationDropdown.astro — SSR wrapper for the React notification island.
 *
 * Fetches notifications server-side and passes them to the React component.
 * Handles the case where the user is not logged in (no notifications shown).
 */
import NotificationDropdown from '@/components/admin/notifications/NotificationDropdown';
import { getNotificaciones } from '@/lib/admin/service';
import { setNotificaciones, $noLeidas } from '@/stores/admin';

interface Props {
  usuarioId?: string;
}

const { usuarioId } = Astro.props;

let notificaciones: Array<{
  id: string;
  tipo: string;
  titulo: string;
  mensaje: string | null;
  link: string | null;
  leida: boolean;
  creado_en: string;
}> = [];

try {
  notificaciones = await getNotificaciones(usuarioId);
  setNotificaciones(notificaciones.map(n => ({
    id: n.id,
    titulo: n.titulo,
    leida: n.leida,
    creado_en: n.creado_en,
  })));
} catch {
  // User not logged in or service error — render empty dropdown
}

const noLeidas = $noLeidas.value;
---

<NotificationDropdown client:load notificaciones={notificaciones} noLeidas={noLeidas} />
