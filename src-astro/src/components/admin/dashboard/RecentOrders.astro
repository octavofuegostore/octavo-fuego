---
import type { Orden } from '@/types/admin'
import { getStatusLabel } from '@/lib/admin/schemas/traducciones'

interface Props {
  ordenes: Orden[]
}

const { ordenes } = Astro.props
const recent = ordenes.slice(0, 5)

const statusColors: Record<string, string> = {
  pendiente: 'bg-warning/10 text-warning',
  confirmada: 'bg-info/10 text-info',
  pagada: 'bg-success/10 text-success',
  preparando: 'bg-accent/10 text-accent',
  enviada: 'bg-accent/10 text-accent',
  entregada: 'bg-success/10 text-success',
  cancelada: 'bg-error/10 text-error',
}

function formatCurrency(amount: number, currency: string): string {
  return new Intl.NumberFormat('es-CO', {
    style: 'currency',
    currency: currency,
    minimumFractionDigits: 0,
  }).format(amount)
}
---

<div class="bg-white rounded-2xl shadow-card overflow-hidden">
  <div class="p-6 border-b border-papel">
    <div class="flex items-center justify-between">
      <h3 class="font-display text-lg font-bold text-humo">Órdenes Recientes</h3>
      <a href="/admin/ordenes" class="text-sm text-tabacco hover:text-tabacco/80 font-medium transition-colors">
        Ver todas →
      </a>
    </div>
  </div>
  
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-papel">
          <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">ID</th>
          <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Cliente</th>
          <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Producto</th>
          <th class="text-right px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Monto</th>
          <th class="text-center px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Estado</th>
          <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Fecha</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-papel">
        {recent.map((orden) => (
          <tr class="hover:bg-papel/30 transition-colors">
            <td class="px-6 py-4 text-sm font-medium text-humo">{orden.id.slice(0, 8)}</td>
            <td class="px-6 py-4 text-sm text-humo">{orden.customer.name}</td>
            <td class="px-6 py-4 text-sm text-ceniza">{orden.items[0]?.name ?? '—'}</td>
            <td class="px-6 py-4 text-sm font-medium text-humo text-right">
              {formatCurrency(orden.total, orden.currency)}
            </td>
            <td class="px-6 py-4 text-center">
              <span class:list={[
                "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium",
                statusColors[orden.status] ?? 'bg-ceniza/10 text-ceniza',
              ]}>
                {getStatusLabel(orden.status, 'es')}
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-ceniza">{orden.createdAt?.slice(0, 10)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
