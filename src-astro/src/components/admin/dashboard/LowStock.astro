---
import type { Producto } from '@/types/admin'

interface Props {
  productos: Producto[]
}

const { productos } = Astro.props

const lowStock = productos
  .filter(p => (p.stockCO + p.stockBR) < 500)
  .sort((a, b) => (a.stockCO + a.stockBR) - (b.stockCO + b.stockBR))
  .slice(0, 6)

const locationColors: Record<string, string> = {
  'BR-ACRE': 'bg-success/10 text-success',
  'CO-BOGOTA': 'bg-info/10 text-info',
}
---

<div class="bg-white rounded-2xl shadow-card overflow-hidden">
  <div class="p-6 border-b border-papel">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <h3 class="font-display text-lg font-bold text-humo">Stock Bajo</h3>
        <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-error/10 text-error text-xs font-bold">
          {lowStock.length}
        </span>
      </div>
      <a href="/admin/inventario/stock" class="text-sm text-tabacco hover:text-tabacco/80 font-medium transition-colors">
        Ver inventario →
      </a>
    </div>
  </div>
  
  <div class="divide-y divide-papel">
    {lowStock.map((product) => {
      const totalStock = product.stockCO + product.stockBR
      const maxStock = 500
      const percentage = Math.round((totalStock / maxStock) * 100)
      const isCritical = percentage < 30
      
      return (
        <div class="p-4 hover:bg-papel/30 transition-colors">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <h4 class="text-sm font-medium text-humo">{product.name}</h4>
                {product.status === 'sin_stock' && (
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-error/10 text-error">
                    Sin stock
                  </span>
                )}
              </div>
              <p class="text-xs text-ceniza mt-1">SKU: {product.sku}</p>
            </div>
          </div>
          
          <div class="mt-3">
            <div class="flex items-center justify-between text-xs mb-1">
              <span class="text-ceniza">
                {totalStock}g total
              </span>
              <span class:list={[
                "font-medium",
                isCritical ? "text-error" : "text-warning",
              ]}>
                {percentage}%
              </span>
            </div>
            <div class="w-full bg-papel rounded-full h-1.5">
              <div 
                class:list={[
                  "h-1.5 rounded-full transition-all duration-300",
                  isCritical ? "bg-error" : "bg-warning",
                ]}
                style={`width: ${Math.min(percentage, 100)}%`}
              />
            </div>
          </div>
        </div>
      )
    })}
  </div>
</div>
