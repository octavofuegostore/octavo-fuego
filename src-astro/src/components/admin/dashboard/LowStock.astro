---
// LowStock.astro — Low stock alerts for dashboard
interface Product {
  id: string;
  name: string;
  sku: string;
  currentStock: number;
  minStock: number;
  location: 'BR-ACRE' | 'CO-BOGOTA';
  unit: 'g' | 'units';
}

const mockProducts: Product[] = [
  {
    id: '1',
    name: 'Cera de Ducha - Cacao',
    sku: 'CD-CA-100',
    currentStock: 250,
    minStock: 500,
    location: 'CO-BOGOTA',
    unit: 'g'
  },
  {
    id: '2',
    name: 'Sabonete - Lavanda',
    sku: 'SL-75',
    currentStock: 15,
    minStock: 50,
    location: 'BR-ACRE',
    unit: 'units'
  },
  {
    id: '3',
    name: 'Cera de Ducha - Vainilla',
    sku: 'CD-VA-100',
    currentStock: 180,
    minStock: 500,
    location: 'CO-BOGOTA',
    unit: 'g'
  },
  {
    id: '4',
    name: 'Pack Regalo Premium',
    sku: 'PR-100',
    currentStock: 3,
    minStock: 10,
    location: 'BR-ACRE',
    unit: 'units'
  }
];

const locationColors = {
  'BR-ACRE': 'bg-success/10 text-success',
  'CO-BOGOTA': 'bg-info/10 text-info'
};
---

<div class="bg-white rounded-2xl shadow-card overflow-hidden">
  <div class="p-6 border-b border-papel">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <h3 class="font-display text-lg font-bold text-humo">Stock Bajo</h3>
        <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-error/10 text-error text-xs font-bold">
          {mockProducts.length}
        </span>
      </div>
      <a href="/admin/inventario/stock" class="text-sm text-tabacco hover:text-tabacco/80 font-medium transition-colors">
        Ver inventario →
      </a>
    </div>
  </div>
  
  <div class="divide-y divide-papel">
    {mockProducts.map((product) => {
      const percentage = Math.round((product.currentStock / product.minStock) * 100);
      const isCritical = percentage < 50;
      
      return (
        <div class="p-4 hover:bg-papel/30 transition-colors">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <h4 class="text-sm font-medium text-humo">{product.name}</h4>
                {isCritical && (
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-error/10 text-error">
                    Crítico
                  </span>
                )}
              </div>
              <p class="text-xs text-ceniza mt-1">SKU: {product.sku}</p>
            </div>
            <span class:list={[
              "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium",
              locationColors[product.location]
            ]}>
              {product.location}
            </span>
          </div>
          
          <div class="mt-3">
            <div class="flex items-center justify-between text-xs mb-1">
              <span class="text-ceniza">
                {product.currentStock} / {product.minStock} {product.unit === 'g' ? 'g' : 'uds'}
              </span>
              <span class:list={[
                "font-medium",
                isCritical ? "text-error" : "text-warning"
              ]}>
                {percentage}%
              </span>
            </div>
            <div class="w-full bg-papel rounded-full h-1.5">
              <div 
                class:list={[
                  "h-1.5 rounded-full transition-all duration-300",
                  isCritical ? "bg-error" : "bg-warning"
                ]}
                style={`width: ${Math.min(percentage, 100)}%`}
              />
            </div>
          </div>
        </div>
      );
    })}
  </div>
</div>
