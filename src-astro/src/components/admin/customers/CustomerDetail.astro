---
// CustomerDetail.astro — Customer detail view
import { getClienteById } from '@/lib/admin/service';

interface Props {
  customerId: string;
}

const { customerId } = Astro.props;

const customer = await getClienteById(customerId);

const locationConfig = {
  CO: { flag: '🇨🇴', label: 'Colombia' },
  BR: { flag: '🇧🇷', label: 'Brasil' }
};

const typeConfig = {
  retail: { bg: 'bg-info/10', text: 'text-info', label: 'Minorista' },
  wholesale: { bg: 'bg-tabacco/10', text: 'text-tabacco', label: 'Mayorista' }
};

function formatPrice(price: number, currency: string): string {
  return new Intl.NumberFormat('es-CO', {
    style: 'currency',
    currency: currency,
    minimumFractionDigits: 0
  }).format(price);
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('es-CO', {
    day: '2-digit',
    month: 'short',
    year: 'numeric'
  });
}

const averageOrderValue = customer && customer.totalOrders > 0
  ? Math.round(customer.totalSpent / customer.totalOrders)
  : 0;
---

{customer ? (<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Main Info -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Customer Header -->
    <div class="bg-white rounded-2xl shadow-card p-6">
      <div class="flex items-start justify-between">
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 bg-tabacco/10 rounded-full flex items-center justify-center">
            <span class="text-tabacco font-bold text-xl">
              {customer.name.split(' ').map(n => n[0]).join('')}
            </span>
          </div>
          <div>
            <h2 class="text-xl font-display font-bold text-humo">{customer.name}</h2>
            <p class="text-sm text-ceniza">{customer.email}</p>
            <div class="flex items-center gap-2 mt-2">
              <span class="text-sm">
                {locationConfig[customer.location].flag} {locationConfig[customer.location].label}
              </span>
              <span class:list={[
                "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium",
                typeConfig[customer.type].bg,
                typeConfig[customer.type].text
              ]}>
                {typeConfig[customer.type].label}
              </span>
            </div>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <button class="p-2 text-ceniza hover:text-humo hover:bg-papel rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </button>
          <button class="p-2 text-ceniza hover:text-success hover:bg-success/10 rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </button>
        </div>
      </div>
    </div>

  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Stats -->
    <div class="bg-white rounded-2xl shadow-card p-6">
      <h3 class="font-display text-lg font-bold text-humo mb-4">Estadísticas</h3>
      
      <div class="space-y-4">
        <div class="flex items-center justify-between">
          <span class="text-sm text-ceniza">Total Órdenes</span>
          <span class="text-sm font-bold text-humo">{customer.totalOrders}</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-ceniza">Total Gastado</span>
          <span class="text-sm font-bold text-humo">{formatPrice(customer.totalSpent, customer.currency)}</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-ceniza">Valor Promedio</span>
          <span class="text-sm font-bold text-humo">{formatPrice(averageOrderValue, customer.currency)}</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-ceniza">Última Orden</span>
          <span class="text-sm font-medium text-humo">{formatDate(customer.lastOrder)}</span>
        </div>
      </div>
    </div>

    <!-- Contact Info -->
    <div class="bg-white rounded-2xl shadow-card p-6">
      <h3 class="font-display text-lg font-bold text-humo mb-4">Contacto</h3>
      
      <div class="space-y-4">
        <div>
          <p class="text-sm text-ceniza">Email</p>
          <p class="text-sm font-medium text-humo">{customer.email}</p>
        </div>
        <div>
          <p class="text-sm text-ceniza">Teléfono</p>
          <p class="text-sm font-medium text-humo">{customer.phone}</p>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="bg-white rounded-2xl shadow-card p-6">
      <h3 class="font-display text-lg font-bold text-humo mb-4">Acciones</h3>
      
      <div class="space-y-3">
        <button class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-success text-white rounded-lg text-sm font-medium hover:bg-success/90 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Enviar WhatsApp
        </button>
        <button class="w-full flex items-center justify-center gap-2 px-4 py-2.5 border border-papel text-humo rounded-lg text-sm font-medium hover:bg-papel transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Enviar Email
        </button>
      </div>
    </div>
  </div>
</div>) : (
  <div class="bg-white rounded-2xl shadow-card p-12 text-center">
    <div class="w-16 h-16 bg-papel rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
    </div>
    <h2 class="text-lg font-display font-bold text-humo mb-2">Cliente no encontrado</h2>
    <p class="text-sm text-ceniza">No se encontró información para el cliente solicitado.</p>
  </div>
)}
