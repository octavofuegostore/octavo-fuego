---
// ClienteForm.astro — Create/Edit customer form in modal
interface Props {
  mode?: 'create' | 'edit';
}

const { mode = 'create' } = Astro.props;
const isEdit = mode === 'edit';
---

<div
  id="cliente-form-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4"
>
  <div class="bg-white rounded-2xl shadow-xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
    <div class="p-6 border-b border-papel">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-xl font-display font-bold text-humo">
            {isEdit ? 'Editar Cliente' : 'Nuevo Cliente'}
          </h2>
          <p class="text-sm text-ceniza mt-1">
            {isEdit ? 'Actualiza la información del cliente' : 'Agrega un nuevo cliente al sistema'}
          </p>
        </div>
        <button
          type="button"
          id="close-cliente-modal"
          class="p-2 text-ceniza hover:text-humo hover:bg-papel rounded-lg transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <form id="cliente-form" class="p-6 space-y-6">
      <input type="hidden" name="id" id="cliente-id" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-humo mb-2">Nombre *</label>
          <input
            type="text"
            name="name"
            id="cliente-name"
            required
            class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            placeholder="María García"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-humo mb-2">Email *</label>
          <input
            type="email"
            name="email"
            id="cliente-email"
            required
            class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            placeholder="maria@email.com"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-humo mb-2">Teléfono *</label>
          <input
            type="tel"
            name="phone"
            id="cliente-phone"
            required
            class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            placeholder="+57 300 123 4567"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-humo mb-2">Ubicación *</label>
          <select
            name="location"
            id="cliente-location"
            required
            class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
          >
            <option value="">Seleccionar...</option>
            <option value="CO">Colombia</option>
            <option value="BR">Brasil</option>
          </select>
        </div>

        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-humo mb-2">Dirección</label>
          <input
            type="text"
            name="address"
            id="cliente-address"
            class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            placeholder="Calle 123 #45-67, Bogotá, Colombia"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-humo mb-2">Tipo</label>
          <select
            name="type"
            id="cliente-type"
            class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
          >
            <option value="retail">Minorista</option>
            <option value="wholesale">Mayorista</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-humo mb-2">Estado</label>
          <select
            name="status"
            id="cliente-status"
            class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
          >
            <option value="active">Activo</option>
            <option value="inactive">Inactivo</option>
          </select>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 pt-4 border-t border-papel">
        <button
          type="button"
          id="cancel-cliente-form"
          class="px-4 py-2 border border-papel rounded-lg text-sm font-medium text-humo hover:bg-papel transition-colors"
        >
          Cancelar
        </button>
        <button
          type="submit"
          class="px-4 py-2 bg-tabacco text-white rounded-lg text-sm font-medium hover:bg-tabacco/90 transition-colors"
        >
          {isEdit ? 'Guardar Cambios' : 'Crear Cliente'}
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  import { toast } from 'sonner';

  const modal = document.getElementById('cliente-form-modal');
  const closeBtn = document.getElementById('close-cliente-modal');
  const cancelBtn = document.getElementById('cancel-cliente-form');
  const form = document.getElementById('cliente-form') as HTMLFormElement;

  export function openClienteModal(cliente?: { id: string; name: string; email: string; phone: string; location: string; address?: string; type: string; status: string }) {
    if (!modal) return;

    if (cliente) {
      // Edit mode - populate form
      (document.getElementById('cliente-id') as HTMLInputElement).value = cliente.id;
      (document.getElementById('cliente-name') as HTMLInputElement).value = cliente.name;
      (document.getElementById('cliente-email') as HTMLInputElement).value = cliente.email;
      (document.getElementById('cliente-phone') as HTMLInputElement).value = cliente.phone;
      (document.getElementById('cliente-location') as HTMLSelectElement).value = cliente.location;
      (document.getElementById('cliente-address') as HTMLInputElement).value = cliente.address || '';
      (document.getElementById('cliente-type') as HTMLSelectElement).value = cliente.type;
      (document.getElementById('cliente-status') as HTMLSelectElement).value = cliente.status;
    } else {
      // Create mode - reset form
      form?.reset();
      (document.getElementById('cliente-id') as HTMLInputElement).value = '';
    }

    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  closeBtn?.addEventListener('click', closeModal);
  cancelBtn?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const cliente = Object.fromEntries(formData.entries());

    // Mock save (in real app, this would be an API call)
    toast.success(cliente.id ? 'Cliente actualizado correctamente' : 'Cliente creado correctamente');
    closeModal();

    // Dispatch event to refresh list
    window.dispatchEvent(new CustomEvent('cliente-saved'));
  });
</script>
