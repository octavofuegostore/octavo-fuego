---
// ProductTable.astro — Products list with search, filter, and actions
interface Product {
  id: string;
  name: string;
  sku: string;
  category: string;
  priceCOP: number;
  priceBRL: number;
  priceUSD: number;
  stockCO: number;
  stockBR: number;
  status: 'active' | 'inactive';
  image?: string;
}

const mockProducts: Product[] = [
  {
    id: '1',
    name: 'Cera de Ducha - Cacao',
    sku: 'CD-CA-100',
    category: 'Cera de Ducha',
    priceCOP: 45000,
    priceBRL: 89,
    priceUSD: 12,
    stockCO: 250,
    stockBR: 800,
    status: 'active',
    image: '/images/products/cera-cacao.jpg'
  },
  {
    id: '2',
    name: 'Cera de Ducha - Vainilla',
    sku: 'CD-VA-100',
    category: 'Cera de Ducha',
    priceCOP: 45000,
    priceBRL: 89,
    priceUSD: 12,
    stockCO: 180,
    stockBR: 650,
    status: 'active',
    image: '/images/products/cera-vainilla.jpg'
  },
  {
    id: '3',
    name: 'Sabonete - Lavanda',
    sku: 'SL-75',
    category: 'Sabonete',
    priceCOP: 35000,
    priceBRL: 69,
    priceUSD: 9.5,
    stockCO: 400,
    stockBR: 15,
    status: 'active',
    image: '/images/products/sabonete-lavanda.jpg'
  },
  {
    id: '4',
    name: 'Sabonete - Avena',
    sku: 'SA-75',
    category: 'Sabonete',
    priceCOP: 35000,
    priceBRL: 69,
    priceUSD: 9.5,
    stockCO: 350,
    stockBR: 450,
    status: 'active',
    image: '/images/products/sabonete-avena.jpg'
  },
  {
    id: '5',
    name: 'Pack Regalo Premium',
    sku: 'PR-100',
    category: 'Packs',
    priceCOP: 120000,
    priceBRL: 239,
    priceUSD: 32,
    stockCO: 50,
    stockBR: 3,
    status: 'active',
    image: '/images/products/pack-premium.jpg'
  }
];

function formatPrice(price: number, currency: string): string {
  return new Intl.NumberFormat('es-CO', {
    style: 'currency',
    currency: currency,
    minimumFractionDigits: 0
  }).format(price);
}

function getStockStatus(stock: number, min: number = 100): 'active' | 'low' | 'critical' {
  if (stock < min * 0.5) return 'critical';
  if (stock < min) return 'low';
  return 'active';
}
---

<div class="bg-white rounded-2xl shadow-card overflow-hidden">
  <!-- Header with search and filters -->
  <div class="p-6 border-b border-papel">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex-1 max-w-md">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            placeholder="Buscar productos..."
            class="w-full pl-10 pr-4 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
          />
        </div>
      </div>
      
      <div class="flex items-center gap-3">
        <select class="px-3 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco">
          <option value="">Todas las categorías</option>
          <option value="cera">Cera de Ducha</option>
          <option value="sabonete">Sabonete</option>
          <option value="packs">Packs</option>
        </select>
        
        <select class="px-3 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco">
          <option value="">Todas las ubicaciones</option>
          <option value="CO">CO-BOGOTA</option>
          <option value="BR">BR-ACRE</option>
        </select>
        
        <button class="flex items-center gap-2 px-4 py-2 bg-tabacco text-white rounded-lg text-sm font-medium hover:bg-tabacco/90 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Nuevo Producto
        </button>
      </div>
    </div>
  </div>
  
  <!-- Products table -->
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-papel">
          <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Producto</th>
          <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">SKU</th>
          <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Categoría</th>
          <th class="text-right px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Precio CO</th>
          <th class="text-right px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Precio BR</th>
          <th class="text-center px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Stock CO</th>
          <th class="text-center px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Stock BR</th>
          <th class="text-center px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Estado</th>
          <th class="text-right px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Acciones</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-papel">
        {mockProducts.map((product) => (
          <tr class="hover:bg-papel/30 transition-colors">
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-papel rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-humo">{product.name}</p>
                  <p class="text-xs text-ceniza">ID: {product.id}</p>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 text-sm text-ceniza font-mono">{product.sku}</td>
            <td class="px-6 py-4 text-sm text-ceniza">{product.category}</td>
            <td class="px-6 py-4 text-sm text-humo text-right font-medium">
              {formatPrice(product.priceCOP, 'COP')}
            </td>
            <td class="px-6 py-4 text-sm text-humo text-right font-medium">
              {formatPrice(product.priceBRL, 'BRL')}
            </td>
            <td class="px-6 py-4 text-center">
              <span class:list={[
                "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium",
                getStockStatus(product.stockCO) === 'critical' ? 'bg-error/10 text-error' :
                getStockStatus(product.stockCO) === 'low' ? 'bg-warning/10 text-warning' :
                'bg-success/10 text-success'
              ]}>
                {product.stockCO}g
              </span>
            </td>
            <td class="px-6 py-4 text-center">
              <span class:list={[
                "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium",
                getStockStatus(product.stockBR) === 'critical' ? 'bg-error/10 text-error' :
                getStockStatus(product.stockBR) === 'low' ? 'bg-warning/10 text-warning' :
                'bg-success/10 text-success'
              ]}>
                {product.stockBR}g
              </span>
            </td>
            <td class="px-6 py-4 text-center">
              <span class:list={[
                "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium",
                product.status === 'active' ? 'bg-success/10 text-success' : 'bg-ceniza/10 text-ceniza'
              ]}>
                {product.status === 'active' ? 'Activo' : 'Inactivo'}
              </span>
            </td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center justify-end gap-2">
                <button class="p-1.5 text-ceniza hover:text-humo hover:bg-papel rounded-lg transition-colors" title="Ver">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                </button>
                <button class="p-1.5 text-ceniza hover:text-tabacco hover:bg-tabacco/10 rounded-lg transition-colors" title="Editar">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                </button>
                <button class="p-1.5 text-ceniza hover:text-error hover:bg-error/10 rounded-lg transition-colors" title="Eliminar">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  
  <!-- Pagination -->
  <div class="p-4 border-t border-papel">
    <div class="flex items-center justify-between">
      <p class="text-sm text-ceniza">Mostrando 1-5 de 24 productos</p>
      <div class="flex items-center gap-2">
        <button class="px-3 py-1.5 border border-papel rounded-lg text-sm text-ceniza hover:bg-papel transition-colors">
          Anterior
        </button>
        <button class="px-3 py-1.5 bg-tabacco text-white rounded-lg text-sm font-medium">
          1
        </button>
        <button class="px-3 py-1.5 border border-papel rounded-lg text-sm text-ceniza hover:bg-papel transition-colors">
          2
        </button>
        <button class="px-3 py-1.5 border border-papel rounded-lg text-sm text-ceniza hover:bg-papel transition-colors">
          3
        </button>
        <button class="px-3 py-1.5 border border-papel rounded-lg text-sm text-ceniza hover:bg-papel transition-colors">
          Siguiente
        </button>
      </div>
    </div>
  </div>
</div>
