---
import ProductTableClient from "./ProductTableClient";

interface Product {
  id: string;
  name: string;
  sku: string;
  category: string;
  priceCOP: number;
  priceBRL: number;
  priceUSD: number;
  stockCO: number;
  stockBR: number;
  status: "active" | "inactive" | "out_of_stock";
}

interface Props {
  products: Product[];
}

const { products } = Astro.props;
---

<ProductTableClient client:load products={products} />
