---
// ProductForm.astro — Create/Edit product form
interface Props {
  mode: 'create' | 'edit';
  product?: {
    id: string;
    name: string;
    sku: string;
    description: string;
    category: string;
    priceCOP: number;
    priceBRL: number;
    priceUSD: number;
    weight: number;
    unit: 'g' | 'units';
    stockCO: number;
    stockBR: number;
    minStockCO: number;
    minStockBR: number;
    status: 'active' | 'inactive';
  };
}

const { mode, product } = Astro.props;
const isEdit = mode === 'edit';
---

<form class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-xl font-display font-bold text-humo">
        {isEdit ? 'Editar Producto' : 'Nuevo Producto'}
      </h2>
      <p class="text-sm text-ceniza mt-1">
        {isEdit ? 'Actualiza la información del producto' : 'Agrega un nuevo producto al catálogo'}
      </p>
    </div>
    <div class="flex items-center gap-3">
      <button type="button" class="px-4 py-2 border border-papel rounded-lg text-sm font-medium text-ceniza hover:bg-papel transition-colors">
        Cancelar
      </button>
      <button type="submit" class="px-4 py-2 bg-tabacco text-white rounded-lg text-sm font-medium hover:bg-tabacco/90 transition-colors">
        {isEdit ? 'Guardar Cambios' : 'Crear Producto'}
      </button>
    </div>
  </div>

  <!-- Main Info -->
  <div class="bg-white rounded-2xl shadow-card p-6">
    <h3 class="text-lg font-display font-bold text-humo mb-4">Información Principal</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium text-humo mb-2">Nombre del Producto *</label>
        <input
          type="text"
          name="name"
          value={product?.name || ''}
          required
          class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
          placeholder="Ej: Cera de Ducha - Cacao"
        />
      </div>
      
      <div>
        <label class="block text-sm font-medium text-humo mb-2">SKU *</label>
        <input
          type="text"
          name="sku"
          value={product?.sku || ''}
          required
          class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
          placeholder="Ej: CD-CA-100"
        />
      </div>
      
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-humo mb-2">Descripción</label>
        <textarea
          name="description"
          rows={3}
          class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors resize-none"
          placeholder="Describe el producto..."
        >{product?.description || ''}</textarea>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-humo mb-2">Categoría *</label>
        <select
          name="category"
          required
          class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
        >
          <option value="">Seleccionar categoría</option>
          <option value="cera" selected={product?.category === 'cera'}>Cera de Ducha</option>
          <option value="sabonete" selected={product?.category === 'sabonete'}>Sabonete</option>
          <option value="pack" selected={product?.category === 'pack'}>Pack</option>
        </select>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-humo mb-2">Estado</label>
        <select
          name="status"
          class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
        >
          <option value="active" selected={product?.status === 'active'}>Activo</option>
          <option value="inactive" selected={product?.status === 'inactive'}>Inactivo</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Pricing -->
  <div class="bg-white rounded-2xl shadow-card p-6">
    <h3 class="text-lg font-display font-bold text-humo mb-4">Precios por Región</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div>
        <label class="block text-sm font-medium text-humo mb-2">Precio COP *</label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-ceniza">$</span>
          <input
            type="number"
            name="priceCOP"
            value={product?.priceCOP || ''}
            required
            min="0"
            class="w-full pl-8 pr-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            placeholder="45000"
          />
        </div>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-humo mb-2">Precio BRL *</label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-ceniza">R$</span>
          <input
            type="number"
            name="priceBRL"
            value={product?.priceBRL || ''}
            required
            min="0"
            step="0.01"
            class="w-full pl-10 pr-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            placeholder="89"
          />
        </div>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-humo mb-2">Precio USD *</label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-ceniza">$</span>
          <input
            type="number"
            name="priceUSD"
            value={product?.priceUSD || ''}
            required
            min="0"
            step="0.01"
            class="w-full pl-8 pr-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            placeholder="12"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Physical Properties -->
  <div class="bg-white rounded-2xl shadow-card p-6">
    <h3 class="text-lg font-display font-bold text-humo mb-4">Propiedades Físicas</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium text-humo mb-2">Peso *</label>
        <div class="flex gap-3">
          <input
            type="number"
            name="weight"
            value={product?.weight || ''}
            required
            min="1"
            class="flex-1 px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            placeholder="100"
          />
          <select
            name="unit"
            class="px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
          >
            <option value="g" selected={product?.unit === 'g'}>Gramos</option>
            <option value="units" selected={product?.unit === 'units'}>Unidades</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <!-- Stock -->
  <div class="bg-white rounded-2xl shadow-card p-6">
    <h3 class="text-lg font-display font-bold text-humo mb-4">Inventario por Ubicación</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- CO-BOGOTA -->
      <div class="p-4 bg-info/5 rounded-xl border border-info/20">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-2 h-2 rounded-full bg-info" />
          <h4 class="font-medium text-humo">CO-BOGOTA</h4>
        </div>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-ceniza mb-1">Stock Actual</label>
            <input
              type="number"
              name="stockCO"
              value={product?.stockCO || 0}
              min="0"
              class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            />
          </div>
          <div>
            <label class="block text-sm text-ceniza mb-1">Stock Mínimo</label>
            <input
              type="number"
              name="minStockCO"
              value={product?.minStockCO || 100}
              min="0"
              class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            />
          </div>
        </div>
      </div>
      
      <!-- BR-ACRE -->
      <div class="p-4 bg-success/5 rounded-xl border border-success/20">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-2 h-2 rounded-full bg-success" />
          <h4 class="font-medium text-humo">BR-ACRE</h4>
        </div>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-ceniza mb-1">Stock Actual</label>
            <input
              type="number"
              name="stockBR"
              value={product?.stockBR || 0}
              min="0"
              class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            />
          </div>
          <div>
            <label class="block text-sm text-ceniza mb-1">Stock Mínimo</label>
            <input
              type="number"
              name="minStockBR"
              value={product?.minStockBR || 100}
              min="0"
              class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</form>
