---
// TransaccionTable.astro — Transaction list with search, filters, and actions
import { formatCurrency } from '@/lib/formatCurrency';

const formatCOP = (amount: number) => formatCurrency(amount, 'COP');

interface TransaccionDisplay {
  id: string;
  fecha: string;
  descripcion: string;
  categoria: string;
  tipo: 'Ingreso' | 'Egreso';
  monto: number;
}

interface Props {
  transactions: TransaccionDisplay[];
  showFilters?: boolean;
  showActions?: boolean;
}

const { transactions, showFilters = true, showActions = true } = Astro.props;

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('es-CO', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });
}

const meses = [
  'Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
  'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre',
];
---

<div class="bg-white rounded-2xl shadow-card overflow-hidden">
  <!-- Header with search and filters -->
  {showFilters && (
    <div class="p-6 border-b border-papel">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div class="flex-1 max-w-md">
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              placeholder="Buscar transacciones..."
              class="w-full pl-10 pr-4 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            />
          </div>
        </div>

        <div class="flex items-center gap-3">
          <select class="px-3 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco">
            <option value="">Mes</option>
            {meses.map((m) => <option value={m}>{m}</option>)}
          </select>

          <select class="px-3 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco">
            <option value="2026">2026</option>
          </select>

          <select class="px-3 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco">
            <option value="">Tipo</option>
            <option value="Ingreso">Ingreso</option>
            <option value="Egreso">Egreso</option>
          </select>

          <button class="flex items-center gap-2 px-4 py-2 bg-tabacco text-white rounded-lg text-sm font-medium hover:bg-tabacco/90 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Nueva Transacción
          </button>
        </div>
      </div>
    </div>
  )}

  <!-- Transactions table -->
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-papel">
          <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Fecha</th>
          <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Descripción</th>
          <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Categoría</th>
          <th class="text-center px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Tipo</th>
          <th class="text-right px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Monto</th>
          {showActions && <th class="text-right px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Acciones</th>}
        </tr>
      </thead>
      <tbody class="divide-y divide-papel">
        {transactions.map((t) => (
          <tr class="hover:bg-papel/30 transition-colors">
            <td class="px-6 py-4 text-sm text-humo">{formatDate(t.fecha)}</td>
            <td class="px-6 py-4 text-sm text-humo">{t.descripcion}</td>
            <td class="px-6 py-4 text-sm text-ceniza">{t.categoria}</td>
            <td class="px-6 py-4 text-center">
              <span
                class:list={[
                  'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium',
                  t.tipo === 'Ingreso'
                    ? 'bg-green-50 text-green-700'
                    : 'bg-red-50 text-red-700',
                ]}
              >
                {t.tipo}
              </span>
            </td>
            <td class="px-6 py-4 text-right text-sm font-medium text-humo">
              {formatCOP(t.monto)}
            </td>
            <td class="px-6 py-4 text-right">
              {showActions && (
                <div class="flex items-center justify-end gap-2">
                  <button class="p-1.5 text-ceniza hover:text-humo hover:bg-papel rounded-lg transition-colors" title="Ver detalle">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                  </button>
                  <button class="p-1.5 text-ceniza hover:text-tabacco hover:bg-tabacco/10 rounded-lg transition-colors" title="Editar">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  </button>
                  <button class="p-1.5 text-ceniza hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors" title="Eliminar">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </button>
                </div>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
