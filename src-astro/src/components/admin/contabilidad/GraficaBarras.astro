---
export interface BarData {
  label: string;
  ingreso: number;
  egreso: number;
}

export interface Props {
  data: BarData[];
  height?: number;
}

const { data, height = 200 } = Astro.props;

// Find max value for scaling
const maxValue = Math.max(...data.flatMap(d => [d.ingreso, d.egreso])) * 1.2;

// Chart dimensions
const padding = { top: 20, right: 20, bottom: 40, left: 50 };
const chartWidth = 500 - padding.left - padding.right;
const chartHeight = height - padding.top - padding.bottom;

const barGroupWidth = chartWidth / data.length;
const barWidth = barGroupWidth * 0.3;
const barGap = barGroupWidth * 0.1;

// Y-axis values
const steps = 4;
const yStep = maxValue / steps;

function formatValue(val: number): string {
  if (val >= 1_000_000) return `${(val / 1_000_000).toFixed(1)}M`;
  if (val >= 1_000) return `${(val / 1_000).toFixed(0)}k`;
  return String(val);
}
---

<div class="bg-white rounded-2xl p-6 shadow-card">
  <svg viewBox="0 0 500 {height}" class="w-full h-auto" xmlns="http://www.w3.org/2000/svg">
    <!-- Legend -->
    <rect x={padding.left} y="5" width="10" height="10" fill="#8B4513" rx="2" />
    <text x={padding.left + 14} y="13" class="text-xs" fill="#2A2A2A" font-size="11">Ingresos</text>
    <rect x={padding.left + 80} y="5" width="10" height="10" fill="#7b8084" rx="2" />
    <text x={padding.left + 94} y="13" class="text-xs" fill="#2A2A2A" font-size="11">Egresos</text>

    <!-- Y-axis grid lines and labels -->
    {
      Array.from({ length: steps + 1 }, (_, i) => {
        const y = padding.top + chartHeight - (i * chartHeight / steps);
        const val = Math.round(yStep * i);
        return [
          <line x1={padding.left} y1={y} x2={500 - padding.right} y2={y} stroke="#E5E5E7" stroke-width="1" />,
          <text x={padding.left - 8} y={y + 4} text-anchor="end" fill="#7b8084" font-size="10">
            {formatValue(val)}
          </text>,
        ];
      })
    }

    <!-- Bars -->
    {
      data.map((d, i) => {
        const x = padding.left + i * barGroupWidth + (barGroupWidth - barWidth * 2 - barGap) / 2;
        const ingresoHeight = (d.ingreso / maxValue) * chartHeight;
        const egresoHeight = (d.egreso / maxValue) * chartHeight;
        const xEgreso = x + barWidth + barGap;
        return [
          <!-- Ingreso bar -->
          <rect x={x} y={padding.top + chartHeight - ingresoHeight} width={barWidth} height={ingresoHeight} fill="#8B4513" rx="2" />,
          <!-- Egreso bar -->
          <rect x={xEgreso} y={padding.top + chartHeight - egresoHeight} width={barWidth} height={egresoHeight} fill="#7b8084" rx="2" />,
          <!-- X-axis label -->
          <text x={x + barWidth + barGap / 2} y={height - 5} text-anchor="middle" fill="#7b8084" font-size="10">
            {d.label}
          </text>,
        ];
      })
    }
  </svg>
</div>
