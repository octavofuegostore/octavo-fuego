---
export interface TortaSegment {
  label: string;
  value: number;
  color: string;
}

export interface Props {
  data: TortaSegment[];
  title?: string;
  size?: number;
}

const { data, title, size = 300 } = Astro.props;

const total = data.reduce((sum, d) => sum + d.value, 0);
const outerRadius = size / 2;
const innerRadius = size / 3;
const circumference = 2 * Math.PI * outerRadius;
const centerX = size / 2;
const centerY = size / 2;

// Single item = full circle (no donut hole)
const isSingleItem = data.length === 1;
const hasData = data.length > 0 && total > 0;

// Calculate segments
const segments = data.map((d, i) => {
  const percentage = hasData ? d.value / total : 0;
  const dashLength = isSingleItem ? circumference : percentage * circumference;
  const dashOffset = data.slice(0, i).reduce((sum, prev) => {
    const prevPercent = hasData ? prev.value / total : 0;
    return sum + (isSingleItem ? circumference : prevPercent * circumference);
  }, 0);
  return {
    ...d,
    dashLength,
    dashOffset,
    percentage: Math.round(percentage * 100),
  };
});

// Format COP currency
function formatCOP(value: number): string {
  return new Intl.NumberFormat('es-CO', {
    style: 'currency',
    currency: 'COP',
    maximumFractionDigits: 0,
  }).format(value);
}

// Truncate label
function truncateLabel(label: string, maxLen = 24): string {
  return label.length > maxLen ? label.slice(0, maxLen - 1) + '…' : label;
}
---

<div class="bg-white rounded-2xl p-6 shadow-card">
  {title && <h3 class="text-base font-display font-bold text-humo mb-4">{title}</h3>}

  <svg
    viewBox={`0 0 ${size} ${size}`}
    class="w-full h-auto"
    style={`max-width: ${size}px;`}
    role="img"
    aria-label={title || 'Gráfico de torta'}
    xmlns="http://www.w3.org/2000/svg"
  >
    <title>{title || 'Gráfico de torta'}</title>

    {!hasData ? (
      // Empty state
      <text x={centerX} y={centerY} text-anchor="middle" dominant-baseline="middle" fill="#7b8084" font-size="14">
        Sin datos
      </text>
    ) : (
      <>
        {/* Donut segments */}
        {segments.map((seg, i) => (
          <circle
            cx={centerX}
            cy={centerY}
            r={outerRadius}
            fill="none"
            stroke={seg.color}
            stroke-width={isSingleItem ? outerRadius : outerRadius - innerRadius}
            stroke-dasharray={isSingleItem ? `${circumference} ${circumference * 0.001}` : `${seg.dashLength} ${circumference - seg.dashLength}`}
            stroke-dashoffset={isSingleItem ? 0 : -seg.dashOffset}
            transform={`rotate(-90 ${centerX} ${centerY})`}
            style={`transition: stroke-dasharray 0.3s ease;`}
          />
        ))}

        {/* Center text */}
        <text x={centerX} y={centerY - 8} text-anchor="middle" dominant-baseline="middle" fill="#2A2A2A" font-size="16" font-weight="bold">
          {formatCOP(total)}
        </text>
        <text x={centerX} y={centerY + 12} text-anchor="middle" dominant-baseline="middle" fill="#7b8084" font-size="10">
          {isSingleItem ? '100%' : 'Total'}
        </text>
      </>
    )}
  </svg>

  {/* Legend */}
  {hasData && (
    <div class="flex flex-wrap justify-center gap-4 mt-4">
      {segments.map((seg) => (
        <div class="flex items-center gap-2">
          <span
            class="w-3 h-3 rounded-sm flex-shrink-0"
            style={`background-color: ${seg.color};`}
          ></span>
          <span class="text-xs text-ceniza whitespace-nowrap">{truncateLabel(seg.label)}</span>
          <span class="text-xs text-humo font-medium">{seg.percentage}%</span>
        </div>
      ))}
    </div>
  )}
</div>
