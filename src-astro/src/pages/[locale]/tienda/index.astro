---
/**
 * Catalog listing page — renders at /tienda, /en/tienda, /pt/tienda
 * Uses: QuickReferenceTable, ProductCard ×5, IntentMap, IntensityProfile, Glossary
 *
 * @source Octavofuego_Catalogo_ESP (1).html
 */

import Layout from '@/layouts/Layout.astro';
import ProductCard from '@/components/product/ProductCard.astro';
import QuickReferenceTable from '@/components/tienda/QuickReferenceTable.astro';
import IntentMap from '@/components/tienda/IntentMap.astro';
import IntensityProfile from '@/components/tienda/IntensityProfile.astro';
import Glossary from '@/components/tienda/Glossary.astro';
import { products } from '@/data/products';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n';

export async function getStaticPaths() {
  return [
    { params: { locale: 'es' } },
    { params: { locale: 'en' } },
    { params: { locale: 'pt' } },
  ];
}

const { locale } = Astro.params;
const locale_ = locale as Locale;
const t = useTranslations(locale_);
const baseUrl = `/${locale_}`;
---

<Layout
  title={t.tienda.title}
  description={t.tienda.subtitle}
  locale={locale_}
>
  <!-- Header -->
  <section class="pt-24 md:pt-32 pb-12 md:pb-16 bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm">
        <ol class="flex items-center gap-2 text-[var(--ceniza)]">
          <li>
            <a href={baseUrl} class="hover:text-[var(--color-action-primary)] transition-colors">
              {locale_ === 'es' ? 'Inicio' : locale_ === 'en' ? 'Home' : 'Início'}
            </a>
          </li>
          <li>/</li>
          <li class="text-[var(--near-black)]">{t.nav.tienda}</li>
        </ol>
      </nav>

      <div class="text-center">
      <span class="text-[0.75rem] uppercase tracking-[0.3em] text-[var(--color-action-primary)] font-semibold block mb-4">
        {t.tienda.subtitle}
      </span>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-[var(--near-black)] mb-6">
        {t.tienda.title}
      </h1>
      <p class="text-[var(--ceniza)] text-lg md:text-xl max-w-[700px] mx-auto font-light italic leading-relaxed">
        {locale_ === 'es'
          ? 'Una guía integral para comprender las variedades sagradas de rapé, sus propiedades y aplicaciones ceremoniales en las tradiciones ancestrales de la Amazonía.'
          : locale_ === 'en'
          ? 'A comprehensive guide to understanding sacred rapé varieties, their properties, and ceremonial applications in ancestral Amazonian traditions.'
          : 'Um guia abrangente para compreender as variedades sagradas de rapé, suas propriedades e aplicações cerimoniais nas tradições ancestrais da Amazônia.'}
      </p>
    </div>
  </section>

  <!-- Quick Reference Table -->
  <QuickReferenceTable locale={locale_} />

  <!-- Product Varieties -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <span class="section-label text-xs uppercase tracking-[0.2em] font-bold text-[var(--color-action-primary)] border-b border-gray-200 pb-3 mb-10 block">
        {t.tienda.varieties}
      </span>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products
          .sort((a, b) => a.varietyOrder - b.varietyOrder)
          .map((product) => (
            <ProductCard
              slug={product.slug}
              varietyOrder={product.varietyOrder}
              nombre={product.nombre[locale_]}
              enfoque={product.enfoque[locale_]}
              usoRecomendado={product.usoRecomendado[locale_]}
              imagen={product.imagenes[0]}
              pricing={product.pricing}
              locale={locale_}
              href={`${baseUrl}/tienda/rape/${product.slug}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- General Note -->
  <section class="py-12 md:py-16 bg-[var(--papel)]">
    <div class="max-w-3xl mx-auto px-6 md:px-12 text-center">
      <p class="text-[var(--ceniza)] italic text-base md:text-lg leading-relaxed">
        <strong>{locale_ === 'es' ? 'Nota general:' : locale_ === 'en' ? 'General note:' : 'Nota geral:'}</strong>{' '}
        {t.tienda.generalNote}
      </p>
    </div>
  </section>

  <!-- Intent Map -->
  <IntentMap locale={locale_} />

  <!-- Intensity Profile -->
  <IntensityProfile locale={locale_} />

  <!-- Glossary -->
  <Glossary locale={locale_} />
</Layout>
