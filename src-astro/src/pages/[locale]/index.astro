---
/**
 * Locale-aware homepage — renders at /, /en, /pt
 * Preserves Hero + Trust Badges, REPLACES quiz with real intention categories,
 * adds ProphecyTeaser, updates product links to /tienda
 *
 * @source src/pages/index.astro (existing) + Octavofuego_Catalogo_ESP (1).html (intentions)
 */

import Layout from '@/layouts/Layout.astro';
import ProphecyTeaser from '@/components/prophecy/ProphecyTeaser.astro';
import { prophecy } from '@/data/prophecy';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  return [
    { params: { locale: 'es' } },
    { params: { locale: 'en' } },
    { params: { locale: 'pt' } },
  ];
}

const { locale } = Astro.params;
const locale_ = locale as Locale;
const t = useTranslations(locale_);
const baseUrl = `/${locale_}`;

// 5 real intention categories from source HTML (word-for-word)
const intentions = [
  {
    key: 'claridadMental',
    medicineName: 'Vena de Pajé',
    slug: 'vena-de-paje',
    icon: 'eye',
  },
  {
    key: 'resetEnergetico',
    medicineName: 'Tisunú',
    slug: 'tisunu',
    icon: 'zap',
  },
  {
    key: 'bienestarFisico',
    medicineName: 'Pixurí, Cumarú de Cheiro o Vena de Pajé',
    slug: 'pixuri',
    icon: 'heart',
  },
  {
    key: 'proteccion',
    medicineName: 'Cumarú de Cheiro',
    slug: 'cumaru-de-cheiro',
    icon: 'shield',
  },
  {
    key: 'conexionEspiritual',
    medicineName: 'Pariká',
    slug: 'parika',
    icon: 'sparkles',
  },
];

const iconNames: Record<string, string> = {
  eye: 'eye-bold-duotone',
  zap: 'lightning-bold-duotone',
  heart: 'heart-bold-duotone',
  shield: 'shield-bold-duotone',
  sparkles: 'moon-bold-duotone',
};
---

<Layout title="Octavo Fuego" locale={locale_}>
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-12 py-24 grid lg:grid-cols-2 gap-16 items-center">
      <!-- Hero Content -->
      <div>
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold mb-6 tracking-tight text-[var(--near-black)] leading-tight">
          {t.home.hero.title}
        </h1>
        
        <p class="text-[var(--ceniza)] text-lg md:text-xl tracking-wide mb-12 max-w-lg">
          {t.home.hero.subtitle}
        </p>
        
        <a 
          href={`${baseUrl}/tienda`}
          class="inline-block bg-[var(--near-black)] text-white px-8 py-4 text-lg font-medium tracking-wide hover:bg-[var(--color-action-primary)] transition-colors rounded-[var(--radius-button)]"
        >
          {t.home.hero.cta} →
        </a>
      </div>
      
      <!-- Hero Image -->
      <div class="relative">
        <div class="aspect-square bg-[var(--papel)] rounded-[var(--radius-card)] overflow-hidden shadow-[var(--shadow-card)]">
          <img 
            src="/images/productos/rape/bobinsana-rape-2.webp" 
            alt="Rapé do Acre"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce">
      <span class="text-[var(--ceniza)] text-sm">↓</span>
    </div>
  </section>

  <!-- Trust Badges -->
  <section class="py-16 bg-[var(--color-action-hover)]" aria-labelledby="trust-heading">
    <h2 id="trust-heading" class="sr-only">{t.home.trust.sectionTitle}</h2>
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Autenticidad -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-white/10 mb-4">
            <Icon name="solar:shield-bold" class="w-7 h-7 text-white" />
          </div>
          <h3 class="text-base sm:text-lg font-display font-semibold mb-2 text-white">{t.home.trust.autenticidad}</h3>
          <p class="text-[var(--color-text-on-dark)]/80 text-sm">{t.home.trust.autenticidadDesc}</p>
        </div>
        
        <!-- Origen Verdeado -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-white/10 mb-4">
            <Icon name="solar:leaf-bold" class="w-7 h-7 text-white" />
          </div>
          <h3 class="text-base sm:text-lg font-display font-semibold mb-2 text-white">{t.home.trust.origen}</h3>
          <p class="text-[var(--color-text-on-dark)]/80 text-sm">{t.home.trust.origenDesc}</p>
        </div>
        
        <!-- Pureza Ritual -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-white/10 mb-4">
            <Icon name="solar:cloud-waterdrop-bold" class="w-7 h-7 text-white" />
          </div>
          <h3 class="text-base sm:text-lg font-display font-semibold mb-2 text-white">{t.home.trust.pureza}</h3>
          <p class="text-[var(--color-text-on-dark)]/80 text-sm">{t.home.trust.purezaDesc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Prophecy Teaser (replaces quiz section) -->
  <ProphecyTeaser prophecy={prophecy} locale={locale_} />

  <!-- Intention Categories (replaces quiz section) -->
  <section class="py-24 bg-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-display text-4xl md:text-5xl font-bold mb-4 text-[var(--near-black)]">
        {t.home.quiz.title}
      </h2>
      <p class="text-[var(--ceniza)] mb-12">{t.home.quiz.subtitle}</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
        {intentions.map((intent) => (
          <a
            href={`${baseUrl}/tienda/rape/${intent.slug}`}
            class="group border border-gray-200 p-6 hover:border-[var(--color-action-primary)] hover:bg-[var(--papel)] transition-all rounded-[var(--radius-card)] shadow-[var(--shadow-card)] text-left"
          >
            <span class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-full bg-[var(--papel)] group-hover:bg-white transition-colors">
              <Icon name={`solar:${iconNames[intent.icon]}`} class="w-7 h-7" />
            </span>
            <span class="text-sm font-semibold text-[var(--near-black)] block mb-1">
              {t.intentions[intent.key as keyof typeof t.intentions]}
            </span>
            <span class="text-xs text-[var(--color-action-primary)] block">
              {intent.medicineName}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Productos Section -->
  <section id="productos" class="py-24 px-6 bg-[var(--papel)]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4 text-[var(--near-black)]">{t.home.productos.title}</h2>
        <p class="text-[var(--ceniza)] tracking-widest uppercase">{t.home.productos.subtitle}</p>
      </div>
      
      <div class="text-center mt-12">
        <a href={`${baseUrl}/tienda`} class="inline-block border border-[var(--color-action-primary)] text-[var(--color-action-primary)] px-8 py-4 hover:bg-[var(--color-action-primary)] hover:text-white transition-colors rounded-[var(--radius-button)]">
          {t.home.productos.verTodos} →
        </a>
      </div>
    </div>
  </section>
</Layout>
