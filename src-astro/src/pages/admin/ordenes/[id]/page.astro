---
export const prerender = false;
// Order detail page — [id]
import AdminLayout from '@/layouts/AdminLayout.astro';
import OrderDetail from '@/components/admin/orders/OrderDetail.astro';

const { id } = Astro.params;
---

<AdminLayout title={`Orden ${id}`} description="Detalle de la orden">
  <!-- Back button -->
  <div class="mb-6">
    <a
      href="/admin/ordenes"
      class="inline-flex items-center gap-2 text-sm text-ceniza hover:text-humo transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a Órdenes
    </a>
  </div>

  <!-- Order Detail Component -->
  <OrderDetail orderId={id || ''} />
</AdminLayout>

<script>
  import { toast } from 'sonner';

  const orderId = window.location.pathname.split('/').pop();

  async function updateStatus(status: string, successMessage: string) {
    if (!orderId) return;

    try {
      const response = await fetch('/api/admin/ordenes/status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: orderId, status }),
      });

      if (!response.ok) {
        const data = await response.json().catch(() => ({ error: 'Error desconocido' }));
        toast.error(data.error || 'Error al actualizar la orden');
        return;
      }

      toast.success(successMessage);
      setTimeout(() => window.location.href = '/admin/ordenes', 1000);
    } catch {
      toast.error('Error de conexión');
    }
  }

  // Wire status update buttons
  document.querySelectorAll('button').forEach(btn => {
    const text = btn.textContent?.trim();

    if (text?.includes('Confirmar Orden')) {
      btn.addEventListener('click', () => updateStatus('confirmed', 'Orden confirmada correctamente'));
    }

    if (text?.includes('Cancelar Orden')) {
      btn.addEventListener('click', () => updateStatus('cancelled', 'Orden cancelada'));
    }

    if (text?.includes('Marcar como Enviada')) {
      btn.addEventListener('click', () => updateStatus('shipped', 'Orden marcada como enviada'));
    }
  });
</script>
