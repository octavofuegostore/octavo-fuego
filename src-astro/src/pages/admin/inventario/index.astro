---
export const prerender = false;
// Inventory page — Products management
import AdminLayout from '@/layouts/AdminLayout.astro';
import ProductTable from '@/components/admin/inventory/ProductTable.astro';
import { crearServicios } from '@/lib/admin/provider';
import { getBodegaSeleccionada } from '@/lib/admin/bodega';

const bodegaId = getBodegaSeleccionada(Astro.cookies);
const svc = crearServicios(bodegaId);
const products = await svc.productos.listar();
---

<AdminLayout title="Inventario" description="Gestiona tu catálogo de productos">
  <!-- Page Header -->
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-display font-bold text-humo">Inventario</h1>
        <p class="text-ceniza mt-1">Gestiona tu catálogo de productos</p>
      </div>
      <div class="flex items-center gap-3">
        <button id="exportar-productos-btn" class="flex items-center gap-2 px-4 py-2 border border-papel rounded-lg text-sm font-medium text-humo hover:bg-papel transition-colors">
          Exportar
        </button>
        <button id="nuevo-producto-btn" class="flex items-center gap-2 px-4 py-2 bg-tabacco text-white rounded-lg text-sm font-medium hover:bg-tabacco/90 transition-colors">
          Nuevo Producto
        </button>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <div class="bg-white rounded-xl p-4 shadow-card">
      <p class="text-sm text-ceniza">Total Productos</p>
      <p class="text-2xl font-bold text-humo font-display" id="stat-total">{products.length}</p>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-card">
      <p class="text-sm text-ceniza">Activos</p>
      <p class="text-2xl font-bold text-success font-display" id="stat-activos">{products.filter(p => p.status === 'active').length}</p>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-card">
      <p class="text-sm text-ceniza">Stock Bajo</p>
      <p class="text-2xl font-bold text-warning font-display" id="stat-bajo">{products.filter(p => p.stockCO < 100 || p.stockBR < 100).length}</p>
    </div>
  </div>

  <!-- Products Table -->
  <ProductTable products={products} />
</AdminLayout>

<script>
  import { toast } from 'sonner';

  const nuevoProductoBtn = document.getElementById('nuevo-producto-btn');
  const exportarBtn = document.getElementById('exportar-productos-btn');

  nuevoProductoBtn?.addEventListener('click', () => {
    toast.info('Formulario de producto - pronto');
  });

  exportarBtn?.addEventListener('click', () => {
    toast.success('Exportando productos...');
    setTimeout(() => toast.success('Productos exportados'), 1000);
  });
</script>
