---
export const prerender = false;
// Inventory page — Products management
import AdminLayout from '@/layouts/AdminLayout.astro';
import ProductTable from '@/components/admin/inventory/ProductTable.astro';
import ProductForm from '@/components/admin/inventory/ProductForm.astro';
import { crearServicios } from '@/lib/admin/provider';
import { CrearProductoSchema, CrearVarianteSchema } from '@/lib/admin/schemas/producto';
import { supabase } from '@/lib/supabase';

const svc = crearServicios();
const action = Astro.url.searchParams.get('action');
const editId = Astro.url.searchParams.get('id');

let editProduct: any = null;
let errors: Record<string, string> | null = null;

// POST handler
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const data = Object.fromEntries(form);
  const formAction = form.get('_action') as string;

  if (formAction === 'create') {
    const parsed = CrearProductoSchema.safeParse({
      slug: data.slug,
      nombre_es: data.nombre_es,
      nombre_en: data.nombre_en,
      nombre_pt: data.nombre_pt,
      tipo_venta: data.tipo_venta,
      activo: true,
    });
    if (!parsed.success) {
      errors = Object.fromEntries(
        parsed.error.errors.map(e => [e.path.join('.'), e.message])
      );
    } else {
      await svc.productos.crear(parsed.data as any);
      return Astro.redirect('/admin/inventario');
    }
  }

  if (formAction === 'update') {
    const parsed = CrearProductoSchema.partial().safeParse({
      slug: data.slug,
      nombre_es: data.nombre_es,
      nombre_en: data.nombre_en,
      nombre_pt: data.nombre_pt,
    });
    if (!parsed.success) {
      errors = Object.fromEntries(
        parsed.error.errors.map(e => [e.path.join('.'), e.message])
      );
    } else if (editId) {
      await svc.productos.actualizar(editId, parsed.data as any);
      return Astro.redirect('/admin/inventario');
    }
  }
}

// Load product + variantes if editing
let variantes: any[] = [];
if (action === 'edit' && editId) {
  try {
    editProduct = await svc.productos.obtenerPorId(editId);
    // Load variantes from Supabase
    const { data: v } = await supabase
      .from('variantes')
      .select('*')
      .eq('producto_id', editId)
      .order('gramos');
    variantes = v ?? [];
  } catch {
    editProduct = null;
  }
}

// Handle variant price update
if (Astro.request.method === 'POST' && editId) {
  const form = await Astro.request.formData();
  const prices: Record<string, any> = {};
  for (const [key, val] of form.entries()) {
    if (key.startsWith('precio_cop_') || key.startsWith('precio_brl_') || key.startsWith('precio_usd_')) {
      const variantId = key.replace('precio_cop_', '').replace('precio_brl_', '').replace('precio_usd_', '');
      const col = key.startsWith('precio_cop_') ? 'precio_cop' : key.startsWith('precio_brl_') ? 'precio_brl' : 'precio_usd';
      if (!prices[variantId]) prices[variantId] = { id: variantId };
      (prices[variantId] as any)[col] = val ? Number(val) : null;
    }
  }
  for (const p of Object.values(prices)) {
    await supabase.from('variantes').update(p).eq('id', (p as any).id);
  }
  return Astro.redirect('/admin/inventario');
}

const products = await svc.productos.listar();
---

<AdminLayout title="Inventario" description="Gestiona tu catálogo de productos">
  {action === 'create' || action === 'edit' ? (
    <ProductForm
      mode={action === 'edit' ? 'edit' : 'create'}
      product={editProduct ?? undefined}
      variantes={variantes}
      errors={errors}
    />
  ) : (
    <>
      <!-- Page Header -->
      <div class="mb-8">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-display font-bold text-humo">Inventario</h1>
            <p class="text-ceniza mt-1">Gestiona tu catálogo de productos</p>
          </div>
          <div class="flex items-center gap-3">
            <button id="exportar-productos-btn" class="flex items-center gap-2 px-4 py-2 border border-papel rounded-lg text-sm font-medium text-humo hover:bg-papel transition-colors">
              Exportar
            </button>
            <a href="/admin/inventario?action=create" class="inline-flex items-center gap-2 px-4 py-2 bg-tabacco text-white rounded-lg text-sm font-medium hover:bg-tabacco/90 transition-colors">
              Nuevo Producto
            </a>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-white rounded-xl p-4 shadow-card">
          <p class="text-sm text-ceniza">Total Productos</p>
          <p class="text-2xl font-bold text-humo font-display">{products.length}</p>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-card">
          <p class="text-sm text-ceniza">Activos</p>
          <p class="text-2xl font-bold text-success font-display">{products.filter(p => p.status === 'activo').length}</p>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-card">
          <p class="text-sm text-ceniza">Stock Bajo</p>
          <p class="text-2xl font-bold text-warning font-display">{products.filter(p => p.stockCO < 100 || p.stockBR < 100).length}</p>
        </div>
      </div>

      <!-- Products Table -->
      <ProductTable products={products} />
    </>
  )}
</AdminLayout>
