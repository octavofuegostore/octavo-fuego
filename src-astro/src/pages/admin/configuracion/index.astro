---
export const prerender = false;
// Settings page — System configuration
import AdminLayout from '@/layouts/AdminLayout.astro';
---

<AdminLayout title="Configuración" description="Configuración del sistema">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-2xl font-display font-bold text-humo">Configuración</h1>
    <p class="text-ceniza mt-1">Administra la configuración del sistema</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Settings -->
    <div class="lg:col-span-2 space-y-6">
      <!-- General Settings -->
      <div class="bg-white rounded-2xl shadow-card p-6">
        <h2 class="text-lg font-display font-bold text-humo mb-6">General</h2>
        
        <div class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-humo mb-2">Nombre del Negocio</label>
            <input
              type="text"
              value="Octavo Fuego"
              class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-humo mb-2">Email de Contacto</label>
            <input
              type="email"
              value="contacto@octavofuego.com"
              class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-humo mb-2">Teléfono</label>
            <input
              type="tel"
              value="+57 300 123 4567"
              class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-humo mb-2">Moneda Principal</label>
            <select class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors">
              <option value="COP" selected>COP - Peso Colombiano</option>
              <option value="BRL">BRL - Real Brasileño</option>
              <option value="USD">USD - Dólar Americano</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Inventory Settings -->
      <div class="bg-white rounded-2xl shadow-card p-6">
        <h2 class="text-lg font-display font-bold text-humo mb-6">Inventario</h2>
        
        <div class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-humo mb-2">Unidad de Medida Principal</label>
            <select class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors">
              <option value="g" selected>Gramos (g)</option>
              <option value="units">Unidades</option>
            </select>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-humo mb-2">Stock Mínimo por Defecto</label>
            <input
              type="number"
              value="100"
              min="0"
              class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            />
          </div>
          
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-humo">Alertas de Stock Bajo</p>
              <p class="text-xs text-ceniza">Recibir notificaciones cuando el stock esté bajo</p>
            </div>
            <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-tabacco transition-colors">
              <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform translate-x-6" />
            </button>
          </div>
        </div>
      </div>

      <!-- Order Settings -->
      <div class="bg-white rounded-2xl shadow-card p-6">
        <h2 class="text-lg font-display font-bold text-humo mb-6">Órdenes</h2>
        
        <div class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-humo mb-2">Tiempo de Expiración de Reserva (minutos)</label>
            <input
              type="number"
              value="15"
              min="5"
              max="60"
              class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-humo mb-2">Costo de Envío por Defecto (COP)</label>
            <input
              type="number"
              value="8000"
              min="0"
              class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
            />
          </div>
          
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-humo">Checkout por WhatsApp</p>
              <p class="text-xs text-ceniza">Habilitar checkout via WhatsApp</p>
            </div>
            <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-tabacco transition-colors">
              <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform translate-x-6" />
            </button>
          </div>
          
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-humo">Modo Mayorista</p>
              <p class="text-xs text-ceniza">Habilitar precios mayoristas</p>
            </div>
            <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-tabacco transition-colors">
              <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform translate-x-6" />
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Locations -->
      <div class="bg-white rounded-2xl shadow-card p-6">
        <h3 class="font-display text-lg font-bold text-humo mb-4">Ubicaciones</h3>
        
        <div class="space-y-4">
          <div class="p-3 bg-info/5 rounded-xl border border-info/20">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-info" />
              <span class="text-sm font-medium text-humo">CO-BOGOTA</span>
            </div>
            <p class="text-xs text-ceniza mt-1">Bogotá, Colombia</p>
          </div>
          
          <div class="p-3 bg-success/5 rounded-xl border border-success/20">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-success" />
              <span class="text-sm font-medium text-humo">BR-ACRE</span>
            </div>
            <p class="text-xs text-ceniza mt-1">Rio Branco, Brasil</p>
          </div>
        </div>
      </div>

      <!-- Regions -->
      <div class="bg-white rounded-2xl shadow-card p-6">
        <h3 class="font-display text-lg font-bold text-humo mb-4">Regiones Activas</h3>
        
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-humo">🇨🇴 Colombia</span>
            <span class="text-xs text-success font-medium">Activa</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-humo">🇧🇷 Brasil</span>
            <span class="text-xs text-success font-medium">Activa</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-humo">🇪🇺 Europa</span>
            <span class="text-xs text-warning font-medium">Próximamente</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-humo">🇺🇸 USA</span>
            <span class="text-xs text-warning font-medium">Próximamente</span>
          </div>
        </div>
      </div>

      <!-- System Info -->
      <div class="bg-white rounded-2xl shadow-card p-6">
        <h3 class="font-display text-lg font-bold text-humo mb-4">Sistema</h3>
        
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-ceniza">Versión</span>
            <span class="text-sm font-medium text-humo">1.0.0</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-ceniza">Última actualización</span>
            <span class="text-sm font-medium text-humo">16 Jun 2026</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-ceniza">Base de datos</span>
            <span class="text-sm font-medium text-success">Conectada</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
