---
export const prerender = false;
// Transacciones page — Lista de transacciones con datos reales
import AdminLayout from '@/layouts/AdminLayout.astro';
import { ContabilidadService } from '@/lib/admin/services/contabilidad';
import { formatCurrency } from '@/lib/formatCurrency';
import type { CategoriaTransaccion } from '@/types/admin';

const svc = new ContabilidadService();
const categorias = await svc.obtenerCategorias();
const { data: transacciones, total } = await svc.listarTransacciones(1, 200);

const meses = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
---

<AdminLayout title="Transacciones" description="Historial de transacciones financieras">
  <!-- Page Header -->
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-display font-bold text-humo">Transacciones</h1>
        <p class="text-ceniza mt-1">Historial de transacciones financieras</p>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-2xl shadow-card p-6 mb-6">
    <div class="flex flex-col sm:flex-row sm:items-center gap-4">
      <!-- Search -->
      <div class="flex-1 max-w-md">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="search-transaccion"
            placeholder="Buscar transacciones..."
            class="w-full pl-10 pr-4 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
          />
        </div>
      </div>
      <!-- Tipo filter -->
      <select id="tipo-filter" class="px-3 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco bg-white">
        <option value="">Todos los tipos</option>
        <option value="Ingreso">Ingreso</option>
        <option value="Egreso">Egreso</option>
      </select>
      <!-- Mes filter -->
      <select id="mes-filter" class="px-3 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco bg-white">
        <option value="">Todos los meses</option>
        {meses.map((m, i) => <option value={i}>{m}</option>)}
      </select>
      <!-- Nueva Transaccion button -->
      <button id="nueva-transaccion-btn" class="flex items-center gap-2 px-4 py-2 bg-tabacco text-white rounded-lg text-sm font-medium hover:bg-tabacco/90 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Nueva Transacción
      </button>
    </div>
  </div>

  <!-- Transactions Table (JS-rendered) -->
  <div class="bg-white rounded-2xl shadow-card overflow-hidden mb-6">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-papel">
            <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Fecha</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Descripción</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Categoría</th>
            <th class="text-center px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Tipo</th>
            <th class="text-right px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Monto</th>
            <th class="text-right px-6 py-3 text-xs font-medium text-ceniza uppercase tracking-wider">Acciones</th>
          </tr>
        </thead>
        <tbody id="transaccion-tbody" class="divide-y divide-papel">
          <!-- JS renders rows -->
        </tbody>
      </table>
    </div>
    <!-- Empty state -->
    <div id="empty-state" class="hidden p-12 text-center">
      <svg class="w-12 h-12 text-ceniza mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p class="text-humo font-medium">No se encontraron transacciones</p>
      <p class="text-ceniza text-sm mt-1">Intenta ajustar los filtros</p>
    </div>
  </div>

  <!-- Delete Confirmation Dialog -->
  <div id="delete-confirm-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full p-6">
      <h3 class="text-lg font-display font-bold text-humo mb-2">Eliminar Transacción</h3>
      <p class="text-sm text-ceniza mb-6">¿Estás seguro de eliminar esta transacción? Esta acción no se puede deshacer.</p>
      <div class="flex items-center justify-end gap-3">
        <button id="cancel-delete-btn" class="px-4 py-2 border border-papel rounded-lg text-sm font-medium text-humo hover:bg-papel transition-colors">Cancelar</button>
        <button id="confirm-delete-btn" class="px-4 py-2 bg-error text-white rounded-lg text-sm font-medium hover:bg-error/90 transition-colors">Eliminar</button>
      </div>
    </div>
  </div>

  <!-- Pagination -->
  <div class="flex items-center justify-between">
    <p id="pagination-info" class="text-sm text-ceniza">Mostrando 1-{Math.min(total, 200)} de {total} transacciones</p>
    <div id="pagination-controls" class="flex items-center gap-2">
      <!-- JS renders pagination buttons -->
    </div>
  </div>

  <!-- Transaccion Modal (Create/Edit) -->
  <div id="transaccion-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
      <div class="p-6 border-b border-papel">
        <div class="flex items-center justify-between">
          <div>
            <h2 id="transaccion-modal-title" class="text-xl font-display font-bold text-humo">Nueva Transacción</h2>
            <p id="transaccion-modal-desc" class="text-sm text-ceniza mt-1">Agrega una nueva transacción al registro</p>
          </div>
          <button id="close-transaccion-modal" class="p-2 text-ceniza hover:text-humo hover:bg-papel rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
      <form id="transaccion-form" class="p-6 space-y-4">
        <input type="hidden" id="transaccion-editing-id" value="" />
        <div>
          <label class="block text-sm font-medium text-humo mb-2">Tipo *</label>
          <select id="transaccion-tipo" required class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco">
            <option value="">Seleccionar...</option>
            <option value="Ingreso">Ingreso</option>
            <option value="Egreso">Egreso</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-humo mb-2">Descripción *</label>
          <input type="text" id="transaccion-descripcion" required placeholder="Descripción de la transacción" class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco" />
        </div>
        <div>
          <label class="block text-sm font-medium text-humo mb-2">Categoría *</label>
          <select id="transaccion-categoria" required class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco">
            <option value="">Seleccionar...</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-humo mb-2">Monto (COP) *</label>
          <input type="number" id="transaccion-monto" required min="0" placeholder="0" class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco" />
        </div>
        <div>
          <label class="block text-sm font-medium text-humo mb-2">Fecha *</label>
          <input type="date" id="transaccion-fecha" required class="w-full px-4 py-2.5 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco" />
        </div>
        <div class="flex items-center justify-end gap-3 pt-4 border-t border-papel">
          <button type="button" id="cancel-transaccion-form" class="px-4 py-2 border border-papel rounded-lg text-sm font-medium text-humo hover:bg-papel transition-colors">Cancelar</button>
          <button type="submit" class="px-4 py-2 bg-tabacco text-white rounded-lg text-sm font-medium hover:bg-tabacco/90 transition-colors">Guardar Transacción</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ transacciones, categorias, total }}>
  import { toast } from 'sonner';

  interface TransaccionItem {
    id: string;
    fecha: string;
    descripcion: string;
    categoria: string;
    tipo: string;
    monto: number;
    moneda: string;
    metodo_pago?: string;
    orden_id?: string;
  }

  function initPage() {
    let allTransacciones: TransaccionItem[] = (transacciones as TransaccionItem[]) || [];

    // Pagination state
    let currentPage = 1;
    const pageSize = 7;
    let filteredTransacciones = [...allTransacciones];
    let editingId: string | null = null;

    // DOM elements
    const searchInput = document.getElementById('search-transaccion') as HTMLInputElement;
    const tipoFilter = document.getElementById('tipo-filter') as HTMLSelectElement;
    const mesFilter = document.getElementById('mes-filter') as HTMLSelectElement;
    const tbody = document.getElementById('transaccion-tbody') as HTMLHTMLTableSectionElement;
    const emptyState = document.getElementById('empty-state') as HTMLDivElement;
    const paginationInfo = document.getElementById('pagination-info') as HTMLParagraphElement;
    const paginationControls = document.getElementById('pagination-controls') as HTMLDivElement;
    const nuevaBtn = document.getElementById('nueva-transaccion-btn');
    const modal = document.getElementById('transaccion-modal');
    const closeBtn = document.getElementById('close-transaccion-modal');
    const cancelBtn = document.getElementById('cancel-transaccion-form');
    const form = document.getElementById('transaccion-form') as HTMLFormElement;
    const tipoSelect = document.getElementById('transaccion-tipo') as HTMLSelectElement;
    const categoriaSelect = document.getElementById('transaccion-categoria') as HTMLSelectElement;
    const modalTitle = document.getElementById('transaccion-modal-title');
    const modalDesc = document.getElementById('transaccion-modal-desc');
    const editingIdInput = document.getElementById('transaccion-editing-id') as HTMLInputElement;
    const deleteConfirmModal = document.getElementById('delete-confirm-modal');
    const confirmDeleteBtn = document.getElementById('confirm-delete-btn');
    const cancelDeleteBtn = document.getElementById('cancel-delete-btn');

    let pendingDeleteId: string | null = null;

    function filterTransacciones() {
      const query = searchInput?.value.toLowerCase() || '';
      const tipo = tipoFilter?.value || '';
      const mes = mesFilter?.value || '';

      filteredTransacciones = allTransacciones.filter((t: TransaccionItem) => {
        const matchesSearch = t.descripcion.toLowerCase().includes(query) || t.categoria.toLowerCase().includes(query);
        const matchesTipo = !tipo || t.tipo === tipo;
        const transactionMonth = new Date(t.fecha).getMonth();
        const matchesMes = !mes || String(transactionMonth) === mes;
        return matchesSearch && matchesTipo && matchesMes;
      });

      currentPage = 1;
      renderTransacciones();
      renderPagination();
    }

    function formatCOP(amount: number): string {
      return new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(amount);
    }

    function formatDate(dateStr: string): string {
      return new Date(dateStr).toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    function renderTransacciones() {
      if (!tbody) return;

      const totalPages = Math.ceil(filteredTransacciones.length / pageSize);
      const start = (currentPage - 1) * pageSize;
      const end = start + pageSize;
      const pageData = filteredTransacciones.slice(start, end);

      if (pageData.length === 0) {
        tbody.innerHTML = '';
        emptyState?.classList.remove('hidden');
        return;
      }

      emptyState?.classList.add('hidden');

      tbody.innerHTML = pageData.map((t: TransaccionItem) => `
        <tr class="hover:bg-papel/30 transition-colors cursor-pointer" data-transaccion-id="${t.id}">
          <td class="px-6 py-4 text-sm text-humo">${formatDate(t.fecha)}</td>
          <td class="px-6 py-4 text-sm text-humo">${t.descripcion}</td>
          <td class="px-6 py-4 text-sm text-ceniza">${t.categoria}</td>
          <td class="px-6 py-4 text-center">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${t.tipo === 'Ingreso' ? 'bg-success/10 text-success' : 'bg-error/10 text-error'}">${t.tipo}</span>
          </td>
          <td class="px-6 py-4 text-right text-sm font-medium text-humo">${formatCOP(t.monto)}</td>
          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-2">
              <button class="p-1.5 text-ceniza hover:text-humo hover:bg-papel rounded-lg transition-colors edit-btn" title="Editar" data-id="${t.id}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
              </button>
            </div>
          </td>
        </tr>
      `).join('');

      // Wire row click to edit
      tbody.querySelectorAll('tr[data-transaccion-id]').forEach(row => {
        row.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('.edit-btn')) return;
          const id = row.getAttribute('data-transaccion-id');
          if (id) {
            const t = allTransacciones.find((tx: TransaccionItem) => tx.id === id);
            if (t) {
              toast.info(`Editando transacción ${t.descripcion}`);
            }
          }
        });
      });

      // Wire edit buttons
      tbody.querySelectorAll('.edit-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const id = (e.currentTarget as HTMLElement).getAttribute('data-id');
          if (id) {
            const t = allTransacciones.find((tx: TransaccionItem) => tx.id === id);
            if (t) {
              toast.info(`Editando transacción ${t.descripcion}`);
            }
          }
        });
      });

      // Update pagination info
      if (paginationInfo) {
        const totalItems = filteredTransacciones.length;
        paginationInfo.textContent = `Mostrando ${start + 1}-${Math.min(end, totalItems)} de ${totalItems} transacciones`;
      }
    }

    function renderPagination() {
      if (!paginationControls) return;
      const totalPages = Math.ceil(filteredTransacciones.length / pageSize);

      let html = `
        <button class="px-3 py-1.5 text-sm rounded-lg border border-papel text-ceniza hover:bg-papel transition-colors prev-btn" ${currentPage === 1 ? 'disabled' : ''}>Anterior</button>
      `;

      for (let i = 1; i <= totalPages; i++) {
        html += `<button class="px-3 py-1.5 text-sm rounded-lg transition-colors page-btn ${i === currentPage ? 'bg-tabacco text-white' : 'border border-papel text-humo hover:bg-papel'}" data-page="${i}">${i}</button>`;
      }

      html += `<button class="px-3 py-1.5 text-sm rounded-lg border border-papel text-ceniza hover:bg-papel transition-colors next-btn" ${currentPage === totalPages ? 'disabled' : ''}>Siguiente</button>`;

      paginationControls.innerHTML = html;

      // Wire pagination buttons
      paginationControls.querySelectorAll('.page-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const page = parseInt((btn as HTMLButtonElement).getAttribute('data-page') || '1', 10);
          currentPage = page;
          renderTransacciones();
          renderPagination();
        });
      });

      const prevBtn = paginationControls.querySelector('.prev-btn');
      prevBtn?.addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage--;
          renderTransacciones();
          renderPagination();
        }
      });

      const nextBtn = paginationControls.querySelector('.next-btn');
      nextBtn?.addEventListener('click', () => {
        if (currentPage < Math.ceil(filteredTransacciones.length / pageSize)) {
          currentPage++;
          renderTransacciones();
          renderPagination();
        }
      });
    }

    // Wire search and filters
    searchInput?.addEventListener('input', filterTransacciones);
    tipoFilter?.addEventListener('change', filterTransacciones);
    mesFilter?.addEventListener('change', filterTransacciones);

    // Wire "Nueva Transaccion" button
    nuevaBtn?.addEventListener('click', () => {
      if (!modal) return;
      form?.reset();
      updateCategoriaOptions('');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    });

    const categoriasList = (categorias as Array<{ nombre: string; tipo: string; subcategorias: string[] }>) || [];
    const categoriaNameToId = new Map(categoriasList.map(c => [c.nombre, c.id]));

    function updateCategoriaOptions(tipo: string) {
      if (!categoriaSelect) return;
      const options = categoriasList
        .filter(c => (tipo === 'Ingreso' && c.tipo === 'ingreso') || (tipo === 'Egreso' && c.tipo === 'egreso'))
        .map(c => c.nombre);
      categoriaSelect.innerHTML = '<option value="">Seleccionar...</option>' + options.map(c => `<option value="${c}">${c}</option>`).join('');
    }

    tipoSelect?.addEventListener('change', () => {
      updateCategoriaOptions(tipoSelect.value);
    });

    function closeModal() {
      if (!modal) return;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    closeBtn?.addEventListener('click', closeModal);
    cancelBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // ════════════════════════════════════════════════════════════════════
    // API helpers
    // ════════════════════════════════════════════════════════════════════

    async function crearTransaccion(data: {
      tipo: string; descripcion: string; categoria: string; monto: number; fecha: string;
    }) {
      const categoriaId = categoriaNameToId.get(data.categoria);
      const res = await fetch('/api/admin/contabilidad/transacciones', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          tipo: data.tipo === 'Ingreso' ? 'ingreso' : 'egreso',
          descripcion: data.descripcion,
          categoria_id: categoriaId,
          monto: data.monto,
          fecha: data.fecha,
          moneda: 'COP',
        }),
      });
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Error al crear transacción');
      }
      return res.json();
    }

    async function actualizarTransaccion(id: string, data: {
      tipo?: string; descripcion?: string; categoria?: string; monto?: number; fecha?: string;
    }) {
      const body: Record<string, unknown> = {};
      if (data.tipo) body.tipo = data.tipo === 'Ingreso' ? 'ingreso' : 'egreso';
      if (data.descripcion) body.descripcion = data.descripcion;
      if (data.categoria) {
        const categoriaId = categoriaNameToId.get(data.categoria);
        if (categoriaId) body.categoria_id = categoriaId;
      }
      if (data.monto !== undefined) body.monto = data.monto;
      if (data.fecha) body.fecha = data.fecha;

      const res = await fetch(`/api/admin/contabilidad/transacciones/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Error al actualizar transacción');
      }
      return res.json();
    }

    async function eliminarTransaccion(id: string) {
      const res = await fetch(`/api/admin/contabilidad/transacciones/${id}`, {
        method: 'DELETE',
      });
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Error al eliminar transacción');
      }
    }

    // ════════════════════════════════════════════════════════════════════
    // Form submit — create or update
    // ════════════════════════════════════════════════════════════════════

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const tipo = (document.getElementById('transaccion-tipo') as HTMLSelectElement)?.value;
      const descripcion = (document.getElementById('transaccion-descripcion') as HTMLInputElement)?.value;
      const categoria = (document.getElementById('transaccion-categoria') as HTMLSelectElement)?.value;
      const monto = parseFloat((document.getElementById('transaccion-monto') as HTMLInputElement)?.value || '0');
      const fecha = (document.getElementById('transaccion-fecha') as HTMLInputElement)?.value;
      const editingIdVal = editingIdInput?.value;

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn?.innerHTML || 'Guardar';
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = 'Guardando...';
      }

      try {
        if (editingIdVal) {
          // UPDATE existing transaction
          await actualizarTransaccion(editingIdVal, {
            tipo, descripcion, categoria, monto, fecha,
          });
          // Reload page to reflect server-side changes
          window.location.reload();
        } else {
          // CREATE new transaction
          const result = await crearTransaccion({
            tipo, descripcion, categoria, monto, fecha,
          });
          // Add returned data to local list
          const newTx: TransaccionItem = {
            id: result.data.id,
            fecha: result.data.fecha,
            descripcion: result.data.descripcion,
            categoria: categoria || '',
            tipo: tipo as 'Ingreso' | 'Egreso',
            monto: result.data.monto,
            moneda: result.data.moneda || 'COP',
          };
          allTransacciones.unshift(newTx);
          closeModal();
          filterTransacciones();
          toast.success('Transacción creada correctamente');
        }
      } catch (err: unknown) {
        const message = err instanceof Error ? err.message : 'Error de red';
        toast.error(message);
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
        }
      }
    });

    // ════════════════════════════════════════════════════════════════════
    // Open modal in CREATE mode
    // ════════════════════════════════════════════════════════════════════

    nuevaBtn?.addEventListener('click', () => {
      if (!modal) return;
      editingId = null;
      if (editingIdInput) editingIdInput.value = '';
      if (modalTitle) modalTitle.textContent = 'Nueva Transacción';
      if (modalDesc) modalDesc.textContent = 'Agrega una nueva transacción al registro';
      form?.reset();
      updateCategoriaOptions('');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    });

    // ════════════════════════════════════════════════════════════════════
    // Open modal in EDIT mode
    // ════════════════════════════════════════════════════════════════════

    function openEditModal(id: string) {
      const t = allTransacciones.find((tx: TransaccionItem) => tx.id === id);
      if (!t || !modal) return;

      editingId = id;
      if (editingIdInput) editingIdInput.value = id;
      if (modalTitle) modalTitle.textContent = 'Editar Transacción';
      if (modalDesc) modalDesc.textContent = 'Modifica los datos de la transacción';

      (document.getElementById('transaccion-tipo') as HTMLSelectElement).value = t.tipo;
      (document.getElementById('transaccion-descripcion') as HTMLInputElement).value = t.descripcion;
      updateCategoriaOptions(t.tipo);
      // Wait for options to populate, then select
      setTimeout(() => {
        const opts = (document.getElementById('transaccion-categoria') as HTMLSelectElement)?.options;
        if (opts) {
          for (let i = 0; i < opts.length; i++) {
            if (opts[i].value === t.categoria) {
              opts.selectedIndex = i;
              break;
            }
          }
        }
      }, 0);
      (document.getElementById('transaccion-monto') as HTMLInputElement).value = String(t.monto);
      (document.getElementById('transaccion-fecha') as HTMLInputElement).value = t.fecha.split('T')[0];

      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    // ════════════════════════════════════════════════════════════════════
    // Delete handlers
    // ════════════════════════════════════════════════════════════════════

    function openDeleteConfirm(id: string) {
      pendingDeleteId = id;
      deleteConfirmModal?.classList.remove('hidden');
      deleteConfirmModal?.classList.add('flex');
    }

    cancelDeleteBtn?.addEventListener('click', () => {
      pendingDeleteId = null;
      deleteConfirmModal?.classList.add('hidden');
      deleteConfirmModal?.classList.remove('flex');
    });

    confirmDeleteBtn?.addEventListener('click', async () => {
      if (!pendingDeleteId) return;
      const id = pendingDeleteId;
      pendingDeleteId = null;
      deleteConfirmModal?.classList.add('hidden');
      deleteConfirmModal?.classList.remove('flex');

      try {
        await eliminarTransaccion(id);
        allTransacciones = allTransacciones.filter((t: TransaccionItem) => t.id !== id);
        filterTransacciones();
        toast.success('Transacción eliminada correctamente');
      } catch (err: unknown) {
        const message = err instanceof Error ? err.message : 'Error de red';
        toast.error(message);
      }
    });

    deleteConfirmModal?.addEventListener('click', (e) => {
      if (e.target === deleteConfirmModal) {
        pendingDeleteId = null;
        deleteConfirmModal.classList.add('hidden');
        deleteConfirmModal.classList.remove('flex');
      }
    });

    // ════════════════════════════════════════════════════════════════════
    // Update table template — full override with edit + delete
    // ════════════════════════════════════════════════════════════════════

    renderTransacciones = function () {
      if (!tbody) return;

      const totalPages = Math.ceil(filteredTransacciones.length / pageSize);
      const start = (currentPage - 1) * pageSize;
      const end = start + pageSize;
      const pageData = filteredTransacciones.slice(start, end);

      if (pageData.length === 0) {
        tbody.innerHTML = '';
        emptyState?.classList.remove('hidden');
        return;
      }

      emptyState?.classList.add('hidden');

      tbody.innerHTML = pageData.map((t: TransaccionItem) => `
        <tr class="hover:bg-papel/30 transition-colors cursor-pointer" data-transaccion-id="${t.id}">
          <td class="px-6 py-4 text-sm text-humo">${formatDate(t.fecha)}</td>
          <td class="px-6 py-4 text-sm text-humo">${t.descripcion}</td>
          <td class="px-6 py-4 text-sm text-ceniza">${t.categoria}</td>
          <td class="px-6 py-4 text-center">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${t.tipo === 'Ingreso' ? 'bg-success/10 text-success' : 'bg-error/10 text-error'}">${t.tipo}</span>
          </td>
          <td class="px-6 py-4 text-right text-sm font-medium text-humo">${formatCOP(t.monto)}</td>
          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-1">
              <button class="p-1.5 text-ceniza hover:text-error hover:bg-error/5 rounded-lg transition-colors delete-btn" title="Eliminar" data-id="${t.id}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
              <button class="p-1.5 text-ceniza hover:text-humo hover:bg-papel rounded-lg transition-colors edit-btn" title="Editar" data-id="${t.id}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
              </button>
            </div>
          </td>
        </tr>
      `).join('');

      // Wire actions
      tbody.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const id = (e.currentTarget as HTMLElement).getAttribute('data-id');
          if (id) openDeleteConfirm(id);
        });
      });
      tbody.querySelectorAll('.edit-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const id = (e.currentTarget as HTMLElement).getAttribute('data-id');
          if (id) openEditModal(id);
        });
      });
      tbody.querySelectorAll('tr[data-transaccion-id]').forEach(row => {
        row.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('.edit-btn') || target.closest('.delete-btn')) return;
          const id = row.getAttribute('data-transaccion-id');
          if (id) openEditModal(id);
        });
      });

      if (paginationInfo) {
        const totalItems = filteredTransacciones.length;
        paginationInfo.textContent = `Mostrando ${start + 1}-${Math.min(end, totalItems)} de ${totalItems} transacciones`;
      }
    };

    // Initial render
    renderTransacciones();
    renderPagination();
  }

  initPage();
  if (!(window as any).__transaccionesInitDone) {
    (window as any).__transaccionesInitDone = true;
    document.addEventListener('astro:page-load', initPage);
  }
</script>
