---
export const prerender = false;
// Contabilidad dashboard — Resumen financiero con datos reales
import AdminLayout from '@/layouts/AdminLayout.astro';
import KpiCard from '@/components/admin/contabilidad/KpiCard.astro';
import GraficaBarras from '@/components/admin/contabilidad/GraficaBarras.astro';
import GraficaTorta from '@/components/admin/charts/GraficaTorta.astro';
import { ContabilidadService } from '@/lib/admin/services/contabilidad';
import { supabase } from '@/lib/supabase';
import { formatCurrency } from '@/lib/formatCurrency';

const svc = new ContabilidadService();

// Parse selected month/year from URL, default to current
const now = new Date();
const mesParam = parseInt(Astro.url.searchParams.get('mes') ?? String(now.getMonth()), 10);
const añoParam = parseInt(Astro.url.searchParams.get('año') ?? String(now.getFullYear()), 10);
const mes = mesParam >= 0 && mesParam <= 11 ? mesParam : now.getMonth();
const año = añoParam >= 2020 && añoParam <= 2030 ? añoParam : now.getFullYear();

const kpis = await svc.obtenerKPIs(mes + 1, año);
const graficaMensual = await svc.obtenerGraficaMensual(año);

// Expense breakdown by category for the selected month
const { data: transacciones } = await svc.listarTransacciones(1, 1000, {
  tipo: 'egreso',
  fechaDesde: `${año}-${String(mes + 1).padStart(2, '0')}-01`,
  fechaHasta: new Date(año, mes + 1, 1).toISOString().split('T')[0],
});

// Aggregate expenses by category
const expenseMap = new Map<string, number>();
const expenseColors = [
  '#8B4513', '#6B7280', '#EC4899', '#F59E0B',
  '#3B82F6', '#10B981', '#EF4444', '#8B5CF6',
];
let colorIdx = 0;
for (const t of transacciones) {
  const current = expenseMap.get(t.categoria) ?? 0;
  expenseMap.set(t.categoria, current + t.monto);
}
const expensesByCategory = Array.from(expenseMap.entries()).map(([label, value]) => ({
  label,
  value,
  color: expenseColors[colorIdx++ % expenseColors.length],
}));

// Serialize monthly KPI data for client-side: single aggregate query
const { data: monthlyTxns } = await supabase
  .from('transacciones')
  .select('tipo, monto, fecha')
  .gte('fecha', `${año}-01-01`)
  .lt('fecha', `${año + 1}-01-01`)

const monthlyData: Record<string, { ingresos: number; egresos: number; balance: number }> = {};
for (let m = 0; m < 12; m++) {
  monthlyData[`${año}-${m}`] = { ingresos: 0, egresos: 0, balance: 0 }
}

for (const t of monthlyTxns ?? []) {
  const d = new Date(t.fecha)
  const mesIdx = d.getMonth()
  const key = `${año}-${mesIdx}`
  if (t.tipo === 'ingreso') {
    monthlyData[key].ingresos += Number(t.monto)
  } else {
    monthlyData[key].egresos += Number(t.monto)
  }
}

for (let m = 0; m < 12; m++) {
  const key = `${año}-${m}`
  monthlyData[key].balance = monthlyData[key].ingresos - monthlyData[key].egresos
}

const mesNames = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
const ingresosIcon = 'M7 11l5-5m0 0l5 5m-5-5v12';
const egresosIcon = 'M7 13l5 5m0 0l5-5m-5 5V6';
const balanceIcon = 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z';
---

<AdminLayout title="Contabilidad" description="Resumen financiero de tu negocio">
  <!-- Page Header -->
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-display font-bold text-humo">Contabilidad</h1>
        <p class="text-ceniza mt-1">Resumen de {mesNames[mes]} {año}</p>
      </div>
      <div class="flex items-center gap-3">
        <!-- Date Range Selector -->
        <div class="flex items-center gap-2">
          <select id="mes-select" class="px-3 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco bg-white">
            <option value="0" set:selected={mes === 0}>Enero</option>
            <option value="1" set:selected={mes === 1}>Febrero</option>
            <option value="2" set:selected={mes === 2}>Marzo</option>
            <option value="3" set:selected={mes === 3}>Abril</option>
            <option value="4" set:selected={mes === 4}>Mayo</option>
            <option value="5" set:selected={mes === 5}>Junio</option>
            <option value="6" set:selected={mes === 6}>Julio</option>
            <option value="7" set:selected={mes === 7}>Agosto</option>
            <option value="8" set:selected={mes === 8}>Septiembre</option>
            <option value="9" set:selected={mes === 9}>Octubre</option>
            <option value="10" set:selected={mes === 10}>Noviembre</option>
            <option value="11" set:selected={mes === 11}>Diciembre</option>
          </select>
          <select id="year-select" class="px-3 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco bg-white">
            <option value="2024" set:selected={año === 2024}>2024</option>
            <option value="2025" set:selected={año === 2025}>2025</option>
            <option value="2026" set:selected={año === 2026}>2026</option>
          </select>
        </div>
        <!-- Export Button -->
        <button id="export-contabilidad-btn" class="flex items-center gap-2 px-4 py-2 border border-papel rounded-lg text-sm font-medium text-humo hover:bg-papel transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
          </svg>
          Exportar CSV
        </button>
      </div>
    </div>
  </div>

  <!-- KPI Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    <KpiCard
      icon={ingresosIcon}
      title="Ingresos del Mes"
      value={formatCurrency(kpis.ingresosMes, 'COP')}
      trend="up"
      trendValue="+12.5%"
    />
    <KpiCard
      icon={egresosIcon}
      title="Egresos del Mes"
      value={formatCurrency(kpis.egresosMes, 'COP')}
      trend="down"
      trendValue="+8.3%"
    />
    <KpiCard
      icon={balanceIcon}
      title="Balance"
      value={formatCurrency(kpis.balance, 'COP')}
      trend="up"
      trendValue="+15.2%"
    />
  </div>

  <!-- Monthly Evolution Chart -->
  <div class="mb-8">
    <h2 class="text-lg font-display font-bold text-humo mb-4">Evolución Mensual</h2>
    <GraficaBarras data={graficaMensual} />
  </div>

  <!-- Expense Breakdown Chart -->
  <div>
    <h2 class="text-lg font-display font-bold text-humo mb-4">Gastos por Categoría</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <GraficaTorta
        data={expensesByCategory}
        title="Gastos del Mes"
        size={280}
      />
      <!-- Summary cards for expenses -->
      <div class="space-y-4">
        {expensesByCategory.map((expense) => (
          <div class="flex items-center justify-between p-4 bg-white rounded-xl shadow-card">
            <div class="flex items-center gap-3">
              <span
                class="w-4 h-4 rounded"
                style={`background-color: ${expense.color};`}
              ></span>
              <span class="text-sm font-medium text-humo">{expense.label}</span>
            </div>
            <span class="text-sm font-bold text-humo">
              {formatCurrency(expense.value, 'COP')}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ monthlyData, mes, año }}>
  import { toast } from 'sonner';

  const mesNames = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];

  function initPage() {
    function formatCOP(amount: number): string {
      return new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(amount);
    }

    function updateDashboard(mes: number, year: number) {
      const key = `${year}-${mes}`;
      const kpis = (monthlyData as Record<string, { ingresos: number; egresos: number; balance: number }>)[key] || { ingresos: 0, egresos: 0, balance: 0 };
      const kpiCards = document.querySelectorAll('[data-kpi-card]');
      if (kpiCards.length >= 3) {
        const ingresosEl = kpiCards[0].querySelector('.font-display.text-2xl');
        const egresosEl = kpiCards[1].querySelector('.font-display.text-2xl');
        const balanceEl = kpiCards[2].querySelector('.font-display.text-2xl');
        if (ingresosEl) ingresosEl.textContent = formatCOP(kpis.ingresos);
        if (egresosEl) egresosEl.textContent = formatCOP(kpis.egresos);
        if (balanceEl) balanceEl.textContent = formatCOP(kpis.balance);
      }
      // Update subtitle
      const subtitle = document.querySelector('.text-ceniza.mt-1');
      if (subtitle) subtitle.textContent = `Resumen de ${mesNames[mes]} ${year}`;
    }

    function navigateTo(mes: number, year: number) {
      // Full page navigation with URL params — loads real data from server
      const params = new URLSearchParams({ mes: String(mes), año: String(year) });
      window.location.href = `/admin/contabilidad?${params.toString()}`;
    }

    // Wire date selectors
    const mesSelect = document.getElementById('mes-select') as HTMLSelectElement;
    const yearSelect = document.getElementById('year-select') as HTMLSelectElement;

    mesSelect?.addEventListener('change', () => {
      const newMes = parseInt(mesSelect.value, 10);
      const newYear = parseInt(yearSelect?.value || String(año), 10);
      navigateTo(newMes, newYear);
    });

    yearSelect?.addEventListener('change', () => {
      const newMes = parseInt(mesSelect?.value || String(mes), 10);
      const newYear = parseInt(yearSelect.value, 10);
      navigateTo(newMes, newYear);
    });

    // Wire export button
    const exportBtn = document.getElementById('export-contabilidad-btn');
    exportBtn?.addEventListener('click', () => {
      const currentMes = parseInt(mesSelect?.value || String(mes), 10);
      const currentYear = parseInt(yearSelect?.value || String(año), 10);
      const key = `${currentYear}-${currentMes}`;
      const kpis = (monthlyData as Record<string, { ingresos: number; egresos: number; balance: number }>)[key] || { ingresos: 0, egresos: 0, balance: 0 };

      const csvContent = `data:text/csv;charset=utf-8,Mes,Ingresos,Egresos,Balance\n"${mesNames[currentMes]} ${currentYear}",${kpis.ingresos},${kpis.egresos},${kpis.balance}`;

      const encodedUri = encodeURI(csvContent);
      const link = document.createElement('a');
      link.setAttribute('href', encodedUri);
      link.setAttribute('download', `contabilidad_${mesNames[currentMes].toLowerCase()}_${currentYear}.csv`);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);

      toast.success('Reporte exportado correctamente');
    });
  }

  initPage();
  document.addEventListener('astro:page-load', initPage);
</script>
