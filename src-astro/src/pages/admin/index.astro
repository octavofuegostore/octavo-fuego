---
export const prerender = false;
// Dashboard page — Admin Panel home
import AdminLayout from '@/layouts/AdminLayout.astro';
import StatsCard from '@/components/admin/dashboard/StatsCard.astro';
import RecentOrders from '@/components/admin/dashboard/RecentOrders.astro';
import LowStock from '@/components/admin/dashboard/LowStock.astro';
import GraficaLíneas from '@/components/admin/contabilidad/GraficaLíneas.astro';
import GraficaTorta from '@/components/admin/charts/GraficaTorta.astro';
import GraficaBarrasH from '@/components/admin/charts/GraficaBarrasH.astro';
import { crearServicios } from '@/lib/admin/provider';
import { formatCurrency } from '@/lib/formatCurrency';
import { getBodegaSeleccionada } from '@/lib/admin/bodega';
import {
  computeOrdenesPorEstado,
  computeTendenciaIngresos,
  computeTopProductos,
} from '@/lib/admin/dashboard/chart-data';

// Compute real stats from service layer (falls back to mock when no Supabase)
const bodegaId = getBodegaSeleccionada(Astro.cookies);
const svc = crearServicios(bodegaId);
let ordenes = [], clientes = [], productos = [];
try {
  const results = await Promise.all([
    svc.ordenes.listar(),
    svc.clientes.listar(),
    svc.productos.listar(),
  ]);
  ordenes = results[0] ?? [];
  clientes = results[1] ?? [];
  productos = results[2] ?? [];
} catch {
  // One or more services failed — render dashboard with empty data
  ordenes = [];
  clientes = [];
  productos = [];
}

// Stats
const ventasHoy = ordenes
  .filter(o => o.status !== 'cancelada')
  .reduce((sum, o) => sum + o.total, 0);

const ordenesActivas = ordenes.filter(
  o => o.status === 'pendiente' || o.status === 'confirmada'
).length;

const totalProductos = productos.filter(p => p.status !== 'inactivo').length;
const totalClientesActivos = clientes.filter(c => c.status === 'activo').length;

// Chart data (computed from real ordenes per period)
const defaultPeriod = 'mes';
const periods = ['mes', 'trimestre', 'ano'] as const
const ordersData = computeOrdenesPorEstado(ordenes, defaultPeriod)
const revenueData = computeTendenciaIngresos(ordenes, defaultPeriod)
const productsData = computeTopProductos(ordenes, defaultPeriod)

// Pre-compute all periods for the period selector
const allPeriodsData = {
  mes: {
    revenue: computeTendenciaIngresos(ordenes, 'mes'),
    orders: computeOrdenesPorEstado(ordenes, 'mes'),
    products: computeTopProductos(ordenes, 'mes'),
  },
  trimestre: {
    revenue: computeTendenciaIngresos(ordenes, 'trimestre'),
    orders: computeOrdenesPorEstado(ordenes, 'trimestre'),
    products: computeTopProductos(ordenes, 'trimestre'),
  },
  ano: {
    revenue: computeTendenciaIngresos(ordenes, 'ano'),
    orders: computeOrdenesPorEstado(ordenes, 'ano'),
    products: computeTopProductos(ordenes, 'ano'),
  },
}
---

<AdminLayout title="Dashboard" description="Panel de administración de Octavo Fuego">
  <!-- Content State (visible immediately — no artificial loading) -->
  <div id="dashboard-content">
    <!-- Page Header -->
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-display font-bold text-humo">Dashboard</h1>
        <p class="text-ceniza mt-1">Resumen de tu negocio</p>
      </div>
      <!-- Period Selector -->
      <div class="flex items-center gap-2">
        <label for="period-selector" class="text-sm text-ceniza">Periodo:</label>
        <select
          id="period-selector"
          class="px-3 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco bg-white"
        >
          <option value="mes">Mes</option>
          <option value="trimestre">Trimestre</option>
          <option value="ano">Año</option>
        </select>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="mb-8 space-y-6">
      <!-- Top Row: Line Chart + Donut Chart -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {(['mes', 'trimestre', 'ano'] as const).map((period) => (
          <div
            id={`chart-revenue-${period}`}
            data-chart="revenue"
            data-period={period}
            class={period !== defaultPeriod ? 'hidden' : ''}
          >
            <GraficaLíneas
              data={allPeriodsData[period].revenue}
              title={`Tendencia de Ingresos (${period === 'mes' ? 'Mes' : period === 'trimestre' ? 'Trimestre' : 'Año'})`}
              height={220}
              color="#8B4513"
              fillColor="rgba(139,69,51,0.1)"
            />
          </div>
        ))}

        {(['mes', 'trimestre', 'ano'] as const).map((period) => (
          <div
            id={`chart-orders-${period}`}
            data-chart="orders"
            data-period={period}
            class={period !== defaultPeriod ? 'hidden' : ''}
          >
            <GraficaTorta
              data={allPeriodsData[period].orders}
              title={`Órdenes por Estado (${period === 'mes' ? 'Mes' : period === 'trimestre' ? 'Trimestre' : 'Año'})`}
              size={280}
            />
          </div>
        ))}
      </div>

      <!-- Bottom Row: Top Products -->
      {(['mes', 'trimestre', 'ano'] as const).map((period) => (
        <div
          id={`chart-products-${period}`}
          data-chart="products"
          data-period={period}
          class={period !== defaultPeriod ? 'hidden' : ''}
        >
          <GraficaBarrasH
            data={allPeriodsData[period].products}
            title={`Top 5 Productos (${period === 'mes' ? 'Mes' : period === 'trimestre' ? 'Trimestre' : 'Año'})`}
            barHeight={32}
            barGap={10}
          />
        </div>
      ))}
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <StatsCard
        title="Ventas Hoy"
        value={formatCurrency(ventasHoy, 'COP')}
        change={12.5}
        trend="up"
        icon='<svg class="w-6 h-6 text-tabacco" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>'
      />

      <StatsCard
        title="Órdenes Activas"
        value={String(ordenesActivas)}
        change={8.3}
        trend="up"
        icon='<svg class="w-6 h-6 text-tabacco" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>'
      />

      <StatsCard
        title="Productos"
        value={String(totalProductos)}
        change={4}
        trend="up"
        icon='<svg class="w-6 h-6 text-tabacco" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>'
      />

      <StatsCard
        title="Clientes"
        value={String(totalClientesActivos)}
        change={15}
        trend="up"
        icon='<svg class="w-6 h-6 text-tabacco" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>'
      />
    </div>

    <!-- Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2">
        <RecentOrders ordenes={ordenes} />
      </div>
      <div>
        <LowStock productos={productos} />
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="mt-8">
      <h2 class="text-lg font-display font-bold text-humo mb-4">Acciones Rápidas</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/admin/inventario" class="flex items-center gap-3 p-4 bg-white rounded-xl shadow-card hover:shadow-hover transition-all duration-300 group">
          <div class="w-10 h-10 bg-tabacco/10 rounded-lg flex items-center justify-center group-hover:bg-tabacco group-hover:text-white transition-colors">
            <svg class="w-5 h-5 text-tabacco group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <div>
            <p class="font-medium text-humo">Inventario</p>
            <p class="text-xs text-ceniza">Gestionar productos</p>
          </div>
        </a>

        <a href="/admin/ordenes" class="flex items-center gap-3 p-4 bg-white rounded-xl shadow-card hover:shadow-hover transition-all duration-300 group">
          <div class="w-10 h-10 bg-tabacco/10 rounded-lg flex items-center justify-center group-hover:bg-tabacco group-hover:text-white transition-colors">
            <svg class="w-5 h-5 text-tabacco group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
          </div>
          <div>
            <p class="font-medium text-humo">Órdenes</p>
            <p class="text-xs text-ceniza">Ver pedidos</p>
          </div>
        </a>

        <a href="/admin/clientes" class="flex items-center gap-3 p-4 bg-white rounded-xl shadow-card hover:shadow-hover transition-all duration-300 group">
          <div class="w-10 h-10 bg-tabacco/10 rounded-lg flex items-center justify-center group-hover:bg-tabacco group-hover:text-white transition-colors">
            <svg class="w-5 h-5 text-tabacco group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <div>
            <p class="font-medium text-humo">Clientes</p>
            <p class="text-xs text-ceniza">Ver clientes</p>
          </div>
        </a>

        <a href="/admin/configuracion" class="flex items-center gap-3 p-4 bg-white rounded-xl shadow-card hover:shadow-hover transition-all duration-300 group">
          <div class="w-10 h-10 bg-tabacco/10 rounded-lg flex items-center justify-center group-hover:bg-tabacco group-hover:text-white transition-colors">
            <svg class="w-5 h-5 text-tabacco group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <p class="font-medium text-humo">Configuración</p>
            <p class="text-xs text-ceniza">Ajustes del sistema</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // Count-up animation for stats
  function animateCountUp(el: HTMLElement, target: number, duration: number = 800) {
      const start = 0;
      const startTime = performance.now();

      function update(currentTime: number) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.floor(start + (target - start) * eased);
        el.textContent = formatValue(current);
        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          el.textContent = formatValue(target);
        }
      }
      requestAnimationFrame(update);
    }

    function formatValue(num: number): string {
      if (num >= 1000000) return '$' + (num / 1000000).toFixed(1) + 'M';
      if (num >= 1000) return '$' + (num / 1000).toFixed(0) + 'K';
      return String(num);
    }

    document.querySelectorAll('[data-count-value]').forEach((el) => {
      const target = parseInt(el.getAttribute('data-count-value') || '0', 10);
      if (target > 0) {
        animateCountUp(el as HTMLElement, target);
      }
    });

  // Period selector
  const periodSelector = document.getElementById('period-selector') as HTMLSelectElement;
  periodSelector?.addEventListener('change', () => {
    const selectedPeriod = periodSelector.value;
    document.querySelectorAll('[id^="chart-"]').forEach((section) => {
      const chartPeriod = section.getAttribute('data-period');
      if (chartPeriod === selectedPeriod) {
        section.classList.remove('hidden');
      } else {
        section.classList.add('hidden');
      }
    });
  });
</script>
