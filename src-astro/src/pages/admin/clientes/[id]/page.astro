---
export const prerender = false;
// Cliente detail page — [id]
import AdminLayout from '@/layouts/AdminLayout.astro';
import CustomerDetail from '@/components/admin/customers/CustomerDetail.astro';

const { id } = Astro.params;
---

<AdminLayout title={`Cliente ${id}`} description="Detalle del cliente">
  <!-- Back button -->
  <div class="mb-6">
    <a
      href="/admin/clientes"
      class="inline-flex items-center gap-2 text-sm text-ceniza hover:text-humo transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a Clientes
    </a>
  </div>

  <!-- Customer Detail Component -->
  <CustomerDetail customerId={id || ''} />
</AdminLayout>
