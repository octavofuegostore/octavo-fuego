---
export const prerender = false;
// B2B Solicitud Detail — approve/reject with notes
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getSolicitudById } from '@/lib/admin/service';

const { id } = Astro.params;
const solicitud = id ? await getSolicitudById(id) : undefined;

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('es-CO', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}

function estadoBadge(estado: string): { bg: string; text: string; label: string } {
  switch (estado) {
    case 'pendiente':
      return { bg: 'bg-amber-100', text: 'text-amber-800', label: 'Pendiente' };
    case 'aprobada':
      return { bg: 'bg-emerald-100', text: 'text-emerald-800', label: 'Aprobada' };
    case 'rechazada':
      return { bg: 'bg-red-100', text: 'text-red-800', label: 'Rechazada' };
    default:
      return { bg: 'bg-gray-100', text: 'text-gray-800', label: estado };
  }
}
---

<AdminLayout title={solicitud ? `Solicitud — ${solicitud.nombre_empresa}` : 'Solicitud no encontrada'} description="Detalle de solicitud B2B">
  <!-- Back button -->
  <div class="mb-6">
    <a
      href="/admin/clientes/b2b"
      class="inline-flex items-center gap-2 text-sm text-ceniza hover:text-humo transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a Solicitudes B2B
    </a>
  </div>

  {!solicitud ? (
    <!-- 404 State -->
    <div class="bg-white rounded-2xl shadow-card p-12 text-center">
      <svg class="w-16 h-16 mx-auto text-ceniza/40 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h2 class="text-xl font-display font-bold text-humo mb-2">Solicitud no encontrada</h2>
      <p class="text-ceniza text-sm mb-6">La solicitud que buscas no existe o fue eliminada.</p>
      <a
        href="/admin/clientes/b2b"
        class="inline-flex items-center gap-2 px-4 py-2 bg-tabacco text-white rounded-lg text-sm font-medium hover:bg-tabacco/90 transition-colors"
      >
        Ver solicitudes
      </a>
    </div>
  ) : (
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Main Info -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Empresa Card -->
        <div class="bg-white rounded-2xl shadow-card p-6">
          <div class="flex items-start justify-between mb-6">
            <div>
              <h2 class="text-xl font-display font-bold text-humo">{solicitud.nombre_empresa}</h2>
              <p class="text-ceniza text-sm mt-1">Contacto: {solicitud.nombre_contacto}</p>
            </div>
            {(() => {
              const badge = estadoBadge(solicitud.estado);
              return (
                <span class:list={['inline-flex items-center px-3 py-1 rounded-full text-sm font-medium', badge.bg, badge.text]}>
                  {badge.label}
                </span>
              );
            })()}
          </div>

          <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <dt class="text-xs font-medium text-ceniza uppercase tracking-wider mb-1">Email</dt>
              <dd class="text-sm text-humo">{solicitud.email}</dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-ceniza uppercase tracking-wider mb-1">Teléfono</dt>
              <dd class="text-sm text-humo">{solicitud.telefono || '—'}</dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-ceniza uppercase tracking-wider mb-1">Tax ID (NIT/CNPJ)</dt>
              <dd class="text-sm text-humo">{solicitud.tax_id || '—'}</dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-ceniza uppercase tracking-wider mb-1">Bodega</dt>
              <dd class="text-sm text-humo">{solicitud.bodega_nombre || solicitud.bodega_id}</dd>
            </div>
          </dl>
        </div>

        <!-- Notas -->
        {solicitud.notas && (
          <div class="bg-white rounded-2xl shadow-card p-6">
            <h3 class="text-sm font-medium text-ceniza uppercase tracking-wider mb-3">Notas del cliente</h3>
            <p class="text-sm text-humo leading-relaxed">{solicitud.notas}</p>
          </div>
        )}

        <!-- Review Info (if reviewed) -->
        {solicitud.estado !== 'pendiente' && solicitud.revisado_en && (
          <div class="bg-white rounded-2xl shadow-card p-6">
            <h3 class="text-sm font-medium text-ceniza uppercase tracking-wider mb-3">Revisión</h3>
            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <dt class="text-xs font-medium text-ceniza uppercase tracking-wider mb-1">Revisado por</dt>
                <dd class="text-sm text-humo">{solicitud.revisado_por || '—'}</dd>
              </div>
              <div>
                <dt class="text-xs font-medium text-ceniza uppercase tracking-wider mb-1">Fecha de revisión</dt>
                <dd class="text-sm text-humo">{formatDate(solicitud.revisado_en)}</dd>
              </div>
            </dl>
            {solicitud.revision_notas && (
              <div class="mt-4">
                <dt class="text-xs font-medium text-ceniza uppercase tracking-wider mb-1">Notas de revisión</dt>
                <dd class="text-sm text-humo mt-1 p-3 bg-papel rounded-xl">{solicitud.revision_notas}</dd>
              </div>
            )}
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Dates -->
        <div class="bg-white rounded-2xl shadow-card p-6">
          <h3 class="text-sm font-medium text-ceniza uppercase tracking-wider mb-3">Fechas</h3>
          <dl class="space-y-3">
            <div>
              <dt class="text-xs text-ceniza">Creada</dt>
              <dd class="text-sm text-humo">{formatDate(solicitud.creado_en)}</dd>
            </div>
            {solicitud.revisado_en && (
              <div>
                <dt class="text-xs text-ceniza">Revisada</dt>
                <dd class="text-sm text-humo">{formatDate(solicitud.revisado_en)}</dd>
              </div>
            )}
          </dl>
        </div>

        <!-- Actions (only for pendiente) -->
        {solicitud.estado === 'pendiente' && (
          <div class="bg-white rounded-2xl shadow-card p-6">
            <h3 class="text-sm font-medium text-ceniza uppercase tracking-wider mb-4">Acciones</h3>
            <div class="space-y-3">
              <textarea
                id="detail-notas"
                rows="3"
                placeholder="Notas de revisión (opcional)..."
                class="w-full px-3 py-2 border border-papel rounded-xl text-sm text-humo placeholder:text-ceniza/60 focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco resize-none"
              ></textarea>
              <button
                id="detail-approve"
                class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-emerald-600 text-white rounded-lg text-sm font-medium hover:bg-emerald-700 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Aprobar Solicitud
              </button>
              <button
                id="detail-reject"
                class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-red-600 text-white rounded-lg text-sm font-medium hover:bg-red-700 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Rechazar Solicitud
              </button>
            </div>
          </div>
        )}

        <!-- Status badge for non-pendiente -->
        {solicitud.estado !== 'pendiente' && (
          <div class="bg-white rounded-2xl shadow-card p-6 text-center">
            {(() => {
              const badge = estadoBadge(solicitud.estado);
              return (
                <div>
                  <span class:list={['inline-flex items-center px-4 py-2 rounded-full text-sm font-medium', badge.bg, badge.text]}>
                    {badge.label}
                  </span>
                  <p class="text-xs text-ceniza mt-3">Esta solicitud ya fue procesada</p>
                </div>
              );
            })()}
          </div>
        )}
      </div>
    </div>
  )}
</AdminLayout>

<script define:vars={{ solicitudId: solicitud?.id }}>
  // ─── Detail page approve/reject ─────────────────────────────────────────
  const notasInput = document.getElementById('detail-notas');
  const approveBtn = document.getElementById('detail-approve');
  const rejectBtn = document.getElementById('detail-reject');

  async function handleSubmit(action) {
    if (!solicitudId) return;

    const notas = notasInput?.value?.trim() || undefined;
    const endpoint = action === 'approve' ? '/api/admin/b2b/approve' : '/api/admin/b2b/reject';

    const btn = action === 'approve' ? approveBtn : rejectBtn;
    if (btn) {
      btn.textContent = 'Procesando...';
      (btn).disabled = true;
    }

    try {
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: solicitudId, notas }),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const data = await res.json();
        alert(`Error: ${data.error || 'No se pudo procesar'}`);
      }
    } catch {
      alert('Error de conexión');
    } finally {
      if (btn) {
        btn.textContent = action === 'approve' ? 'Aprobar Solicitud' : 'Rechazar Solicitud';
        (btn).disabled = false;
      }
    }
  }

  approveBtn?.addEventListener('click', () => handleSubmit('approve'));
  rejectBtn?.addEventListener('click', () => handleSubmit('reject'));
</script>
