---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n';
import { Shield, Leaf, Droplets } from 'lucide-react';

const t = useTranslations('es');
---

<Layout title="Octavo Fuego" locale="es">
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-12 py-24 grid lg:grid-cols-2 gap-16 items-center">
      <!-- Hero Content -->
      <div>
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold mb-6 tracking-tight text-[var(--near-black)] leading-tight">
          {t.home.hero.title}
        </h1>
        
        <p class="text-[var(--ceniza)] text-lg md:text-xl tracking-wide mb-12 max-w-lg">
          {t.home.hero.subtitle}
        </p>
        
        <a 
          href="#productos"
          class="inline-block bg-[var(--near-black)] text-white px-8 py-4 text-lg font-medium tracking-wide hover:bg-[var(--verde-botanico)] transition-colors rounded-[var(--radius-button)]"
        >
          {t.home.hero.cta} →
        </a>
      </div>
      
      <!-- Hero Image -->
      <div class="relative">
        <div class="aspect-square bg-[var(--papel)] rounded-[var(--radius-card)] overflow-hidden shadow-[var(--shadow-card)]">
          <img 
            src="/images/productos/rape/bobinsana-rape-2.webp" 
            alt="Rapé do Acre"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce">
      <span class="text-[var(--ceniza)] text-sm">↓</span>
    </div>
  </section>

  <!-- Trust Badges -->
  <section class="py-16 bg-[var(--papel)] border-y border-gray-100">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Autenticidad -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-white shadow-[var(--shadow-card)] mb-4">
            <Shield class="w-7 h-7 text-[var(--verde-botanico)]" />
          </div>
          <h3 class="text-lg font-display font-semibold mb-2 text-[var(--near-black)]">{t.home.trust.autenticidad}</h3>
          <p class="text-[var(--ceniza)] text-sm">{t.home.trust.autenticidadDesc}</p>
        </div>
        
        <!-- Origen Verdeado -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-white shadow-[var(--shadow-card)] mb-4">
            <Leaf class="w-7 h-7 text-[var(--verde-botanico)]" />
          </div>
          <h3 class="text-lg font-display font-semibold mb-2 text-[var(--near-black)]">{t.home.trust.origen}</h3>
          <p class="text-[var(--ceniza)] text-sm">{t.home.trust.origenDesc}</p>
        </div>
        
        <!-- Pureza Ritual -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-white shadow-[var(--shadow-card)] mb-4">
            <Droplets class="w-7 h-7 text-[var(--verde-botanico)]" />
          </div>
          <h3 class="text-lg font-display font-semibold mb-2 text-[var(--near-black)]">{t.home.trust.pureza}</h3>
          <p class="text-[var(--ceniza)] text-sm">{t.home.trust.purezaDesc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Productos Section -->
  <section id="productos" class="py-24 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4 text-[var(--near-black)]">{t.home.productos.title}</h2>
        <p class="text-[var(--ceniza)] tracking-widest uppercase">{t.home.productos.subtitle}</p>
      </div>
      
      <!-- Product Grid (placeholder) -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[1, 2, 3].map((i) => (
          <div class="bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-hover)] hover:-translate-y-1 transition-all duration-200 group">
            <div class="aspect-square bg-gray-50 rounded-t-[var(--radius-card)] flex items-center justify-center">
              <Leaf class="w-16 h-16 text-gray-200" />
            </div>
            <div class="p-6">
              <p class="text-[var(--ceniza)] text-sm uppercase tracking-wider mb-2">Etnia</p>
              <h3 class="font-display text-xl font-semibold mb-2 text-[var(--near-black)]">Producto {i}</h3>
              <p class="text-[var(--ceniza)] text-sm mb-4">Descripción breve del producto</p>
              <div class="flex items-center justify-between">
                <span class="text-[var(--verde-botanico)] font-semibold">$75.000 COP</span>
                <a href="#" class="text-sm text-[var(--ceniza)] group-hover:text-[var(--verde-botanico)] transition-colors">
                  {t.home.productos.verProducto} →
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <div class="text-center mt-12">
        <a href="/tienda" class="inline-block border border-[var(--verde-botanico)] text-[var(--verde-botanico)] px-8 py-4 hover:bg-[var(--verde-botanico)] hover:text-white transition-colors rounded-[var(--radius-button)]">
          {t.home.productos.verTodos}
        </a>
      </div>
    </div>
  </section>

  <!-- Quiz Section -->
  <section class="py-24 bg-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-display text-4xl md:text-5xl font-bold mb-4 text-[var(--near-black)]">{t.home.quiz.title}</h2>
      <p class="text-[var(--ceniza)] mb-12">{t.home.quiz.subtitle}</p>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <button class="border border-gray-200 p-8 hover:border-[var(--verde-botanico)] hover:bg-[var(--papel)] transition-all group rounded-[var(--radius-card)] shadow-[var(--shadow-card)]">
          <span class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-full bg-[var(--papel)]">
            <Leaf class="w-6 h-6 text-[var(--verde-botanico)]" />
          </span>
          <span class="text-sm text-[var(--ceniza)]">{t.home.quiz.claridad}</span>
        </button>
        <button class="border border-gray-200 p-8 hover:border-[var(--verde-botanico)] hover:bg-[var(--papel)] transition-all group rounded-[var(--radius-card)] shadow-[var(--shadow-card)]">
          <span class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-full bg-[var(--papel)]">
            <svg class="w-6 h-6 text-[var(--verde-botanico)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" />
            </svg>
          </span>
          <span class="text-sm text-[var(--ceniza)]">{t.home.quiz.energia}</span>
        </button>
        <button class="border border-gray-200 p-8 hover:border-[var(--verde-botanico)] hover:bg-[var(--papel)] transition-all group rounded-[var(--radius-card)] shadow-[var(--shadow-card)]">
          <span class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-full bg-[var(--papel)]">
            <svg class="w-6 h-6 text-[var(--verde-botanico)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </span>
          <span class="text-sm text-[var(--ceniza)]">{t.home.quiz.limpieza}</span>
        </button>
        <button class="border border-gray-200 p-8 hover:border-[var(--verde-botanico)] hover:bg-[var(--papel)] transition-all group rounded-[var(--radius-card)] shadow-[var(--shadow-card)]">
          <span class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-full bg-[var(--papel)]">
            <Droplets class="w-6 h-6 text-[var(--verde-botanico)]" />
          </span>
          <span class="text-sm text-[var(--ceniza)]">{t.home.quiz.relajacion}</span>
        </button>
      </div>
    </div>
  </section>
</Layout>
