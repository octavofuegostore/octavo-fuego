---
/**
 * Informational page — /que-es-el-rape, /en/que-es-el-rape, /pt/que-es-el-rape
 * Article schema. Explains what rapé is.
 */
import Layout from '@/layouts/Layout.astro';
import { useTranslations, type Locale } from '@/i18n';

export const prerender = false;

const locale_ = (Astro.currentLocale || 'es') as Locale;
const t = useTranslations(locale_);
const baseUrl = locale_ === 'es' ? '' : `/${locale_}`;

const content = {
  es: {
    title: '¿Qué es el Rapé?',
    description: 'Descubre qué es el rapé, su origen amazónico, sus variedades y su uso en la medicina ancestral.',
    sections: {
      origen: 'Origen del Rapé',
      medicinal: 'El Rapé en la Medicina Ancestral',
      tipos: 'Tipos de Rapé',
      uso: '¿Para qué sirve el Rapé?',
    },
    cta: 'Explora nuestra tienda',
  },
  en: {
    title: 'What is Rapé?',
    description: 'Learn what rapé is, its Amazonian origin, varieties, and use in ancestral medicine.',
    sections: {
      origen: 'Origin of Rapé',
      medicinal: 'Rapé in Ancestral Medicine',
      tipos: 'Types of Rapé',
      uso: 'What is Rapé Used For?',
    },
    cta: 'Explore our store',
  },
  pt: {
    title: 'O que é o Rapé?',
    description: 'Descubra o que é o rapé, sua origem amazônica, variedades e uso na medicina ancestral.',
    sections: {
      origen: 'Origem do Rapé',
      medicinal: 'O Rapé na Medicina Ancestral',
      tipos: 'Tipos de Rapé',
      uso: 'Para que serve o Rapé?',
    },
    cta: 'Explore nossa loja',
  },
};

const c = content[locale_];
const canonicalUrl = `https://octavofuego.com${baseUrl}/que-es-el-rape`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${canonicalUrl}#article`,
  url: canonicalUrl,
  headline: c.title,
  description: c.description,
  datePublished: '2026-07-01',
  dateModified: '2026-07-01',
  author: {
    '@type': 'Organization',
    '@id': 'https://octavofuego.com/#organization',
    name: 'Octavo Fuego',
  },
  publisher: {
    '@type': 'Organization',
    '@id': 'https://octavofuego.com/#organization',
    name: 'Octavo Fuego',
    logo: {
      '@type': 'ImageObject',
      url: 'https://octavofuego.com/images/octavofuego-logo.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
};
---

<Layout title={c.title} description={c.description} locale={locale_} ogImage="/images/og-default.svg">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />

  <div class="max-w-3xl mx-auto px-6 py-16 md:py-24">
    <h1 class="font-display heading-xl font-bold text-[var(--near-black)] mb-6">
      {c.title}
    </h1>

    <!-- Origen -->
    <section class="mb-16" id="origen">
      <h2 class="font-display heading-lg font-bold text-[var(--near-black)] mb-4">{c.sections.origen}</h2>
      <p class="text-[var(--ceniza)] leading-relaxed mb-4">
        El rapé es una medicina ancestral elaborada a partir de tabaco molido y cenizas específicas de árboles amazónicos. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Su uso se remonta a cientos de años entre pueblos indígenas de la Amazonía.
      </p>
      <p class="text-[var(--ceniza)] leading-relaxed">
        Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
      </p>
    </section>

    <!-- Medicina Ancestral -->
    <section class="mb-16" id="medicina-ancestral">
      <h2 class="font-display heading-lg font-bold text-[var(--near-black)] mb-4">{c.sections.medicinal}</h2>
      <p class="text-[var(--ceniza)] leading-relaxed mb-4">
        En las tradiciones amazónicas, el rapé se utiliza como herramienta de claridad, limpieza energética y conexión espiritual. Lorem ipsum dolor sit amet, consectetur adipiscing elit.
      </p>
      <p class="text-[var(--ceniza)] leading-relaxed">
        Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident.
      </p>
    </section>

    <!-- Tipos -->
    <section class="mb-16" id="tipos">
      <h2 class="font-display heading-lg font-bold text-[var(--near-black)] mb-4">{c.sections.tipos}</h2>
      <p class="text-[var(--ceniza)] leading-relaxed mb-4">
        En Octavo Fuego ofrecemos cinco variedades de rapé do Acre: Tisunú, Pixurí, Pariká, Cumarú de Cheiro y Vena de Pajé. Cada una tiene su propia alquimia, aroma y orientación ceremonial.
      </p>
      <p class="text-[var(--ceniza)] leading-relaxed">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
      </p>
    </section>

    <!-- Uso -->
    <section class="mb-16" id="para-que-sirve">
      <h2 class="font-display heading-lg font-bold text-[var(--near-black)] mb-4">{c.sections.uso}</h2>
      <p class="text-[var(--ceniza)] leading-relaxed mb-4">
        El rapé sirve para enfocar la mente, limpiar vías respiratorias, equilibrar energías y acompañar prácticas de meditación. Lorem ipsum dolor sit amet, consectetur adipiscing elit.
      </p>
      <p class="text-[var(--ceniza)] leading-relaxed">
        Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
      </p>
    </section>

    <!-- CTA -->
    <section class="text-center py-12 border-t border-[var(--color-border-subtle)]">
      <a href={`${baseUrl}/tienda`} class="inline-block bg-[var(--color-action-primary)] text-white px-8 py-4 rounded-[var(--radius-button)] font-medium hover:bg-[var(--color-action-hover)] transition-colors">
        {c.cta} →
      </a>
    </section>
  </div>
</Layout>
