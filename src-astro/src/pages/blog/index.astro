---
import Layout from '@/layouts/Layout.astro';
import { Badge } from '@/components/ui/badge';

const t = await import('@/i18n/es.json').then(m => m.default);

const allPosts = [
  {
    slug: 'guia-rape-principiantes',
    title: 'Guía Completa del Rapé para Principiantes',
    excerpt: 'Descubre los fundamentos del Rapé, su uso ceremonial y cómo incorporar esta medicina ancestral en tu práctica espiritual de manera respetuosa.',
    publishedAt: '2026-03-15',
    author: 'Octavo Fuego',
    coverImage: '/images/productos/rape/bobinsana-rape-2.webp',
    category: 'ancestral',
  },
  {
    slug: 'historia-sananga',
    title: 'La Historia milenaria de la Sananga',
    excerpt: 'Conoce el origen de las gotas Sananga, su preparación tradicional por las tribus amazónicas y sus beneficios para la visión física y espiritual.',
    publishedAt: '2026-03-10',
    author: 'Octavo Fuego',
    coverImage: '/images/productos/rape/bobinsana-rape-2.webp',
    category: 'cultura',
  },
  {
    slug: 'ceremonia-rape-amazonia',
    title: 'Cómo preparar una Ceremonia de Rapé',
    excerpt: 'Pasos fundamentales para organizar una ceremonia de Rapé con respeto, intención y siguiendo las tradiciones amazónicas.',
    publishedAt: '2026-03-05',
    author: 'Octavo Fuego',
    coverImage: '/images/productos/rape/bobinsana-rape-2.webp',
    category: 'ancestral',
  },
  {
    slug: 'beneficios-spiritus',
    title: 'Beneficios Espirituales del Rapé',
    excerpt: 'Explora cómo el Rapé puede ayudarte a limpiar energías negativas, mejorar tu meditación y conectar con tus ancestros.',
    publishedAt: '2026-02-28',
    author: 'Octavo Fuego',
    coverImage: '/images/productos/rape/bobinsana-rape-2.webp',
    category: 'salud',
  },
];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('es-CO', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

function getCategoryLabel(category: string) {
  const labels: Record<string, string> = {
    ancestral: 'Ancestral',
    cultura: 'Cultura',
    salud: 'Salud',
  };
  return labels[category] || category;
}
---

<Layout title="Blog" description="Artículos sobre Rapé, Sananga y Kuripes. Medicina ancestral amazónica, ceremonias y tradiciones.">
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">
          Blog
        </h1>
        <p class="text-ceniza text-lg max-w-2xl mx-auto">
          Artículos sobre medicina ancestral amazónica, ceremonias, tradiciones y bienestar espiritual.
        </p>
      </div>

      <!-- Featured Post -->
      {allPosts[0] && (
        <a href={`/blog/${allPosts[0].slug}`} class="block mb-12 group">
          <article class="grid grid-cols-1 md:grid-cols-2 gap-8 bg-humo/20 border border-humo hover:border-tabacco transition-colors">
            <div class="aspect-video md:aspect-auto overflow-hidden">
              <img 
                src={allPosts[0].coverImage} 
                alt={allPosts[0].title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-8 flex flex-col justify-center">
              <Badge variant="secondary" className="w-fit mb-4">
                {getCategoryLabel(allPosts[0].category)}
              </Badge>
              <h2 class="font-display text-2xl md:text-3xl font-bold mb-4 group-hover:text-tabacco transition-colors">
                {allPosts[0].title}
              </h2>
              <p class="text-ceniza mb-4 line-clamp-3">
                {allPosts[0].excerpt}
              </p>
              <p class="text-sm text-ceniza/70">
                {formatDate(allPosts[0].publishedAt)}
              </p>
            </div>
          </article>
        </a>
      )}

      <!-- Post Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {allPosts.slice(1).map((post) => (
          <a href={`/blog/${post.slug}`} class="group">
            <article class="h-full bg-humo/20 border border-humo hover:border-tabacco transition-colors">
              <div class="aspect-video overflow-hidden">
                <img 
                  src={post.coverImage} 
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-6">
                <Badge variant="secondary" className="w-fit mb-3">
                  {getCategoryLabel(post.category)}
                </Badge>
                <h3 class="font-display text-xl font-bold mb-2 group-hover:text-tabacco transition-colors">
                  {post.title}
                </h3>
                <p class="text-ceniza text-sm mb-4 line-clamp-2">
                  {post.excerpt}
                </p>
                <p class="text-xs text-ceniza/70">
                  {formatDate(post.publishedAt)}
                </p>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
