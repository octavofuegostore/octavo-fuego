---
/**
 * Prophecy page — renders at /profecia, /en/profecia, /pt/profecia
 * Full prophecy rendering with all 7 fires, narrative interlude, and final question.
 *
 * @source ProfeciaOctavoFuego-ESPANOL (1).html
 */

import Layout from '@/layouts/Layout.astro';
import ProphecyContent from '@/components/prophecy/ProphecyContent.astro';
import { prophecy } from '@/data/prophecy';
import { useTranslations, type Locale } from '@/i18n';

export const prerender = false;

const locale_ = (Astro.currentLocale || 'es') as Locale;
const t = useTranslations(locale_);
---

<Layout
  title={t.profecia.title}
  description={t.profecia.description}
  locale={locale_}
>
  <ProphecyContent prophecy={prophecy} locale={locale_} />
</Layout>
