---
/**
 * Contact page — /contacto
 * Trust Foundation SEO page with ContactPage schema.
 */
import Layout from '@/layouts/Layout.astro';

const title = 'Contacto — Octavo Fuego';
const description = 'Escríbenos por WhatsApp, email o completa el formulario. Octavo Fuego atiende pedidos, preguntas y distribución institucional.';
const canonicalUrl = 'https://octavofuego.com/contacto';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': `${canonicalUrl}#contact`,
  url: canonicalUrl,
  name: title,
  description,
  mainEntity: {
    '@type': 'Organization',
    '@id': 'https://octavofuego.com/#organization',
    name: 'Octavo Fuego',
    url: 'https://octavofuego.com',
    contactPoint: [
      {
        '@type': 'ContactPoint',
        telephone: '+573172137932',
        contactType: 'customer service',
        contactOption: 'WhatsApp',
        availableLanguage: ['Spanish', 'English', 'Portuguese'],
      },
      {
        '@type': 'ContactPoint',
        email: 'hola@octavofuego.com',
        contactType: 'customer support',
        availableLanguage: ['Spanish', 'English', 'Portuguese'],
      },
    ],
  },
};
---

<Layout title={title} description={description} locale="es" ogImage="/images/og-default.svg">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(contactSchema)} />

  <div class="max-w-3xl mx-auto px-6 py-16 md:py-24">
    <h1 class="font-display heading-xl font-bold text-[var(--near-black)] mb-6">
      Contacto — Octavo Fuego
    </h1>

    <section class="mb-12">
      <!-- 🖊️ USUARIO: reemplazar este texto -->
      <p class="text-lg text-[var(--ceniza)] leading-relaxed">
        ¿Tienes dudas sobre nuestros productos, envíos o distribución? Escríbenos y te responderemos lo antes posible. Lorem ipsum dolor sit amet, consectetur adipiscing elit.
      </p>
    </section>

    <!-- Contact Methods -->
    <section class="mb-16" aria-labelledby="contact-methods">
      <h2 id="contact-methods" class="font-display heading-lg font-bold text-[var(--near-black)] mb-6">Medios de contacto</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="https://wa.me/573172137932" class="block p-6 border border-[var(--color-border-subtle)] rounded-[var(--radius-card)] hover:shadow-[var(--shadow-hover)] transition-shadow">
          <h3 class="font-display heading-md font-bold text-[var(--near-black)] mb-2">WhatsApp</h3>
          <p class="text-[var(--ceniza)]">+57 317 213 7932</p>
        </a>
        <div class="p-6 border border-[var(--color-border-subtle)] rounded-[var(--radius-card)]">
          <h3 class="font-display heading-md font-bold text-[var(--near-black)] mb-2">Email</h3>
          <p class="text-[var(--ceniza)]">hola@octavofuego.com</p>
        </div>
      </div>
    </section>

    <!-- Contact Form -->
    <section class="mb-16" aria-labelledby="contact-form">
      <h2 id="contact-form" class="font-display heading-lg font-bold text-[var(--near-black)] mb-6">Envíanos un mensaje</h2>
      <form class="space-y-6" action="#" method="POST">
        <!-- 🖊️ USUARIO: reemplazar este texto — conectar backend o servicio de formularios -->
        <div>
          <label for="nombre" class="block text-sm font-medium text-[var(--near-black)] mb-2">Nombre</label>
          <input type="text" id="nombre" name="nombre" required class="w-full px-4 py-3 border border-[var(--color-border-subtle)] rounded-[var(--radius-button)] bg-white text-[var(--near-black)] focus:outline-none focus:ring-2 focus:ring-[var(--color-action-primary)]" placeholder="Tu nombre" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-[var(--near-black)] mb-2">Email</label>
          <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-[var(--color-border-subtle)] rounded-[var(--radius-button)] bg-white text-[var(--near-black)] focus:outline-none focus:ring-2 focus:ring-[var(--color-action-primary)]" placeholder="tu@email.com" />
        </div>
        <div>
          <label for="mensaje" class="block text-sm font-medium text-[var(--near-black)] mb-2">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" required class="w-full px-4 py-3 border border-[var(--color-border-subtle)] rounded-[var(--radius-button)] bg-white text-[var(--near-black)] focus:outline-none focus:ring-2 focus:ring-[var(--color-action-primary)]" placeholder="¿En qué podemos ayudarte?"></textarea>
        </div>
        <button type="submit" class="inline-block bg-[var(--color-action-primary)] text-white px-8 py-4 rounded-[var(--radius-button)] font-medium hover:bg-[var(--color-action-hover)] transition-colors">
          Enviar mensaje
        </button>
      </form>
    </section>

    <!-- Horarios -->
    <section aria-labelledby="horarios">
      <h2 id="horarios" class="font-display heading-lg font-bold text-[var(--near-black)] mb-4">Horarios de Atención</h2>
      <!-- 🖊️ USUARIO: reemplazar este texto -->
      <p class="text-[var(--ceniza)] leading-relaxed mb-2">
        Atendemos de lunes a viernes de 9:00 a.m. a 6:00 p.m. (hora Colombia). Lorem ipsum dolor sit amet.
      </p>
      <p class="text-[var(--ceniza)] leading-relaxed">
        Los fines de semana y días festivos respondemos con menor frecuencia, pero siempre intentamos contestar en menos de 24 horas.
      </p>
    </section>
  </div>
</Layout>
