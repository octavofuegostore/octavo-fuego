    etnia: 'Kuntanawa',
    tipo: 'rape' as const,
    precio: 92000,
    imagen: '/images/productos/rape/bobinsana-rape-2.webp',
    slug: 'rape-acre-kuntanawa',
    descripcion: 'Rapé ceremonial Kuntanawa, preparado siguiendo tradiciones ancestrales.'
  },
  {
    id: 'sananga-1',
    variantId: 'sananga-1-10ml',
    nombre: 'Sananga - Kibiton',
    etnia: 'Katahiri',
    tipo: 'sananga' as const,
    precio: 65000,
    imagen: '/images/productos/rape/bobinsana-rape-2.webp',
