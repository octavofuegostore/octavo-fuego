    slug: 'kuripe-pulso',
    descripcion: 'Kuripe de pulso, diseñado para uso personal ceremonial.'
  },
];

const PRODUCTS_PER_PAGE = 8;
const totalProducts = productos.length;
const totalPages = Math.ceil(totalProducts / PRODUCTS_PER_PAGE);

const url = Astro.url;
const currentPage = parseInt(url.searchParams.get('page') || '1');
const currentFilter = url.searchParams.get('filter') || 'all';

const filteredProducts = currentFilter === 'all' 
  ? productos 
  : productos.filter(p => p.tipo === currentFilter);

const paginatedProducts = filteredProducts.slice(
  (currentPage - 1) * PRODUCTS_PER_PAGE,
  currentPage * PRODUCTS_PER_PAGE
);

const categorias = [
  { name: 'Todos', value: 'all', count: productos.length },
  { name: 'Rapé', value: 'rape', count: productos.filter(p => p.tipo === 'rape').length },
  { name: 'Sananga', value: 'sananga', count: productos.filter(p => p.tipo === 'sananga').length },
  { name: 'Kuripes', value: 'kuripe', count: productos.filter(p => p.tipo === 'kuripe').length },
  { name: 'Accesorios', value: 'accesorio', count: productos.filter(p => p.tipo === 'accesorio').length },
];

function getPageUrl(page: number, filter?: string) {
  const params = new URLSearchParams();
  params.set('page', page.toString());
  if (filter && filter !== 'all') params.set('filter', filter);
  return `/tienda?${params.toString()}`;
}

const filteredCount = currentFilter === 'all' ? productos.length : productos.filter(p => p.tipo === currentFilter).length;
const filteredTotalPages = Math.ceil(filteredCount / PRODUCTS_PER_PAGE);
---

<Layout title="Tienda" description="Explora nuestra colección de Rapé do Acre, Sananga y Kuripes. Medicinas ancestrales amazónicas.">
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="font-display text-4xl md:text-5xl font-bold mb-4 text-[var(--near-black)]">
          Nuestra Medicina
        </h1>
        <p class="text-[var(--ceniza)] text-lg max-w-2xl mx-auto">
          Rapé do Acre · Sananga · Kuripes
        </p>
      </div>

      <!-- Category Pills -->
      <div class="flex justify-center mb-12">
        <CategoryPills 
          categories={categorias} 
          currentFilter={currentFilter} 
          baseUrl="/tienda"
        />
      </div>

      <!-- Product Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {paginatedProducts.map((producto) => (
          <ProductCard
            nombre={producto.nombre}
            etnia={producto.etnia}
            precio={producto.precio}
            imagen={producto.imagen}
            slug={producto.slug}
            href={`/tienda/${producto.slug}`}
            className="product-card"
            data-tipo={producto.tipo}
          />
        ))}
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="hidden text-center py-16">
        <p class="text-[var(--ceniza)] text-lg mb-4">No hay productos en esta categoría</p>
        <a href="/tienda">
          <Button variant="secondary">Ver todos los productos</Button>
        </a>
      </div>

      <!-- Pagination -->
      {filteredTotalPages > 1 && (
        <div class="flex justify-center items-center gap-2 mt-12">
          {currentPage > 1 && (
            <a href={getPageUrl(currentPage - 1, currentFilter)} class="px-4 py-2 border border-gray-200 hover:border-[var(--verde-botanico)] transition-colors text-[var(--ceniza)] rounded-[var(--radius-button)]">
              ← Anterior
            </a>
          )}
          
          {Array.from({ length: filteredTotalPages }, (_, i) => i + 1).map((page) => (
            <a
              href={getPageUrl(page, currentFilter)}
              class:list={[
                "w-10 h-10 flex items-center justify-center border transition-colors rounded-[var(--radius-button)]",
                page === currentPage 
                  ? "bg-[var(--verde-botanico)] border-[var(--verde-botanico)] text-white" 
                  : "border-gray-200 hover:border-[var(--verde-botanico)] text-[var(--ceniza)]"
              ]}
            >
              {page}
            </a>
          ))}
          
          {currentPage < filteredTotalPages && (
            <a href={getPageUrl(currentPage + 1, currentFilter)} class="px-4 py-2 border border-gray-200 hover:border-[var(--verde-botanico)] transition-colors text-[var(--ceniza)] rounded-[var(--radius-button)]">
              Siguiente →
            </a>
          )}
        </div>
      )}

      <!-- Products Count -->
      <p class="text-center text-[var(--ceniza)] text-sm mt-8">
        Mostrando {Math.min((currentPage - 1) * PRODUCTS_PER_PAGE + 1, filteredCount)} - {Math.min(currentPage * PRODUCTS_PER_PAGE, filteredCount)} de {filteredCount} productos
      </p>
    </div>
  </section>
</Layout>