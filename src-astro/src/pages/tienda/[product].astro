---
import Layout from '@/layouts/Layout.astro';
import { AddToCartButton, QuantitySelector } from '@/components/cart/AddToCartButton';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { useTranslations } from '@/i18n';
import ProductJsonLd from '@/components/seo/ProductJsonLd.astro';
import BreadcrumbJsonLd from '@/components/seo/BreadcrumbJsonLd.astro';

const t = useTranslations('es');

export function getStaticPaths() {
  return [
    { params: { product: 'rape-acre-apewi-mapu' } },
    { params: { product: 'rape-acre-yawanawa' } },
    { params: { product: 'sananga-kibiton' } },
    { params: { product: 'sananga-apiaka' } },
    { params: { product: 'kuripe-tucum' } },
    { params: { product: 'kuripe-bambu' } },
  ];
}

const { product: slug } = Astro.params;

const productos: Record<string, any> = {
  'rape-acre-apewi-mapu': {
    id: 'rape-1',
    variantId: 'rape-1-25g',
    nombre: 'Rapé do Acre - Apéwi Mapu',
    etnia: 'Katahiri',
    tipo: 'rape',
    precio: 85000,
    imagen: '/images/productos/rape/bobinsana-rape-2.webp',
    imagenes: [
      '/images/productos/rape/bobinsana-rape-2.webp',
    ],
    slug: 'rape-acre-apewi-mapu',
    descripcion: 'Rapé ancestral preparado por los Katahiri del Acre, Brasil. Este Rapé ceremonial es conocido por sus propiedades purificadoras y energetizantes.',
    usoCeremonial: 'Uso ceremonial tradicional: aplica una pequeña cantidad en cada fosa nasal con la ayuda de un kuripe. Ideal para meditaciones y rituales de limpieza.',
    laEtnia: 'La comunidad Katahiri habita las profundidades de la selva amazónica en el estado de Acre, Brasil. Son guardianes de tradiciones ancestrales que han pasado de generación en generación.',
    stock: 15,
  },
  'rape-acre-yawanawa': {
    id: 'rape-2',
    variantId: 'rape-2-25g',
    nombre: 'Rapé do Acre - Yawanawa',
    etnia: 'Yawanawa',
    tipo: 'rape',
    precio: 95000,
    imagen: '/images/productos/rape/bobinsana-rape-2.webp',
    imagenes: [
      '/images/productos/rape/bobinsana-rape-2.webp',
    ],
    slug: 'rape-acre-yawanawa',
    descripcion: 'Rapé ceremonial Yawanawa, conocido por su potencia y profundidad. Preaparado según las tradiciones de esta respetada comunidad.',
    usoCeremonial: 'Para uso ceremonial: aplica con kuripe después de la preparación ritual. Potencia la conexión espiritual.',
    laEtnia: 'Los Yawanawa son una de las comunidades más reconocidas del Acre, conocidos por preservar sus tradiciones medicinales ancestrales.',
    stock: 8,
  },
  'sananga-kibiton': {
    id: 'sananga-1',
    variantId: 'sananga-1-10ml',
    nombre: 'Sananga - Kibiton',
    etnia: 'Katahiri',
    tipo: 'sananga',
    precio: 65000,
    imagen: '/images/productos/rape/bobinsana-rape-2.webp',
    imagenes: [
      '/images/productos/rape/bobinsana-rape-2.webp',
    ],
    slug: 'sananga-kibiton',
    descripcion: 'Gotas oftálmicas tradicionales preparadas con la raíz Tabernaemontana. Conocidas por limpiar la visión física y espiritual.',
    usoCeremonial: 'Aplicar 1-2 gotas en cada ojo durante ceremonias. Produce una sensación intensa pero temporal.',
    laEtnia: 'Preparado por los Katahiri siguiendo estrictos protocolos ancestrales.',
    stock: 20,
  },
  'sananga-apiaka': {
    id: 'sananga-2',
    variantId: 'sananga-2-10ml',
    nombre: 'Sananga - Apiaka',
    etnia: 'Apiaka',
    tipo: 'sananga',
    precio: 70000,
    imagen: '/images/productos/rape/bobinsana-rape-2.webp',
    imagenes: [
      '/images/productos/rape/bobinsana-rape-2.webp',
    ],
    slug: 'sananga-apiaka',
    descripcion: 'Sananga de la comunidad Apiaka, reconocida por su alta calidad y pureza.',
    usoCeremonial: '2-3 gotas por ojo. Usar en espacios ceremoniales seguros.',
    laEtnia: 'Los Apiaka son maestros en la preparación de medicines amazónicas.',
    stock: 12,
  },
  'kuripe-tucum': {
    id: 'kuripe-1',
    variantId: 'kuripe-1-tucum',
    nombre: 'Kuripe - Tucum',
    etnia: 'Traditional',
    tipo: 'kuripe',
    precio: 45000,
    imagen: '/images/productos/kuripes/Hauxhaux_Kuripe_001_B.jpg',
    imagenes: [
      '/images/productos/kuripes/Hauxhaux_Kuripe_001_B.jpg',
    ],
    slug: 'kuripe-tucum',
    descripcion: 'Kuripe artesanal tallado en madera de Tucum. Instrumento ceremonial para administrar Rapé.',
    usoCeremonial: 'Llena una punta con Rapé y sopla la otra punta hacia la fosa nasal.',
    laEtnia: 'Tallado por artesanos tradicionales.',
    stock: 25,
  },
  'kuripe-bambu': {
    id: 'kuripe-2',
    variantId: 'kuripe-2-bamboo',
    nombre: 'Kuripe - Bambú',
    etnia: 'Traditional',
    tipo: 'kuripe',
    precio: 35000,
    imagen: '/images/productos/kuripes/Hauxhaux_Kuripe_001_B.jpg',
    imagenes: [
      '/images/productos/kuripes/Hauxhaux_Kuripe_001_B.jpg',
    ],
    slug: 'kuripe-bambu',
    descripcion: 'Kuripe de bambú natural. Opción accesible y efectiva para uso ceremonial.',
    usoCeremonial: 'Soplado tradicional para administración de Rapé.',
    laEtnia: 'Producido sosteniblemente.',
    stock: 30,
  },
};

const producto = productos[slug || ''];

if (!producto) {
  return Astro.redirect('/404');
}

const formattedPrice = new Intl.NumberFormat('es-CO', {
  style: 'currency',
  currency: 'COP',
  minimumFractionDigits: 0,
}).format(producto.precio);

const breadcrumbs = [
  { name: 'Inicio', url: 'https://octavofuego.com/' },
  { name: 'Tienda', url: 'https://octavofuego.com/tienda' },
  { name: producto.nombre, url: `https://octavofuego.com/producto/${producto.slug}` }
];
---

<Layout title={producto.nombre} description={producto.descripcion} ogType="product">
  <!-- SEO JSON-LD -->
  <ProductJsonLd product={producto} />
  <BreadcrumbJsonLd items={breadcrumbs} />
  
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm">
        <ol class="flex items-center gap-2 text-gray-500">
          <li><a href="/" class="hover:text-tabacco transition-colors">Inicio</a></li>
          <li>/</li>
          <li><a href="/tienda" class="hover:text-tabacco transition-colors">Tienda</a></li>
          <li>/</li>
          <li class="text-black">{producto.nombre}</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Image Gallery - 60% -->
        <div class="lg:col-span-3 space-y-4">
          <div class="aspect-square bg-gray-50 border border-gray-200 overflow-hidden">
            <img
              id="main-image"
              src={producto.imagenes[0]}
              alt={producto.nombre}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          {producto.imagenes.length > 1 && (
            <div class="flex gap-3">
              {producto.imagenes.map((img: string, index: number) => (
                <button
                  class="thumb-btn w-20 h-20 border border-gray-200 hover:border-tabacco transition-colors overflow-hidden"
                  data-src={img}
                >
                  <img src={img} alt={`${producto.nombre} ${index + 1}`} class="w-full h-full object-cover" loading="lazy" decoding="async" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Product Info - 40% -->
        <div class="lg:col-span-2">
          <Badge variant="secondary" className="mb-4 bg-papel text-gray-700">
            {producto.etnia}
          </Badge>
          <h1 class="font-display text-3xl md:text-4xl font-bold mb-4 text-black">
            {producto.nombre}
          </h1>
          <p class="text-4xl font-display text-tabacco font-bold mb-6">
            {formattedPrice}
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            {producto.descripcion}
          </p>

          <!-- Quantity & Add to Cart -->
          <div class="flex flex-wrap items-center gap-6 mb-8">
            <QuantitySelector 
              client:load 
              value={1} 
              onChange={(value: number) => {}} 
            />
            <AddToCartButton 
              client:load 
              product={producto} 
              className="flex-1 min-w-[200px]"
            />
          </div>

          <!-- Trust Badges -->
          <div class="grid grid-cols-3 gap-4 py-6 border-t border-b border-gray-200">
            <div class="text-center">
              <span class="text-2xl">🔐</span>
              <p class="text-xs text-gray-500 mt-2">Origen Certificado</p>
            </div>
            <div class="text-center">
              <span class="text-2xl">🌿</span>
              <p class="text-xs text-gray-500 mt-2">Cultivo Sostenible</p>
            </div>
            <div class="text-center">
              <span class="text-2xl">💧</span>
              <p class="text-xs text-gray-500 mt-2">Empacado al Vacío</p>
            </div>
          </div>

          <!-- Tabs -->
          <div class="mt-8" id="product-tabs">
            <div class="flex border-b border-gray-200">
              <button class="tab-btn active px-6 py-3 text-sm font-medium border-b-2 border-tabacco text-black" data-tab="descripcion">
                Descripción
              </button>
              <button class="tab-btn px-6 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-black transition-colors" data-tab="uso">
                Uso Ceremonial
              </button>
              <button class="tab-btn px-6 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-black transition-colors" data-tab="etnia">
                La Etnia
              </button>
            </div>
            <div class="tab-content pt-4" data-content="descripcion">
              <p class="text-gray-600 leading-relaxed">{producto.descripcion}</p>
            </div>
            <div class="tab-content hidden pt-4" data-content="uso">
              <p class="text-gray-600 leading-relaxed">{producto.usoCeremonial}</p>
            </div>
            <div class="tab-content hidden pt-4" data-content="etnia">
              <p class="text-gray-600 leading-relaxed">{producto.laEtnia}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const thumbButtons = document.querySelectorAll('.thumb-btn');
  const mainImage = document.getElementById('main-image') as HTMLImageElement;

  thumbButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const src = btn.getAttribute('data-src');
      if (src && mainImage) {
        mainImage.src = src;
      }
    });
  });

  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tabId = btn.getAttribute('data-tab');
      
      tabBtns.forEach((b) => {
        b.classList.remove('active', 'border-tabacco', 'text-black');
        b.classList.add('border-transparent', 'text-gray-500');
      });
      
      tabContents.forEach((c) => {
        if (c.getAttribute('data-content') === tabId) {
          c.classList.remove('hidden');
        } else {
          c.classList.add('hidden');
        }
      });

      btn.classList.add('active', 'border-tabacco', 'text-black');
      btn.classList.remove('border-transparent', 'text-gray-500');
    });
  });
</script>
