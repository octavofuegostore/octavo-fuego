---
import '../styles/global.css';
import { Icon } from 'astro-icon/components';
import ToasterClient from '@/components/admin/ToasterClient';
import BodegaSwitcher from '@/components/admin/BodegaSwitcher';
import NotificationDropdown from '@/components/admin/notifications/NotificationDropdown.astro';
import { ClientRouter } from 'astro:transitions';
import { $sidebarOpen, $seccionActual } from '@/stores/admin';
import { supabase } from '@/lib/supabase';

const SUPABASE_CONFIGURED = !!(
  import.meta.env.PUBLIC_SUPABASE_URL &&
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
)
// Stock alert badge now lazy-loads via client-side JS after page render — no longer blocking
const stockAlertCount = 0

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Panel de administración de Octavo Fuego' } = Astro.props;
const currentPath = Astro.url.pathname;
const user = Astro.locals.user;

function getInitials(nameOrEmail?: string): string {
  if (!nameOrEmail) return 'OF';
  const parts = nameOrEmail.trim().split(/\s+/);
  if (parts.length === 1) {
    return parts[0].slice(0, 2).toUpperCase();
  }
  return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
}

const userName = user?.nombre || user?.email || 'Administrador';
const userInitials = getInitials(user?.nombre || user?.email || undefined);
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Admin Octavo Fuego</title>
    {description && <meta name="description" content={description} />}
    <ClientRouter />
  </head>
  <body class="bg-papel min-h-screen">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside
        id="admin-sidebar"
        transition:persist
        class="w-64 bg-humo text-papel flex flex-col transition-all duration-300 lg:translate-x-0 -translate-x-full fixed lg:static inset-y-0 left-0 z-50"
      >
        <!-- Logo -->
        <div class="p-4 border-b border-humo/50">
          <a href="/admin" class="flex items-center gap-3">
            <div class="w-10 h-10 bg-tabacco rounded-lg flex items-center justify-center">
              <span class="text-white font-display font-bold text-lg">OF</span>
            </div>
            <div>
              <span class="font-display text-lg font-bold block leading-tight">Octavo Fuego</span>
              <span class="text-xs text-ceniza">Admin Panel</span>
            </div>
          </a>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 p-4 overflow-y-auto">
          <ul class="space-y-1">
            <!-- Dashboard -->
            <li>
              <a
                href="/admin"
                class:list={[
                  "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors",
                  currentPath === "/admin"
                    ? "bg-tabacco text-white"
                    : "text-papel/70 hover:bg-humo/80 hover:text-papel"
                ]}
              >
                <Icon name="solar:chart-square-bold" class="w-5 h-5" />
                <span class="font-medium">Dashboard</span>
              </a>
            </li>

            <!-- Inventario -->
            <li>
              <button
                id="inventario-toggle"
                class:list={[
                  "w-full flex items-center justify-between px-3 py-2.5 rounded-lg transition-colors",
                  currentPath.startsWith("/admin/inventario")
                    ? "bg-tabacco text-white"
                    : "text-papel/70 hover:bg-humo/80 hover:text-papel"
                ]}
              >
                <div class="flex items-center gap-3">
                  <Icon name="solar:box-bold" class="w-5 h-5" />
                  <span class="font-medium">Inventario</span>
                  <span data-stock-alert-badge></span>
                </div>
                <svg class="w-4 h-4 transition-transform duration-200 inventario-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <ul id="inventario-submenu" class:list={[
                "mt-1 ml-8 space-y-1 overflow-hidden transition-all duration-200",
                currentPath.startsWith("/admin/inventario") ? "max-h-40 opacity-100" : "max-h-0 opacity-0"
              ]}>
                <li>
                  <a
                    href="/admin/inventario"
                    class:list={[
                      "block px-3 py-2 rounded-lg text-sm transition-colors",
                      currentPath === "/admin/inventario"
                        ? "bg-tabacco/20 text-tabacco"
                        : "text-papel/60 hover:bg-humo/60 hover:text-papel"
                    ]}
                  >
                    Productos
                  </a>
                </li>
                <li>
                  <a
                    href="/admin/inventario/stock"
                    class:list={[
                      "block px-3 py-2 rounded-lg text-sm transition-colors",
                      currentPath === "/admin/inventario/stock"
                        ? "bg-tabacco/20 text-tabacco"
                        : "text-papel/60 hover:bg-humo/60 hover:text-papel"
                    ]}
                  >
                    Stock
                  </a>
                </li>
                <li>
                  <a
                    href="/admin/inventario/transferencias"
                    class:list={[
                      "block px-3 py-2 rounded-lg text-sm transition-colors",
                      currentPath === "/admin/inventario/transferencias"
                        ? "bg-tabacco/20 text-tabacco"
                        : "text-papel/60 hover:bg-humo/60 hover:text-papel"
                    ]}
                  >
                    Transferencias
                  </a>
                </li>
              </ul>
            </li>

            <!-- Órdenes -->
            <li>
              <a
                href="/admin/ordenes"
                class:list={[
                  "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors",
                  currentPath.startsWith("/admin/ordenes")
                    ? "bg-tabacco text-white"
                    : "text-papel/70 hover:bg-humo/80 hover:text-papel"
                ]}
              >
                <Icon name="solar:cart-large-2-bold" class="w-5 h-5" />
                <span class="font-medium">Órdenes</span>
              </a>
            </li>

            <!-- Pagos -->
            <li>
              <a
                href="/admin/pagos"
                class:list={[
                  "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors",
                  currentPath.startsWith("/admin/pagos")
                    ? "bg-tabacco text-white"
                    : "text-papel/70 hover:bg-humo/80 hover:text-papel"
                ]}
              >
                <Icon name="solar:card-bold" class="w-5 h-5" />
                <span class="font-medium">Pagos</span>
              </a>
            </li>

            <!-- Clientes -->
            <li>
              <button
                id="clientes-toggle"
                class:list={[
                  "w-full flex items-center justify-between px-3 py-2.5 rounded-lg transition-colors",
                  currentPath.startsWith("/admin/clientes")
                    ? "bg-tabacco text-white"
                    : "text-papel/70 hover:bg-humo/80 hover:text-papel"
                ]}
              >
                <div class="flex items-center gap-3">
                  <Icon name="solar:users-group-rounded-bold" class="w-5 h-5" />
                  <span class="font-medium">Clientes</span>
                </div>
                <svg class="w-4 h-4 transition-transform duration-200 clientes-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <ul id="clientes-submenu" class:list={[
                "mt-1 ml-8 space-y-1 overflow-hidden transition-all duration-200",
                currentPath.startsWith("/admin/clientes") ? "max-h-40 opacity-100" : "max-h-0 opacity-0"
              ]}>
                <li>
                  <a
                    href="/admin/clientes"
                    class:list={[
                      "block px-3 py-2 rounded-lg text-sm transition-colors",
                      currentPath === "/admin/clientes"
                        ? "bg-tabacco/20 text-tabacco"
                        : "text-papel/60 hover:bg-humo/60 hover:text-papel"
                    ]}
                  >
                    Todos
                  </a>
                </li>
                <li>
                  <a
                    href="/admin/clientes/b2b"
                    class:list={[
                      "block px-3 py-2 rounded-lg text-sm transition-colors",
                      currentPath.startsWith("/admin/clientes/b2b")
                        ? "bg-tabacco/20 text-tabacco"
                        : "text-papel/60 hover:bg-humo/60 hover:text-papel"
                    ]}
                  >
                    Solicitudes B2B
                  </a>
                </li>
              </ul>
            </li>

            <!-- Contabilidad -->
            <li>
              <button
                id="contabilidad-toggle"
                class:list={[
                  "w-full flex items-center justify-between px-3 py-2.5 rounded-lg transition-colors",
                  currentPath.startsWith("/admin/contabilidad")
                    ? "bg-tabacco text-white"
                    : "text-papel/70 hover:bg-humo/80 hover:text-papel"
                ]}
              >
                <div class="flex items-center gap-3">
                  <Icon name="solar:clipboard-list-bold" class="w-5 h-5" />
                  <span class="font-medium">Contabilidad</span>
                </div>
                <svg class="w-4 h-4 transition-transform duration-200 contabilidad-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <ul id="contabilidad-submenu" class:list={[
                "mt-1 ml-8 space-y-1 overflow-hidden transition-all duration-200",
                currentPath.startsWith("/admin/contabilidad") ? "max-h-40 opacity-100" : "max-h-0 opacity-0"
              ]}>
                <li>
                  <a
                    href="/admin/contabilidad"
                    class:list={[
                      "block px-3 py-2 rounded-lg text-sm transition-colors",
                      currentPath === "/admin/contabilidad"
                        ? "bg-tabacco/20 text-tabacco"
                        : "text-papel/60 hover:bg-humo/60 hover:text-papel"
                    ]}
                  >Dashboard</a>
                </li>
                <li>
                  <a
                    href="/admin/contabilidad/transacciones"
                    class:list={[
                      "block px-3 py-2 rounded-lg text-sm transition-colors",
                      currentPath === "/admin/contabilidad/transacciones"
                        ? "bg-tabacco/20 text-tabacco"
                        : "text-papel/60 hover:bg-humo/60 hover:text-papel"
                    ]}
                  >Transacciones</a>
                </li>
                <li>
                  <a
                    href="/admin/contabilidad/informes"
                    class:list={[
                      "block px-3 py-2 rounded-lg text-sm transition-colors",
                      currentPath === "/admin/contabilidad/informes"
                        ? "bg-tabacco/20 text-tabacco"
                        : "text-papel/60 hover:bg-humo/60 hover:text-papel"
                    ]}
                  >Informes</a>
                </li>
              </ul>
            </li>

            <!-- Configuración -->
            <li>
              <a
                href="/admin/configuracion"
                class:list={[
                  "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors",
                  currentPath === "/admin/configuracion"
                    ? "bg-tabacco text-white"
                    : "text-papel/70 hover:bg-humo/80 hover:text-papel"
                ]}
              >
                <Icon name="solar:settings-bold" class="w-5 h-5" />
                <span class="font-medium">Configuración</span>
              </a>
            </li>

            <!-- Actividad -->
            <li>
              <a
                href="/admin/actividad"
                class:list={[
                  "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors",
                  currentPath === "/admin/actividad"
                    ? "bg-tabacco text-white"
                    : "text-papel/70 hover:bg-humo/80 hover:text-papel"
                ]}
              >
                <Icon name="solar:clock-circle-bold" class="w-5 h-5" />
                <span class="font-medium">Actividad</span>
              </a>
            </li>
          </ul>
        </nav>

        <!-- User section -->
        <div class="p-4 border-t border-humo/50">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-tabacco/20 rounded-full flex items-center justify-center">
              <span class="text-tabacco font-medium text-sm">{userInitials}</span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-papel truncate">{userName}</p>
              <p class="text-xs text-ceniza truncate">{user?.role || 'Admin'}</p>
            </div>
            <a
              href="/api/auth/logout"
              class="flex items-center gap-2 px-3 py-2 rounded-lg text-papel/70 hover:text-papel hover:bg-humo/80 transition-colors"
              title="Cerrar sesión"
            >
              <Icon name="solar:logout-2-bold" class="w-5 h-5" />
              <span class="text-sm font-medium">Cerrar Sesión</span>
            </a>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col min-w-0">
        <!-- Header -->
        <header class="h-16 bg-white border-b border-papel flex items-center justify-between px-6 sticky top-0 z-40">
          <!-- Mobile menu button -->
          <button
            id="mobile-menu-toggle"
            class="lg:hidden text-humo hover:text-tabacco transition-colors"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

          <!-- Search -->
          <div class="flex-1 max-w-md mx-4">
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input
                id="admin-global-search"
                type="text"
                placeholder="Buscar productos, órdenes, clientes... (Enter para buscar)"
                class="w-full pl-10 pr-4 py-2 border border-papel rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-tabacco/20 focus:border-tabacco transition-colors"
              />
            </div>
          </div>

          <!-- Right section -->
          <div class="flex items-center gap-4">
            <!-- Bodega Switcher -->
            <BodegaSwitcher client:idle />

            <!-- Notifications -->
            <NotificationDropdown usuarioId={user?.sub} />

            <!-- Quick actions -->
            <div class="relative">
              <button
                id="admin-quick-create-btn"
                class="flex items-center gap-2 px-3 py-2 bg-tabacco text-white rounded-lg text-sm font-medium hover:bg-tabacco/90 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Nuevo
                <svg class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div id="quick-create-dropdown" class="absolute right-0 top-full mt-1 w-56 bg-white rounded-xl shadow-lg border border-papel py-2 hidden z-50">
                <a href="/admin/inventario?action=create" class="flex items-center gap-3 px-4 py-2.5 text-sm text-humo hover:bg-papel/50 transition-colors">
                  <svg class="w-4 h-4 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                  </svg>
                  Nuevo Producto
                </a>
                <button id="quick-create-cliente" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-humo hover:bg-papel/50 transition-colors text-left">
                  <svg class="w-4 h-4 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                  </svg>
                  Nuevo Cliente
                </button>
                <a href="/admin/contabilidad/transacciones" class="flex items-center gap-3 px-4 py-2.5 text-sm text-humo hover:bg-papel/50 transition-colors">
                  <svg class="w-4 h-4 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                  </svg>
                  Nueva Transacción
                </a>
                <a href="/admin/ordenes" class="flex items-center gap-3 px-4 py-2.5 text-sm text-humo hover:bg-papel/50 transition-colors">
                  <svg class="w-4 h-4 text-ceniza" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                  </svg>
                  Nueva Orden
                </a>
              </div>
            </div>
          </div>
        </header>

        <!-- Page Content -->
        <main class="flex-1 overflow-y-auto p-6">
          <slot />
        </main>
      </div>
    </div>

    <!-- Mobile sidebar overlay -->
    <div
      id="sidebar-overlay"
      class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden"
    ></div>

    <!-- Sonner Toaster -->
    <ToasterClient client:load />

    <script>
      import { $sidebarOpen, $seccionActual } from '@/stores/admin'

      // ── STORE SUBSCRIPTION (module scope — runs once per ESM module lifecycle) ──
      $sidebarOpen.subscribe((open) => {
        const el = document.getElementById('admin-sidebar')
        if (!el) return
        if (window.innerWidth < 1024) return
        el.classList.toggle('-translate-x-full', !open)
      })

      // ── PATH DETECTION + SUBMENU RESET (runs on every navigation) ──
      function initAdminUI() {
        const path = window.location.pathname

        // Set active section from path
        if (path.includes('/admin/ordenes')) $seccionActual.set('ordenes')
        else if (path.includes('/admin/pagos')) $seccionActual.set('pagos')
        else if (path.includes('/admin/clientes/b2b')) $seccionActual.set('b2b')
        else if (path.includes('/admin/clientes')) $seccionActual.set('clientes')
        else if (path.includes('/admin/inventario/stock')) $seccionActual.set('stock')
        else if (path.includes('/admin/inventario')) $seccionActual.set('inventario')
        else if (path.includes('/admin/contabilidad/informes')) $seccionActual.set('informes')
        else if (path.includes('/admin/contabilidad/transacciones')) $seccionActual.set('transacciones')
        else if (path.includes('/admin/contabilidad')) $seccionActual.set('contabilidad')
        else if (path.includes('/admin/configuracion')) $seccionActual.set('configuracion')
        else if (path.includes('/admin/actividad')) $seccionActual.set('actividad')
        else $seccionActual.set('dashboard')

        // Reset submenu expand/collapse based on current path
        const entries = [
          { toggle: 'inventario', active: path.includes('/admin/inventario') },
          { toggle: 'clientes', active: path.includes('/admin/clientes') },
          { toggle: 'contabilidad', active: path.includes('/admin/contabilidad') },
        ]
        for (const { toggle, active } of entries) {
          const submenu = document.getElementById(`${toggle}-submenu`)
          const arrow = document.querySelector(`.${toggle}-arrow`)
          if (!submenu) continue
          if (active) {
            submenu.classList.remove('max-h-0', 'opacity-0')
            submenu.classList.add('max-h-40', 'opacity-100')
            arrow?.classList.add('rotate-180')
          } else {
            submenu.classList.remove('max-h-40', 'opacity-100', 'rotate-180')
            submenu.classList.add('max-h-0', 'opacity-0')
            arrow?.classList.remove('rotate-180')
          }
        }
      }

      // ── ONE-TIME UI SETUP (runs only once — init guard via data attribute) ──
      const sidebar = document.getElementById('admin-sidebar')
      if (sidebar && !sidebar.hasAttribute('data-ui-initialized')) {
        sidebar.setAttribute('data-ui-initialized', 'true')

        // Event delegation on <nav> for submenu toggles
        document.querySelector('nav')?.addEventListener('click', (e) => {
          const btn = (e.target as HTMLElement).closest('button[id$="-toggle"]')
          if (!btn) return
          const id = btn.id.replace('-toggle', '')
          const submenu = document.getElementById(`${id}-submenu`)
          const arrow = document.querySelector(`.${id}-arrow`)
          submenu?.classList.toggle('max-h-0')
          submenu?.classList.toggle('max-h-40')
          submenu?.classList.toggle('opacity-0')
          submenu?.classList.toggle('opacity-100')
          arrow?.classList.toggle('rotate-180')
        })

        // Sidebar-level delegation for mobile toggle, overlay
        sidebar.addEventListener('click', (e) => {
          const target = e.target as HTMLElement
          const toggle = target.closest('#mobile-menu-toggle')
          const overlayEl = target.closest('#sidebar-overlay')
          if (toggle) {
            sidebar.classList.toggle('-translate-x-full')
            document.getElementById('sidebar-overlay')?.classList.toggle('hidden')
          } else if (overlayEl) {
            sidebar.classList.add('-translate-x-full')
            document.getElementById('sidebar-overlay')?.classList.add('hidden')
          }
        })

        // ── Quick-create dropdown toggle (header button) ──
        document.getElementById('admin-quick-create-btn')?.addEventListener('click', (e) => {
          e.stopPropagation()
          document.getElementById('quick-create-dropdown')?.classList.toggle('hidden')
        })

        // Close quick-create dropdown on outside click
        document.addEventListener('click', (e) => {
          const btn = document.getElementById('admin-quick-create-btn')
          const dd = document.getElementById('quick-create-dropdown')
          if (!btn || !dd || dd.classList.contains('hidden')) return
          if (!btn.contains(e.target as Node) && !dd.contains(e.target as Node)) {
            dd.classList.add('hidden')
          }
        })

        // "Nuevo Cliente" in dropdown dispatches custom event for clientes page
        document.getElementById('quick-create-cliente')?.addEventListener('click', () => {
          const path = window.location.pathname
          if (path.startsWith('/admin/clientes')) {
            window.dispatchEvent(new CustomEvent('edit-customer', { detail: null }))
          } else {
            window.location.href = '/admin/clientes'
          }
          document.getElementById('quick-create-dropdown')?.classList.add('hidden')
        })

        // ── Global search (Enter key navigates to most likely page) ──
        document.getElementById('admin-global-search')?.addEventListener('keydown', (e) => {
          if (e.key !== 'Enter') return
          const input = e.currentTarget as HTMLInputElement
          const query = input.value.trim()
          if (!query) return

          // Order ID pattern: OF-2026-XXX or just a number
          if (/^OF-\d{4}-\d{3,}$/i.test(query)) {
            window.location.href = `/admin/ordenes?search=${encodeURIComponent(query)}`
            return
          }
          if (/^\d{3,}$/.test(query)) {
            window.location.href = `/admin/ordenes?search=OF-2026-${query}`
            return
          }

          // SKU pattern: XXX-000
          if (/^[A-Z]{3,4}-\d+$/i.test(query)) {
            window.location.href = `/admin/inventario?search=${encodeURIComponent(query)}`
            return
          }

          // Default: search clientes page
          window.location.href = `/admin/clientes?search=${encodeURIComponent(query)}`
        })

        // Escape key closes mobile menu
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            sidebar.classList.add('-translate-x-full')
            document.getElementById('sidebar-overlay')?.classList.add('hidden')
          }
        })
      }

      // ── STOCK ALERT BADGE — lazy load after page render ──
      async function loadStockAlertBadge() {
        const inventarioItem = document.querySelector('[data-stock-alert-badge]')
        if (!inventarioItem) return
        try {
          const res = await fetch('/api/admin/inventario/stock-alert-count')
          if (!res.ok) return
          const { count } = await res.json()
          if (count > 0) {
            inventarioItem.innerHTML = `
              <span class="ml-2 w-5 h-5 bg-error text-white text-xs rounded-full flex items-center justify-center font-medium">
                ${count > 9 ? '9+' : count}
              </span>
            `
          }
        } catch {
          // silently fail — badge stays hidden
        }
      }

      // Run on initial load and after every ClientRouter navigation
      initAdminUI()
      document.addEventListener('astro:page-load', () => {
        initAdminUI()
        // Re-fetch badge after navigation (ClientRouter)
        const existingBadge = document.querySelector('[data-stock-alert-badge] span')
        if (!existingBadge) loadStockAlertBadge()
      })

      // Initial badge load (runs once per module lifecycle)
      loadStockAlertBadge()
    </script>
  </body>
</html>
