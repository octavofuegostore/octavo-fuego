---
import '../styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import FloatingWhatsApp from '@/components/ui/FloatingWhatsApp.astro';
import OrganizationJsonLd from '@/components/seo/OrganizationJsonLd.astro';

interface Props {
  title?: string;
  description?: string;
  locale?: 'es' | 'en' | 'pt';
  ogImage?: string;
  ogType?: 'website' | 'product';
}

const {
  title = 'Octavo Fuego',
  description = 'Rapé do Acre, Sananga y Kuripes. Medicinas ancestrales amazónicas con propósito.',
  locale = 'es',
  ogImage = '/images/octavofuego-logo.png',
  ogType = 'website'
} = Astro.props;

const fullTitle = title === 'Octavo Fuego' ? title : `${title} | Octavo Fuego`;

// F6.1.1: Canonical always points to ES version (strip locale prefix)
const canonicalPath = Astro.url.pathname.replace(/^\/(en|pt)(?:\/|$)/, '/');
const canonicalUrl = new URL(canonicalPath, 'https://octavofuego.com').href;

const absoluteOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, 'https://octavofuego.com').href;

// Hreflang: regex-based locale extraction to avoid substring corruption
// (e.g., "beneficios", "principiantes" containing "en"/"pt")
const pathname = Astro.url.pathname;
const localeMatch = pathname.match(/^\/(es|en|pt)(\/.*)?$/i);
const matchedLocale = localeMatch ? localeMatch[1] : 'es';
const restPath = localeMatch ? (localeMatch[2] || '/') : (pathname || '/');

// F6.1.2: Language-only hreflang (no region subtags) + x-default pointing to ES
const hreflangLocales = [
  { tag: 'es', urlPrefix: '' },           // default locale — no prefix
  { tag: 'en', urlPrefix: '/en' },
  { tag: 'pt', urlPrefix: '/pt' },
];
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    
    <!-- Page-specific head slot FIRST so it takes priority over defaults -->
    <slot name="head" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang Tags (language-only: es, en, pt) -->
    {
      hreflangLocales.map(({ tag, urlPrefix }) => (
        <link rel="alternate" hreflang={tag} href={`https://octavofuego.com${urlPrefix}${restPath}`} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={`https://octavofuego.com${restPath}`} />
    
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Octavo Fuego" />
    <meta property="og:locale" content={locale === 'es' ? 'es_CO' : locale === 'en' ? 'en_US' : 'pt_BR'} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
    
    <!-- Organization Schema -->
    <OrganizationJsonLd />

    <!-- CSS-first breakpoint detection -->
    <script>
      document.addEventListener('astro:after-swap', () => {
        const setBreakpoint = () => {
          const w = window.innerWidth;
          if (w >= 1024) document.documentElement.dataset.breakpoint = 'lg';
          else if (w >= 768) document.documentElement.dataset.breakpoint = 'md';
          else document.documentElement.dataset.breakpoint = 'sm';
        };
        setBreakpoint();
        window.addEventListener('resize', setBreakpoint);
      });
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-black" style="padding-bottom: env(safe-area-inset-bottom,0px)">
    <Navbar locale={locale} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
    <FloatingWhatsApp />
  </body>
</html>
